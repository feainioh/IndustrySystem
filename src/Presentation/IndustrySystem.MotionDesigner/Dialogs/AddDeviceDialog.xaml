<Window x:Class="IndustrySystem.MotionDesigner.Dialogs.AddDeviceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    Title="添加新设备" 
    Height="500" 
    Width="600"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="{DynamicResource MaterialDesignPaper}">
    
<b:Interaction.Triggers>
    <b:DataTrigger Binding="{Binding DialogResult}" Value="True">
        <b:ChangePropertyAction PropertyName="DialogResult" Value="True"/>
        <b:CallMethodAction TargetObject="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                           MethodName="Close"/>
    </b:DataTrigger>
    <b:DataTrigger Binding="{Binding DialogResult}" Value="False">
        <b:ChangePropertyAction PropertyName="DialogResult" Value="False"/>
        <b:CallMethodAction TargetObject="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                           MethodName="Close"/>
    </b:DataTrigger>
</b:Interaction.Triggers>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Border Grid.Row="0" 
                Background="{DynamicResource PrimaryHueLightBrush}" 
                CornerRadius="8" 
                Padding="16,12"
                Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" 
                                            Width="24" 
                                            Height="24" 
                                            VerticalAlignment="Center" 
                                            Margin="0,0,8,0"/>
                    <TextBlock Text="添加新设备" 
                              FontSize="20" 
                              FontWeight="Bold" 
                              VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="选择设备类型并输入设备参数" 
                          FontSize="13" 
                          Opacity="0.7" 
                          Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- 表单内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">
                <!-- 设备类型 -->
                <TextBlock Text="设备类型" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding DeviceTypes}"
                         SelectedIndex="{Binding SelectedDeviceTypeIndex}"
                         materialDesign:HintAssist.Hint="选择设备类型"
                         Margin="0,0,0,16"/>

                <!-- 设备 ID -->
                <TextBox Text="{Binding DeviceId, UpdateSourceTrigger=PropertyChanged}"
                        materialDesign:HintAssist.Hint="设备 ID *"
                        materialDesign:HintAssist.IsFloating="True"
                        Margin="0,0,0,16"/>

                <!-- 设备名称 -->
                <TextBox Text="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}"
                        materialDesign:HintAssist.Hint="设备名称 *"
                        materialDesign:HintAssist.IsFloating="True"
                        Margin="0,0,0,16"/>

                <!-- 设备描述 -->
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                        materialDesign:HintAssist.Hint="设备描述（可选）"
                        materialDesign:HintAssist.IsFloating="True"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        Height="80"
                        VerticalScrollBarVisibility="Auto"
                        Margin="0,0,0,16"/>

                <!-- 连接参数区域 -->
                <Expander Header="连接参数" IsExpanded="True" Margin="0,0,0,8">
                    <StackPanel Margin="16,8">
                        <!-- CAN 设备 -->
                        <StackPanel Visibility="{Binding ShowCanParameters, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBox Text="{Binding CanNodeId, UpdateSourceTrigger=PropertyChanged}"
                                    materialDesign:HintAssist.Hint="CAN 节点 ID"
                                    materialDesign:HintAssist.IsFloating="True"
                                    Margin="0,0,0,8"/>
                        </StackPanel>

                        <!-- 串口设备 -->
                        <StackPanel Visibility="{Binding ShowSerialPortParameters, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ComboBox ItemsSource="{Binding SerialPorts}"
                                     SelectedIndex="{Binding SelectedPortIndex}"
                                     materialDesign:HintAssist.Hint="串口号"
                                     Margin="0,0,0,8"/>
                            <TextBox Text="{Binding BaudRate, UpdateSourceTrigger=PropertyChanged}"
                                    materialDesign:HintAssist.Hint="波特率"
                                    materialDesign:HintAssist.IsFloating="True"
                                    Margin="0,0,0,8"/>
                        </StackPanel>

                        <!-- 网络设备 -->
                        <StackPanel Visibility="{Binding ShowNetworkParameters, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                                    materialDesign:HintAssist.Hint="IP 地址"
                                    materialDesign:HintAssist.IsFloating="True"
                                    Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                    materialDesign:HintAssist.Hint="端口号"
                                    materialDesign:HintAssist.IsFloating="True"
                                    Margin="0,0,0,8"/>
                        </StackPanel>

                        <!-- EtherCAT 设备 -->
                        <StackPanel Visibility="{Binding ShowEtherCatParameters, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBox Text="{Binding SlaveId, UpdateSourceTrigger=PropertyChanged}"
                                    materialDesign:HintAssist.Hint="从站 ID"
                                    materialDesign:HintAssist.IsFloating="True"
                                    Margin="0,0,0,8"/>
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <!-- 提示信息 -->
                <Border Background="#1A2196F3" 
                       CornerRadius="4" 
                       Padding="12,8"
                       Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Information" 
                                                VerticalAlignment="Center" 
                                                Margin="0,0,8,0"
                                                Foreground="#2196F3"/>
                        <TextBlock Text="添加设备后，可以在位置列表中为该设备添加工作位置" 
                                  TextWrapping="Wrap" 
                                  VerticalAlignment="Center"
                                  Opacity="0.8"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="2" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right"
                   Margin="0,16,0,0">
            <Button Content="取消" 
                   Style="{StaticResource MaterialDesignOutlinedButton}"
                   Command="{Binding CancelCommand}"
                   Width="100"
                   Margin="0,0,8,0"/>
            <Button Content="添加" 
                   Style="{StaticResource MaterialDesignRaisedButton}"
                   Command="{Binding AddCommand}"
                   Width="100"/>
        </StackPanel>
    </Grid>
</Window>
