<Window x:Class="IndustrySystem.MotionDesigner.Dialogs.AddPositionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    Title="添加工作位置" 
    Height="450" 
    Width="550"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="{DynamicResource MaterialDesignPaper}">
    
<b:Interaction.Triggers>
    <b:DataTrigger Binding="{Binding DialogResult}" Value="True">
        <b:ChangePropertyAction PropertyName="DialogResult" Value="True"/>
        <b:CallMethodAction TargetObject="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                           MethodName="Close"/>
    </b:DataTrigger>
    <b:DataTrigger Binding="{Binding DialogResult}" Value="False">
        <b:ChangePropertyAction PropertyName="DialogResult" Value="False"/>
        <b:CallMethodAction TargetObject="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                           MethodName="Close"/>
    </b:DataTrigger>
</b:Interaction.Triggers>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题区域 -->
        <Border Grid.Row="0" 
                Background="{DynamicResource PrimaryHueLightBrush}" 
                CornerRadius="8" 
                Padding="16,12"
                Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="MapMarkerPlus" 
                                            Width="28" 
                                            Height="28" 
                                            VerticalAlignment="Center" 
                                            Margin="0,0,12,0"/>
                    <TextBlock Text="添加工作位置" 
                              FontSize="22" 
                              FontWeight="Bold" 
                              VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="为设备添加新的工作位置点" 
                          FontSize="14" 
                          Opacity="0.8" 
                          Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- 表单内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">
                <!-- 选择设备 -->
                <Border Background="#1A2196F3" 
                       CornerRadius="8" 
                       Padding="16,12"
                       Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="Devices" 
                                                    VerticalAlignment="Center" 
                                                    Margin="0,0,8,0"
                                                    Foreground="#2196F3"/>
                            <TextBlock Text="选择目标设备" 
                                      FontWeight="SemiBold" 
                                      FontSize="15"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <ComboBox x:Name="DeviceComboBox"
                                 ItemsSource="{Binding AvailableDevices}"
                                 SelectedItem="{Binding SelectedDevice}"
                                 materialDesign:HintAssist.Hint="选择设备 *"
                                 DisplayMemberPath="DisplayName"
                                 Margin="0,8,0,0"
                                 FontSize="14"/>
                    </StackPanel>
                </Border>

                <!-- 位置信息 -->
                <Border Background="#1A4CAF50" 
                       CornerRadius="8" 
                       Padding="16,12"
                       Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="MapMarker" 
                                                    VerticalAlignment="Center" 
                                                    Margin="0,0,8,0"
                                                    Foreground="#4CAF50"/>
                            <TextBlock Text="位置参数" 
                                      FontWeight="SemiBold" 
                                      FontSize="15"
                                      VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 位置名称 -->
                        <TextBox x:Name="PositionNameTextBox"
                                Text="{Binding PositionName, UpdateSourceTrigger=PropertyChanged}"
                                materialDesign:HintAssist.Hint="位置名称 *"
                                materialDesign:HintAssist.IsFloating="True"
                                Margin="0,0,0,16"
                                FontSize="14"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 位置值 -->
                            <StackPanel Grid.Column="0">
                                <TextBox x:Name="PositionValueTextBox"
                                        Text="{Binding PositionValue, UpdateSourceTrigger=PropertyChanged}"
                                        materialDesign:HintAssist.Hint="位置值 *"
                                        materialDesign:HintAssist.IsFloating="True"
                                        FontSize="14"/>
                                <TextBlock Text="单位: mm / 度" 
                                          FontSize="11" 
                                          Opacity="0.6" 
                                          Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- 速度 -->
                            <StackPanel Grid.Column="2">
                                <TextBox x:Name="SpeedTextBox"
                                        Text="{Binding Speed, UpdateSourceTrigger=PropertyChanged}"
                                        materialDesign:HintAssist.Hint="速度 *"
                                        materialDesign:HintAssist.IsFloating="True"
                                        FontSize="14"/>
                                <TextBlock Text="单位: mm/s / 度/s" 
                                          FontSize="11" 
                                          Opacity="0.6" 
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 快速预设 -->
                <Expander Header="快速预设位置" 
                         Margin="0,0,0,16"
                         materialDesign:ExpanderAssist.HorizontalHeaderPadding="12,8">
                    <Border Background="{DynamicResource MaterialDesignDivider}" 
                           Padding="16,12"
                           Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="常用位置名称" 
                                      FontSize="13" 
                                      FontWeight="Medium" 
                                      Margin="0,0,0,8"/>
                            <WrapPanel>
                                <Button Content="原点位置" 
                                       Style="{StaticResource MaterialDesignOutlinedButton}"
                                       Margin="0,0,8,8"
                                       Padding="12,4"
                                       Command="{Binding PresetCommand}"
                                       CommandParameter="HOME_POS"/>
                                <Button Content="取样位置" 
                                       Style="{StaticResource MaterialDesignOutlinedButton}"
                                       Margin="0,0,8,8"
                                       Padding="12,4"
                                       Command="{Binding PresetCommand}"
                                       CommandParameter="SAMPLE_POS"/>
                                <Button Content="清洗位置" 
                                       Style="{StaticResource MaterialDesignOutlinedButton}"
                                       Margin="0,0,8,8"
                                       Padding="12,4"
                                       Command="{Binding PresetCommand}"
                                       CommandParameter="WASH_POS"/>
                                <Button Content="等待位置" 
                                       Style="{StaticResource MaterialDesignOutlinedButton}"
                                       Margin="0,0,8,8"
                                       Padding="12,4"
                                       Command="{Binding PresetCommand}"
                                       CommandParameter="WAIT_POS"/>
                                <Button Content="停靠位置" 
                                       Style="{StaticResource MaterialDesignOutlinedButton}"
                                       Margin="0,0,8,8"
                                       Padding="12,4"
                                       Command="{Binding PresetCommand}"
                                       CommandParameter="PARK_POS"/>
                                <Button Content="维护位置" 
                                       Style="{StaticResource MaterialDesignOutlinedButton}"
                                       Margin="0,0,8,8"
                                       Padding="12,4"
                                       Command="{Binding PresetCommand}"
                                       CommandParameter="MAINTENANCE_POS"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- 提示信息 -->
                <Border Background="#1AFF9800" 
                       CornerRadius="6" 
                       Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="InformationOutline" 
                                                VerticalAlignment="Center" 
                                                Margin="0,0,8,0"
                                                Foreground="#FF9800"/>
                        <TextBlock TextWrapping="Wrap" 
                                  VerticalAlignment="Center"
                                  FontSize="12">
                            <Run Text="提示：添加位置后，可以在右侧编辑器中进一步调整参数。"/>
                            <LineBreak/>
                            <Run Text="位置值和速度必须为有效数字。"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 按钮区域 -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 继续添加选项 -->
            <CheckBox x:Name="ContinueAddCheckBox"
                     Grid.Column="0"
                     Content="添加后继续添加"
                     IsChecked="{Binding ContinueAdding}"
                     VerticalAlignment="Center"
                     Margin="4,0,0,0"/>

            <!-- 操作按钮 -->
            <Button Grid.Column="1"
                   Content="取消" 
                   Style="{StaticResource MaterialDesignOutlinedButton}"
                   Command="{Binding CancelCommand}"
                   Width="100"
                   Margin="0,0,8,0"/>
            <Button Grid.Column="2"
                   Content="添加位置" 
                   Style="{StaticResource MaterialDesignRaisedButton}"
                   Command="{Binding AddCommand}"
                   Width="120">
                <Button.CommandParameter>
                    <materialDesign:PackIcon Kind="Plus"/>
                </Button.CommandParameter>
            </Button>
        </Grid>
    </Grid>
</Window>
