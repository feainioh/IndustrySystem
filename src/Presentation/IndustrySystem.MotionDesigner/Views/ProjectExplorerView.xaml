<UserControl x:Class="IndustrySystem.MotionDesigner.Views.ProjectExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:IndustrySystem.MotionDesigner.Models"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MaterialDesignPaper}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- 子程序类型图标转换器 -->
        <Style x:Key="ProgramTypeIcon" TargetType="materialDesign:PackIcon">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <!-- 树节点样式 -->
        <Style x:Key="TreeItemStyle" TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" Padding="12,8">
            <Grid>
                <TextBlock Text="项目资源管理器" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                            Command="{Binding NewProjectCommand}" 
                            ToolTip="新建项目" Foreground="White" Width="28" Height="28">
                        <materialDesign:PackIcon Kind="FolderPlusOutline" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                            Command="{Binding OpenProjectCommand}" 
                            ToolTip="打开项目" Foreground="White" Width="28" Height="28">
                        <materialDesign:PackIcon Kind="FolderOpenOutline" Width="18" Height="18"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                            Command="{Binding SaveProjectCommand}" 
                            ToolTip="保存项目" Foreground="White" Width="28" Height="28">
                        <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 项目信息 -->
        <Border Grid.Row="1" Padding="8,4" Background="{DynamicResource MaterialDesignToolBarBackground}"
                Visibility="{Binding HasProject, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ProjectTitle}" FontWeight="SemiBold" 
                          VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource MaterialDesignIconButton}" 
                            Command="{Binding AddSubProjectCommand}" 
                            ToolTip="添加子项目" Width="24" Height="24">
                        <materialDesign:PackIcon Kind="FolderPlus" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 项目树 -->
        <TreeView Grid.Row="2" x:Name="ProjectTree"
                  ItemsSource="{Binding CurrentProject.SubProjects}"
                  SelectedItemChanged="OnTreeViewSelectedItemChanged"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  Visibility="{Binding HasProject, Converter={StaticResource BooleanToVisibilityConverter}}">
            
            <TreeView.Resources>
                <!-- 子项目模板 -->
                <HierarchicalDataTemplate DataType="{x:Type models:SubProject}" 
                                         ItemsSource="{Binding SubPrograms}">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <materialDesign:PackIcon Kind="FolderOutline" Width="18" Height="18" 
                                                VerticalAlignment="Center" Margin="0,0,6,0"
                                                Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="添加子程序" Command="{Binding DataContext.AddSubProgramCommand, 
                                         RelativeSource={RelativeSource AncestorType=TreeView}}">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="Plus"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="导入子程序" Command="{Binding DataContext.ImportSubProgramCommand, 
                                         RelativeSource={RelativeSource AncestorType=TreeView}}">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="Import"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="重命名" Command="{Binding DataContext.RenameItemCommand, 
                                         RelativeSource={RelativeSource AncestorType=TreeView}}">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="Pencil"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="删除" Command="{Binding DataContext.DeleteItemCommand, 
                                         RelativeSource={RelativeSource AncestorType=TreeView}}"
                                         Foreground="Red">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="Delete" Foreground="Red"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                    </StackPanel>
                </HierarchicalDataTemplate>

                <!-- 子程序模板 -->
                <DataTemplate DataType="{x:Type models:SubProgram}">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <materialDesign:PackIcon Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Kind" Value="FileDocumentOutline"/>
                                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ProgramType}" Value="Main">
                                            <Setter Property="Kind" Value="Play"/>
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ProgramType}" Value="Initialize">
                                            <Setter Property="Kind" Value="Cog"/>
                                            <Setter Property="Foreground" Value="#2196F3"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ProgramType}" Value="ErrorHandler">
                                            <Setter Property="Kind" Value="AlertCircle"/>
                                            <Setter Property="Foreground" Value="#F44336"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ProgramType}" Value="Cleanup">
                                            <Setter Property="Kind" Value="Broom"/>
                                            <Setter Property="Foreground" Value="#FF9800"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsModified}" Value="True">
                                            <Setter Property="Foreground" Value="#E91E63"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>
                        <TextBlock VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding Name}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModified}" Value="True">
                                            <Setter Property="Text" Value="{Binding Name, StringFormat={}{0} *}"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="打开" Command="{Binding DataContext.OpenSubProgramCommand, 
                                         RelativeSource={RelativeSource AncestorType=TreeView}}"
                                         CommandParameter="{Binding}">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="OpenInNew"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="复制" Command="{Binding DataContext.DuplicateSubProgramCommand, 
                                         RelativeSource={RelativeSource AncestorType=TreeView}}">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="ContentCopy"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="导出" Command="{Binding DataContext.ExportSubProgramCommand, 
                                         RelativeSource={RelativeSource AncestorType=TreeView}}">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="Export"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="重命名" Command="{Binding DataContext.RenameItemCommand, 
                                         RelativeSource={RelativeSource AncestorType=TreeView}}">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="Pencil"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="删除" Command="{Binding DataContext.DeleteItemCommand, 
                                         RelativeSource={RelativeSource AncestorType=TreeView}}"
                                         Foreground="Red">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="Delete" Foreground="Red"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                        <StackPanel.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" 
                                         Command="{Binding DataContext.OpenSubProgramCommand, 
                                         RelativeSource={RelativeSource AncestorType=TreeView}}"
                                         CommandParameter="{Binding}"/>
                        </StackPanel.InputBindings>
                    </StackPanel>
                </DataTemplate>
            </TreeView.Resources>

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                    <Setter Property="Padding" Value="4,2"/>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <!-- 无项目提示 -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                   Visibility="{Binding HasProject, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
            <materialDesign:PackIcon Kind="FolderAlertOutline" Width="48" Height="48" 
                                    HorizontalAlignment="Center" Opacity="0.3"/>
            <TextBlock Text="无打开的项目" Opacity="0.5" Margin="0,8,0,0" HorizontalAlignment="Center"/>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" 
                   Command="{Binding NewProjectCommand}" Margin="0,16,0,4">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FolderPlusOutline" Margin="0,0,4,0"/>
                    <TextBlock Text="新建项目"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" 
                   Command="{Binding OpenProjectCommand}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FolderOpenOutline" Margin="0,0,4,0"/>
                    <TextBlock Text="打开项目"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- 状态栏 -->
        <Border Grid.Row="3" Padding="8,4" Background="{DynamicResource MaterialDesignToolBarBackground}">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Opacity="0.7"/>
        </Border>
    </Grid>
</UserControl>
