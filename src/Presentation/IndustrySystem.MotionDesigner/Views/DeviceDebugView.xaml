<UserControl x:Class="IndustrySystem.MotionDesigner.Views.DeviceDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:deviceDebug="clr-namespace:IndustrySystem.MotionDesigner.Controls.DeviceDebug"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MaterialDesignPaper}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        
        <!-- Inverse Boolean to Visibility Converter -->
        <Style x:Key="InverseBooleanToVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDeviceSelected}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <!-- 设备项模板 -->
        <DataTemplate x:Key="DeviceItemTemplate">
            <Grid Margin="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Grid.Column="0" 
                                        Kind="{Binding IconKind, FallbackValue=Cog}" 
                                        VerticalAlignment="Center" 
                                        Margin="0,0,12,0"
                                        Width="20"
                                        Height="20"
                                        Opacity="0.7"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="14"/>
                    <TextBlock Text="{Binding DeviceType}" FontSize="12" Opacity="0.6" Margin="0,2,0,0"/>
                </StackPanel>
                <Ellipse Grid.Column="2" 
                        Width="10" Height="10" 
                        VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#4CAF50"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                    <Setter Property="Fill" Value="#9E9E9E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
            </Grid>
        </DataTemplate>
        
        <!-- 分类模板 -->
        <HierarchicalDataTemplate x:Key="CategoryTemplate" 
                                  ItemsSource="{Binding Devices}"
                                  ItemTemplate="{StaticResource DeviceItemTemplate}">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Grid.Column="0" 
                                        Kind="{Binding IconKind}" 
                                        VerticalAlignment="Center" 
                                        Margin="0,0,12,0"
                                        Width="22"
                                        Height="22"
                                        Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Grid.Column="1" 
                          Text="{Binding CategoryName}" 
                          FontWeight="SemiBold" 
                          FontSize="15"
                          VerticalAlignment="Center"/>
                <Border Grid.Column="2" 
                       Background="{DynamicResource PrimaryHueLightBrush}" 
                       CornerRadius="10"
                       Padding="8,4"
                       Margin="8,0,0,0">
                    <TextBlock Text="{Binding DeviceCount}" 
                              FontSize="12" 
                              FontWeight="Medium"
                              Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                </Border>
            </Grid>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <materialDesign:ColorZone Mode="PrimaryMid" Padding="16,12" materialDesign:ElevationAssist.Elevation="Dp4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding CreateConfigCommand}" 
                           Style="{StaticResource MaterialDesignRaisedButton}"
                           Height="36"
                           Margin="0,0,8,0"
                           Background="#4CAF50"
                           BorderBrush="#4CAF50"
                           ToolTip="Create new configuration">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="新建配置" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ImportConfigCommand}" 
                           Style="{StaticResource MaterialDesignRaisedButton}"
                           Height="36"
                           Margin="0,0,12,0"
                           ToolTip="Import hardware configuration">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileImport" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="导入配置" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshDeviceStatusCommand}" 
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Height="36"
                           IsEnabled="{Binding IsDeviceSelected}"
                           ToolTip="Refresh device status">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="刷新状态" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Information" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                              FontSize="14"
                              FontWeight="Medium"
                              Opacity="0.95"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding ConnectDeviceCommand}" 
                           Style="{StaticResource MaterialDesignRaisedButton}"
                           Height="36"
                           IsEnabled="{Binding IsDeviceSelected}"
                           Background="#4CAF50"
                           BorderBrush="#4CAF50"
                           Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Link" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="连接" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DisconnectDeviceCommand}" 
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Height="36"
                           IsEnabled="{Binding IsDeviceSelected}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="LinkOff" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="断开" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧设备列表 -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,16,0" materialDesign:ElevationAssist.Elevation="Dp4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource PrimaryHueLightBrush}" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Devices" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="设备列表" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                   Background="{DynamicResource PrimaryHueMidBrush}"
                                   CornerRadius="12"
                                   Padding="10,4">
                                <TextBlock Text="{Binding AllDevices.Count, StringFormat='共 {0} 个设备'}" 
                                          FontSize="12"
                                          FontWeight="Medium"
                                          Foreground="White"/>
                            </Border>
                        </Grid>
                    </Border>
                    <TextBox Grid.Row="1" 
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                            materialDesign:HintAssist.Hint="搜索设备..."
                            materialDesign:TextFieldAssist.HasClearButton="True"
                            Margin="12,12,12,8"
                            FontSize="14"/>

                    <!-- 使用 TreeView 显示分组设备 -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <TreeView x:Name="DeviceTreeView"
                                 ItemsSource="{Binding DeviceCategories}"
                                 ItemTemplate="{StaticResource CategoryTemplate}"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 SelectedItemChanged="DeviceTreeView_SelectedItemChanged"
                                 Margin="8,0,8,8">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </ScrollViewer>
                </Grid>
            </materialDesign:Card>

            <!-- 右侧设备详情 -->
            <materialDesign:Card Grid.Column="1" materialDesign:ElevationAssist.Elevation="Dp4">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20">
                        <!-- 未选择设备提示 -->
                        <Border Background="{DynamicResource MaterialDesignDivider}" 
                               CornerRadius="12" 
                               Padding="40,60"
                               Style="{StaticResource InverseBooleanToVisibilityStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Devices" 
                                                        Width="64" 
                                                        Height="64" 
                                                        HorizontalAlignment="Center"
                                                        Opacity="0.3"
                                                        Margin="0,0,0,16"/>
                                <TextBlock Text="请从左侧列表选择设备" 
                                          FontSize="18" 
                                          FontWeight="Medium"
                                          Opacity="0.6" 
                                          HorizontalAlignment="Center"/>
                                <TextBlock Text="选择设备后可进行调试和配置操作" 
                                          FontSize="14" 
                                          Opacity="0.5" 
                                          HorizontalAlignment="Center"
                                          Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 已选择设备信息 -->
                        <StackPanel Visibility="{Binding IsDeviceSelected, Converter={StaticResource BoolToVisConverter}}">
                            <!-- 设备头部信息 -->
                            <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                                   CornerRadius="12" 
                                   Padding="20,16"
                                   Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <materialDesign:PackIcon Kind="Cog" 
                                                            Width="48" 
                                                            Height="48"
                                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,16,0"/>
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedDevice.Name}" 
                                                  FontSize="22" 
                                                  FontWeight="Bold"/>
                                        <TextBlock Text="{Binding SelectedDevice.DeviceType}" 
                                                  FontSize="14" 
                                                  Opacity="0.7"
                                                  Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding SelectedDevice.DeviceId, StringFormat='设备ID: {0}'}" 
                                                  FontSize="13" 
                                                  Opacity="0.6"
                                                  Margin="0,4,0,0"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2" 
                                               Orientation="Horizontal"
                                               VerticalAlignment="Center">
                                        <Button Command="{Binding ConnectDeviceCommand}" 
                                               Style="{StaticResource MaterialDesignRaisedButton}"
                                               Background="#4CAF50"
                                               BorderBrush="#4CAF50"
                                               Height="36"
                                               Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Plug" Margin="0,0,8,0"/>
                                                <TextBlock Text="连接"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding DisconnectDeviceCommand}" 
                                               Style="{StaticResource MaterialDesignOutlinedButton}"
                                               Height="36">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="PowerPlugOffOutline" Margin="0,0,8,0"/>
                                                <TextBlock Text="断开"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 设备调试控件 -->
                            <!-- 通信类设备 -->
                            <deviceDebug:CommunicationDeviceControl 
                                DataContext="{Binding}"
                                Visibility="{Binding IsCommunicationDeviceSelected, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- 电机调试 -->
                            <deviceDebug:MotorDebugControl 
                                DataContext="{Binding MotorDebugVM}"
                                Visibility="{Binding DataContext.IsAnyMotorSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- IO 模块 -->
                            <deviceDebug:IODeviceControl 
                                DataContext="{Binding IODeviceDebugVM}"
                                Visibility="{Binding DataContext.IsIODeviceSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- 注射泵调试 -->
                            <deviceDebug:SyringePumpDebugControl 
                                DataContext="{Binding SyringePumpDebugVM}"
                                Visibility="{Binding DataContext.IsSyringePumpSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- 蠕动泵调试 -->
                            <deviceDebug:PeristalticPumpDebugConntrol 
                                DataContext="{Binding PeristalticPumpDebugVM}"
                                Visibility="{Binding DataContext.IsPeristalticPumpSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- 自定义泵调试 -->
                            <deviceDebug:DiyPumpDebugControl 
                                DataContext="{Binding DiyPumpDebugVM}"
                                Visibility="{Binding DataContext.IsDiyPumpSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- TCU温控调试 -->
                            <deviceDebug:TCUDebugControl 
                                DataContext="{Binding TCUDebugVM}"
                                Visibility="{Binding DataContext.IsTcuSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- 离心机调试 -->
                            <deviceDebug:CentrifugalDebugControl 
                                DataContext="{Binding CentrifugalDebugVM}"
                                Visibility="{Binding DataContext.IsCentrifugalSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- 称重传感器调试 -->
                            <deviceDebug:WeightSensorDebugControl 
                                DataContext="{Binding WeightSensorDebugVM}"
                                Visibility="{Binding DataContext.IsWeighingSensorSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- 扫码枪调试 -->
                            <deviceDebug:ScannerDebugControl 
                                DataContext="{Binding ScannerDebugVM}"
                                Visibility="{Binding DataContext.IsScannerSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- 机器人调试 -->
                            <deviceDebug:RobotDebugControl 
                                DataContext="{Binding RobotDebugVM}"
                                Visibility="{Binding DataContext.IsRobotSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" 
               Background="{DynamicResource MaterialDesignBackground}" 
               BorderBrush="{DynamicResource MaterialDesignDivider}" 
               BorderThickness="0,1,0,0"
               Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="InformationOutline" 
                                            Width="16" 
                                            Height="16" 
                                            Margin="0,0,8,0" 
                                            VerticalAlignment="Center"
                                            Opacity="0.6"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Opacity="0.7"/>
                </StackPanel>
                <Border Grid.Column="1"
                       Background="{DynamicResource PrimaryHueLightBrush}"
                       CornerRadius="8"
                       Padding="12,4">
                    <TextBlock FontSize="13" FontWeight="Medium">
                        <Run Text="已选择:"/>
                        <Run Text="{Binding SelectedDevice.Name, FallbackValue='无'}" FontWeight="Bold"/>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
