<UserControl x:Class="IndustrySystem.MotionDesigner.Views.PositionSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MaterialDesignPaper}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        
        <!-- Null to Visibility Converter -->
        <Style x:Key="NullVisibleStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.SelectedPosition, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="NullCollapsedStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.SelectedPosition, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <materialDesign:ColorZone Mode="PrimaryMid" Padding="12,8" materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding ImportConfigCommand}" 
                           Style="{StaticResource MaterialDesignRaisedButton}"
                           Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileImport" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="导入" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SaveConfigCommand}" 
                           Style="{StaticResource MaterialDesignRaisedButton}"
                           Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="保存" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ExportConfigCommand}" 
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Foreground="White" BorderBrush="White">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileExport" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="导出" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <TextBlock Grid.Column="1" 
                          Text="{Binding StatusMessage}" 
                          VerticalAlignment="Center" 
                          HorizontalAlignment="Center"
                          FontSize="14"
                          Foreground="White"
                          Opacity="0.9"/>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Command="{Binding AddDeviceCommand}" 
                           Style="{StaticResource MaterialDesignRaisedButton}"
                           Margin="0,0,8,0" 
                           ToolTip="添加新设备"
                           Background="#4CAF50">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Margin="0,0,4,0"/>
                            <TextBlock Text="添加设备"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding AddPositionCommand}" 
                           Style="{StaticResource MaterialDesignRaisedButton}"
                           Margin="0,0,8,0"
                           ToolTip="添加新位置"
                           Background="#2196F3">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="MapMarkerPlus" Margin="0,0,4,0"/>
                            <TextBlock Text="添加位置"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeletePositionCommand}" 
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Foreground="White" BorderBrush="White"
                           ToolTip="删除选中位置">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Delete" Margin="0,0,4,0"/>
                            <TextBlock Text="删除"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- 统计信息栏 -->
        <materialDesign:Card Grid.Row="1" Margin="8,8,8,0" Padding="12,8" materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="{DynamicResource PrimaryHueLightBrush}" CornerRadius="4" Padding="12,4" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FormatListBulleted" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding TotalPositionCount, StringFormat='总计: {0}'}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" Background="#E3F2FD" CornerRadius="4" Padding="12,4" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Engine" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#1976D2"/>
                        <TextBlock Text="{Binding MotorPositionCount, StringFormat='电机: {0}'}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="4" Padding="12,4" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Robot" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#388E3C"/>
                        <TextBlock Text="{Binding RobotPositionCount, StringFormat='机器人: {0}'}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="3" Background="#FFF3E0" CornerRadius="4" Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Pencil" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#F57C00"/>
                        <TextBlock Text="{Binding ModifiedCount, StringFormat='已修改: {0}'}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <TextBlock Grid.Column="5" Text="筛选:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="6" 
                         ItemsSource="{Binding DeviceFilters}" 
                         SelectedItem="{Binding SelectedDeviceFilter}"
                         materialDesign:HintAssist.Hint="选择设备"/>
            </Grid>
        </materialDesign:Card>

        <!-- 主内容区域 -->
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- 位置列表 -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,8,0" materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" Padding="12,8">
                        <TextBlock Text="位置列表" FontWeight="SemiBold" Foreground="White"/>
                    </Border>

                    <TextBox Grid.Row="1" 
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                            materialDesign:HintAssist.Hint="搜索位置..."
                            materialDesign:TextFieldAssist.HasClearButton="True"
                            Margin="8"/>

                    <DataGrid Grid.Row="2" 
                             ItemsSource="{Binding FilteredPositions}"
                             SelectedItem="{Binding SelectedPosition}"
                             AutoGenerateColumns="False"
                             CanUserAddRows="False"
                             CanUserDeleteRows="False"
                             SelectionMode="Single"
                             SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="设备名称" Binding="{Binding DeviceName}" Width="150" IsReadOnly="True"/>
                            <DataGridTextColumn Header="设备类型" Binding="{Binding DeviceType}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="位置名称" Binding="{Binding PositionName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="位置值" Binding="{Binding Position}" Width="100"/>
                            <DataGridTextColumn Header="速度" Binding="{Binding Speed}" Width="80"/>
                            <DataGridCheckBoxColumn Header="已修改" Binding="{Binding IsModified, Mode=OneWay}" Width="60" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <!-- 位置编辑器 -->
            <materialDesign:Card Grid.Column="1" materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" Padding="12,8">
                        <TextBlock Text="位置编辑" FontWeight="SemiBold" Foreground="White"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <!-- 未选择提示 -->
                            <StackPanel Style="{StaticResource NullVisibleStyle}"
                                       HorizontalAlignment="Center" Margin="0,50,0,0">
                                <materialDesign:PackIcon Kind="MapMarkerQuestion" Width="48" Height="48" 
                                                        HorizontalAlignment="Center" Opacity="0.3"/>
                                <TextBlock Text="请从列表中选择位置" FontSize="14" Opacity="0.5" 
                                          HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- 编辑区域 -->
                            <StackPanel Style="{StaticResource NullCollapsedStyle}"
                                       DataContext="{Binding SelectedPosition}">
                                
                                <TextBlock Text="{Binding DeviceName}" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding DeviceType}" FontSize="12" Opacity="0.6" Margin="0,0,0,16"/>
                                
                                <Separator Margin="0,0,0,16"/>
                                
                                <TextBlock Text="位置名称" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding PositionName}" IsReadOnly="True" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="位置值" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Position, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="速度" FontWeight="Medium" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Speed, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>
                                
                                <Separator Margin="0,0,0,16"/>
                                
                                <Button Command="{Binding DataContext.MoveToPositionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                       Style="{StaticResource MaterialDesignRaisedButton}"
                                       Background="#4CAF50"
                                       Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ArrowRight" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="移动到位置" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button Command="{Binding DataContext.TeachPositionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                       Style="{StaticResource MaterialDesignOutlinedButton}"
                                       Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="School" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="示教当前位置" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button Command="{Binding DataContext.ResetPositionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                       Style="{StaticResource MaterialDesignOutlinedButton}"
                                       Foreground="Orange">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Restore" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="重置为原始值" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
