<UserControl x:Class="IndustrySystem.MotionDesigner.Controls.DeviceDebug.WeightSensorDebugControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <materialDesign:Card Padding="24" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧状态和连接 -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <!-- 标题和状态 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="ScaleBalance" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="称重传感器调试" FontWeight="SemiBold" FontSize="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 状态指示器 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding WeightSensorConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已连接" FontSize="12" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                    </Border>
                    <Border Background="#4CAF50" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding WeightSensorStable, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="稳定" FontSize="12" Foreground="White"/>
                    </Border>
                    <Border Background="Orange" 
                           CornerRadius="12" Padding="12,4"
                           Visibility="{Binding WeightSensorZeroed, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已清零" FontSize="12" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- 当前重量显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="12" Padding="32,24" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="当前重量" FontSize="16" Opacity="0.7" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding WeightSensorCurrentWeight, StringFormat='{}{0:F3}', FallbackValue='0.000'}" 
                                      FontWeight="Bold" FontSize="48" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="g" FontSize="24" VerticalAlignment="Bottom" Margin="8,0,0,8" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 连接设置 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="连接设置" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="串口" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" 
                                     ItemsSource="{Binding SerialPorts}" 
                                     SelectedItem="{Binding SelectedWeightSensorPort}"
                                     materialDesign:HintAssist.Hint="选择串口"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="波特率" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedWeightSensor.BaudRate, FallbackValue='9600'}" FontWeight="Medium"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="从站地址" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedWeightSensor.SlaveAddress, FallbackValue='1'}" FontWeight="Medium"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding WeightSensorRefreshPortsCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="刷新" 
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding WeightSensorConnectCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="#4CAF50"
                                   BorderBrush="#4CAF50"
                                   Content="连接"
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding WeightSensorDisconnectCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="断开"
                                   Height="36"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 设备参数 -->
                <Expander Header="设备参数" IsExpanded="True">
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="最大量程" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedWeightSensor.MaxWeight, StringFormat='{}{0} g', FallbackValue='5000 g'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="精度" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedWeightSensor.Precision, StringFormat='{}{0} g', FallbackValue='0.001 g'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="小数位" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedWeightSensor.DecimalPlaces, FallbackValue='3'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="设备名称" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedWeightSensor.Name, FallbackValue='加粉传感器'}" FontWeight="Medium" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>
            </StackPanel>

            <!-- 右侧控制 -->
            <StackPanel Grid.Column="1">
                <!-- 基本操作 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="基本操作" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Command="{Binding WeightSensorReadCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Content="读取重量" 
                                   Height="40"
                                   IsEnabled="{Binding WeightSensorConnected}"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding WeightSensorZeroCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="清零" 
                                   Height="40"
                                   IsEnabled="{Binding WeightSensorConnected}"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding WeightSensorTareCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="去皮" 
                                   Height="40"
                                   IsEnabled="{Binding WeightSensorConnected}"/>
                        </StackPanel>

                        <CheckBox Content="自动读取" 
                                 IsChecked="{Binding WeightSensorAutoRead}"
                                 IsEnabled="{Binding WeightSensorConnected}"
                                 Margin="0,0,0,8"/>

                        <Grid Visibility="{Binding WeightSensorAutoRead, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="读取间隔" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding WeightSensorReadInterval}" Margin="12,0" materialDesign:HintAssist.Hint="毫秒"/>
                            <TextBlock Grid.Column="2" Text="ms" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 目标重量检测 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="目标重量检测" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="目标重量" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding WeightSensorTargetWeight}" Margin="12,0" materialDesign:HintAssist.Hint="输入目标"/>
                            <TextBlock Grid.Column="2" Text="g" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="允许偏差" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding WeightSensorTolerance}" Margin="12,0" materialDesign:HintAssist.Hint="输入偏差"/>
                            <TextBlock Grid.Column="2" Text="g" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding WeightSensorStartMonitorCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}" 
                                   Background="#4CAF50"
                                   BorderBrush="#4CAF50"
                                   Content="开始监测" 
                                   Height="36"
                                   IsEnabled="{Binding WeightSensorConnected}"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding WeightSensorStopMonitorCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="停止监测" 
                                   Height="36"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 校准 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="校准设置" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="校准砝码" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding WeightSensorCalibrationWeight}" Margin="12,0" materialDesign:HintAssist.Hint="标准砝码"/>
                            <TextBlock Grid.Column="2" Text="g" VerticalAlignment="Center"/>
                        </Grid>

                        <Button Command="{Binding WeightSensorCalibrateCommand}" 
                               Style="{StaticResource MaterialDesignOutlinedButton}" 
                               Content="执行校准" 
                               Height="36"
                               HorizontalAlignment="Stretch"
                               IsEnabled="{Binding WeightSensorConnected}"/>
                    </StackPanel>
                </Border>

                <!-- 状态显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="状态信息" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding WeightSensorStatus, FallbackValue='等待操作...'}" 
                                  Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
