<UserControl x:Class="IndustrySystem.MotionDesigner.Controls.DeviceDebug.RobotDebugControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <materialDesign:Card Padding="24" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧状态和连接 -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <!-- 标题和状态 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="Robot" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="机器人调试" FontWeight="SemiBold" FontSize="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 状态指示器 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding RobotConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已连接" FontSize="12" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                    </Border>
                    <Border Background="#4CAF50" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding RobotEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已使能" FontSize="12" Foreground="White"/>
                    </Border>
                    <Border Background="Orange" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding RobotMoving, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="运动中" FontSize="12" Foreground="White"/>
                    </Border>
                    <Border Background="Red" 
                           CornerRadius="12" Padding="12,4"
                           Visibility="{Binding RobotHasAlarm, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="报警" FontSize="12" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- 当前任务显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="当前任务" FontSize="16" Opacity="0.7" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding RobotCurrentTask, FallbackValue='空闲'}" 
                                  FontWeight="Bold" FontSize="24" 
                                  Foreground="{DynamicResource PrimaryHueMidBrush}"
                                  HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 连接设置 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="连接设置" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="IP地址" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" 
                                    Text="{Binding RobotIp}" 
                                    materialDesign:HintAssist.Hint="192.168.1.100"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="端口" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" 
                                    Text="{Binding RobotPort}" 
                                    materialDesign:HintAssist.Hint="502"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Command="{Binding RobotConnectCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="#4CAF50"
                                   BorderBrush="#4CAF50"
                                   Content="连接"
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding RobotDisconnectCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="断开"
                                   Height="36"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 设备参数 -->
                <Expander Header="设备参数" IsExpanded="True">
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="设备ID" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedJakaRobot.DeviceId, FallbackValue='-'}" FontWeight="Medium" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="设备名称" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedJakaRobot.Name, FallbackValue='-'}" FontWeight="Medium" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="机器人类型" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedJakaRobot.RobotType, FallbackValue='Jaka'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="机器人型号" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedJakaRobot.RobotModel, FallbackValue='Zu7'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="从站ID" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedJakaRobot.RobotParameters.SlaveId, FallbackValue='1'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="自动重连" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedJakaRobot.AutoReconnect, FallbackValue='True'}" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>
            </StackPanel>

            <!-- 右侧控制 -->
            <StackPanel Grid.Column="1">
                <!-- 使能控制 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="使能控制" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding RobotEnableCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="#4CAF50"
                                   BorderBrush="#4CAF50"
                                   Content="上使能"
                                   Height="36"
                                   IsEnabled="{Binding RobotConnected}"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding RobotDisableCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="下使能"
                                   Height="36"
                                   IsEnabled="{Binding RobotConnected}"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding RobotClearAlarmCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="清报警"
                                   Height="36"
                                   IsEnabled="{Binding RobotConnected}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 任务控制 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="任务控制" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="任务号" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" 
                                    Text="{Binding RobotTaskNumber}" 
                                    materialDesign:HintAssist.Hint="输入任务号"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Command="{Binding RobotExecuteTaskCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Content="执行任务"
                                   Height="36"
                                   IsEnabled="{Binding RobotConnected}"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding RobotContinueCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="继续执行"
                                   Height="36"
                                   IsEnabled="{Binding RobotConnected}"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding RobotStopCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="#F44336"
                                   BorderBrush="#F44336"
                                   Content="停止"
                                   Height="36"
                                   IsEnabled="{Binding RobotConnected}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 运动控制 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="运动控制" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0" Grid.Column="0" 
                                   Command="{Binding RobotMoveHomeCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="44"
                                   IsEnabled="{Binding RobotConnected}"
                                   Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Home" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text=" 回原点" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="0" Grid.Column="1" 
                                   Command="{Binding RobotMoveSafeCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="44"
                                   IsEnabled="{Binding RobotConnected}"
                                   Margin="8,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShieldCheck" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text=" 安全位" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="0" 
                                   Command="{Binding RobotPauseCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="44"
                                   IsEnabled="{Binding RobotConnected}"
                                   Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Pause" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text=" 暂停" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="1" 
                                   Command="{Binding RobotResumeCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="44"
                                   IsEnabled="{Binding RobotConnected}"
                                   Margin="8,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Play" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text=" 恢复" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 状态显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="状态信息" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding RobotStatus, FallbackValue='等待操作...'}" 
                                  Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
