<UserControl x:Class="IndustrySystem.MotionDesigner.Controls.DeviceDebug.ScannerDebugControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <materialDesign:Card Padding="24" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧状态和连接 -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <!-- 标题和状态 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="Barcode" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="扫码枪调试" FontWeight="SemiBold" FontSize="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 状态指示器 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding ScannerConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已连接" FontSize="12" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                    </Border>
                    <Border Background="#4CAF50" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding ScannerEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已启用" FontSize="12" Foreground="White"/>
                    </Border>
                    <Border Background="Orange" 
                           CornerRadius="12" Padding="12,4"
                           Visibility="{Binding ScannerScanning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="扫描中" FontSize="12" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- 扫描结果显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="扫描结果" FontSize="16" Opacity="0.7" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource MaterialDesignPaper}" 
                               CornerRadius="8" Padding="16,8" MinWidth="200">
                            <TextBlock Text="{Binding ScannerResult, FallbackValue='等待扫描...'}" 
                                      FontWeight="Bold" FontSize="20" 
                                      Foreground="{DynamicResource PrimaryHueMidBrush}"
                                      HorizontalAlignment="Center"
                                      TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 连接设置 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="连接设置" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="IP地址" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" 
                                    Text="{Binding ScannerIp}" 
                                    materialDesign:HintAssist.Hint="192.168.1.x"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="端口" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" 
                                    Text="{Binding ScannerPort}" 
                                    materialDesign:HintAssist.Hint="2002"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Command="{Binding ScannerConnectCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="#4CAF50"
                                   BorderBrush="#4CAF50"
                                   Content="连接"
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding ScannerDisconnectCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="断开"
                                   Height="36"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 设备参数 -->
                <Expander Header="设备参数" IsExpanded="True">
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="设备ID" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedScanner.DeviceId, FallbackValue='-'}" FontWeight="Medium" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="设备名称" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedScanner.Name, FallbackValue='-'}" FontWeight="Medium" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="触发命令" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedScanner.TriggerCommand, FallbackValue='T'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="连接超时" FontSize="11" Opacity="0.6"/>
                                <TextBlock FontWeight="Medium">
                                    <Run Text="{Binding SelectedScanner.ConnectionTimeout, FallbackValue='5000'}"/>
                                    <Run Text="ms"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="读取超时" FontSize="11" Opacity="0.6"/>
                                <TextBlock FontWeight="Medium">
                                    <Run Text="{Binding SelectedScanner.ReadTimeout, FallbackValue='3000'}"/>
                                    <Run Text="ms"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="启用状态" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedScanner.IsEnabled, FallbackValue='True'}" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>
            </StackPanel>

            <!-- 右侧控制 -->
            <StackPanel Grid.Column="1">
                <!-- 扫描控制 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="扫描控制" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <Button Command="{Binding ScannerScanCommand}" 
                               Style="{StaticResource MaterialDesignRaisedButton}"
                               Background="{DynamicResource PrimaryHueMidBrush}"
                               Height="56"
                               HorizontalAlignment="Stretch"
                               IsEnabled="{Binding ScannerConnected}"
                               Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="BarcodeScanner" Width="24" Height="24" VerticalAlignment="Center"/>
                                <TextBlock Text="  触发扫描" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding ScannerClearResultCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="清除结果"
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding ScannerCopyResultCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="复制结果"
                                   Height="36"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 连续扫描 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="连续扫描" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <CheckBox Content="启用连续扫描" 
                                 IsChecked="{Binding ScannerContinuousScan}"
                                 IsEnabled="{Binding ScannerConnected}"
                                 Margin="0,0,0,12"/>

                        <Grid Visibility="{Binding ScannerContinuousScan, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="扫描间隔" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding ScannerInterval}" Margin="12,0" materialDesign:HintAssist.Hint="毫秒"/>
                            <TextBlock Grid.Column="2" Text="ms" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding ScannerStartContinuousCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="#4CAF50"
                                   BorderBrush="#4CAF50"
                                   Content="开始"
                                   Height="36"
                                   IsEnabled="{Binding ScannerConnected}"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding ScannerStopContinuousCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="停止"
                                   Height="36"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 扫描历史 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="扫描历史" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ScannerHistory.Count, StringFormat=' ({0})'}" Opacity="0.6"/>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding ScannerHistory}" 
                                MaxHeight="150"
                                materialDesign:ListBoxAssist.IsToggle="False">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Barcode" Width="16" Height="16" Margin="0,0,8,0" Opacity="0.6"/>
                                        <TextBlock Text="{Binding}" FontSize="13"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Command="{Binding ScannerClearHistoryCommand}" 
                               Style="{StaticResource MaterialDesignFlatButton}"
                               Content="清除历史"
                               HorizontalAlignment="Right"
                               Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 状态显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="状态信息" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ScannerStatus, FallbackValue='等待操作...'}" 
                                  Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
