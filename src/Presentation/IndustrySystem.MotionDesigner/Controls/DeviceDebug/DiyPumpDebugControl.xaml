<UserControl x:Class="IndustrySystem.MotionDesigner.Controls.DeviceDebug.DiyPumpDebugControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <materialDesign:Card Padding="24" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧状态显示 -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <!-- 标题和状态 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="TuneVertical" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="自定义阀调试" FontWeight="SemiBold" FontSize="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 状态指示器 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding DiyPumpConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已连接" FontSize="12" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                    </Border>
                    <Border Background="#4CAF50" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding DiyPumpServoEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已使能" FontSize="12" Foreground="White"/>
                    </Border>
                    <Border Background="Orange" 
                           CornerRadius="12" Padding="12,4"
                           Visibility="{Binding DiyPumpIsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="运行中" FontSize="12" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- 当前位置显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="当前位置" FontSize="13" Opacity="0.7"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DiyPumpCurrentPosition, StringFormat='{}{0:F1}', FallbackValue='0.0'}" FontWeight="Bold" FontSize="28" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                <TextBlock Text="°" FontSize="18" Margin="4,0,0,0" VerticalAlignment="Bottom" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="目标位置" FontSize="13" Opacity="0.7"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DiyPumpTargetPosition, StringFormat='{}{0:F1}', FallbackValue='0.0'}" FontWeight="Bold" FontSize="28" Foreground="Orange"/>
                                <TextBlock Text="°" FontSize="18" Margin="4,0,0,0" VerticalAlignment="Bottom" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 设备参数 -->
                <Expander Header="设备参数" IsExpanded="True" Margin="0,0,0,16">
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="脉冲/转" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedDiyPump.PulsePerRevolution, FallbackValue='12800'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="减速比" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedDiyPump.GearRatio, FallbackValue='27'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="每转角度" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedDiyPump.DisplacementPerRevolution, StringFormat='{}{0}°', FallbackValue='360°'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="偏移位置" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedDiyPump.OffsetPostion, StringFormat='{}{0}°', FallbackValue='0°'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="通信ID" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedDiyPump.CommunicationId, FallbackValue='30'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="最大转速" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedDiyPump.MaxRPM, StringFormat='{}{0} RPM', FallbackValue='300 RPM'}" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>

                <!-- 快捷位置 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="快捷位置" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <WrapPanel>
                            <Button Content="0°" 
                                   Command="{Binding DiyPumpQuickMoveCommand}" 
                                   CommandParameter="0"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="36"
                                   Margin="0,0,8,8"/>
                            <Button Content="45°" 
                                   Command="{Binding DiyPumpQuickMoveCommand}" 
                                   CommandParameter="45"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="36"
                                   Margin="0,0,8,8"/>
                            <Button Content="90°" 
                                   Command="{Binding DiyPumpQuickMoveCommand}" 
                                   CommandParameter="90"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="36"
                                   Margin="0,0,8,8"/>
                            <Button Content="180°" 
                                   Command="{Binding DiyPumpQuickMoveCommand}" 
                                   CommandParameter="180"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="36"
                                   Margin="0,0,8,8"/>
                            <Button Content="270°" 
                                   Command="{Binding DiyPumpQuickMoveCommand}" 
                                   CommandParameter="270"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="36"
                                   Margin="0,0,8,8"/>
                            <Button Content="360°" 
                                   Command="{Binding DiyPumpQuickMoveCommand}" 
                                   CommandParameter="360"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="36"
                                   Margin="0,0,0,8"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 右侧控制区域 -->
            <StackPanel Grid.Column="1">
                <!-- 使能和报警控制 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Command="{Binding DiyPumpServoOnCommand}" 
                           Style="{StaticResource MaterialDesignRaisedButton}"
                           Background="#4CAF50"
                           BorderBrush="#4CAF50"
                           Content="上使能" 
                           Height="36"
                           Margin="0,0,12,0"/>
                    <Button Command="{Binding DiyPumpServoOffCommand}" 
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Content="下使能" 
                           Height="36"
                           Margin="0,0,12,0"/>
                    <Button Command="{Binding DiyPumpClearAlarmCommand}" 
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Content="清除报警" 
                           Height="36"
                           Margin="0,0,12,0"/>
                    <Button Command="{Binding DiyPumpResetCommand}" 
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Content="复位"
                           Height="36"/>
                </StackPanel>

                <!-- 运动参数 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="运动控制" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="目标角度" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding DiyPumpTarget}" Margin="12,0" materialDesign:HintAssist.Hint="输入角度"/>
                            <TextBlock Grid.Column="2" Text="°" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="转速" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding DiyPumpSpeed}" Margin="12,0" materialDesign:HintAssist.Hint="输入转速"/>
                            <TextBlock Grid.Column="2" Text="RPM" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="JOG步长" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding DiyPumpJogStep}" Margin="12,0" materialDesign:HintAssist.Hint="输入步长"/>
                            <TextBlock Grid.Column="2" Text="°" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox Content="相对运动" IsChecked="{Binding DiyPumpRelative}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding DiyPumpMoveCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Content="运行" 
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding DiyPumpHomeCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="回零" 
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding DiyPumpStopCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="Red"
                                   BorderBrush="Red"
                                   Content="停止"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- JOG控制 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="JOG 控制" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding DiyPumpJogNegativeCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="JOG - (逆时针)" 
                                   Width="130"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding DiyPumpJogPositiveCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="JOG + (顺时针)" 
                                   Width="130"
                                   Margin="0,0,12,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 状态显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="状态信息" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding DiyPumpStatus, FallbackValue='等待操作...'}" 
                                  Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
