<UserControl x:Class="IndustrySystem.MotionDesigner.Controls.DeviceDebug.MotorDebugControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <materialDesign:Card Padding="24" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧状态和参数 -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <!-- 标题和状态 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="Engine" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="电机调试" FontWeight="SemiBold" FontSize="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 状态指示器 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding MotorOnline, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Visible}">
                        <TextBlock Text="在线" FontSize="12" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                    </Border>
                    <Border Background="#4CAF50" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding MotorServoEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已使能" FontSize="12" Foreground="White"/>
                    </Border>
                    <Border Background="Orange" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding MotorHomed, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已回原" FontSize="12" Foreground="White"/>
                    </Border>
                    <Border Background="Red" 
                           CornerRadius="12" Padding="12,4"
                           Visibility="{Binding MotorHasAlarm, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="报警" FontSize="12" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- 当前位置显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="12" Padding="32,24" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="当前位置" FontSize="16" Opacity="0.7" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding MotorPosition, StringFormat='{}{0:F2}', FallbackValue='0.00'}" 
                                      FontWeight="Bold" FontSize="48" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="{Binding MotorUnit, FallbackValue='mm'}" FontSize="24" VerticalAlignment="Bottom" Margin="8,0,0,8" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 设备参数 -->
                <Expander Header="设备参数" IsExpanded="True">
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="轴号" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedMotor.AxisId, FallbackValue='-'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="通信ID" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedMotor.CommunicationId, FallbackValue='-'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="脉冲/转" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedMotor.Parameters.PulsesPerRevolution, FallbackValue='-'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="每转位移" FontSize="11" Opacity="0.6"/>
                                <TextBlock FontWeight="Medium">
                                    <Run Text="{Binding SelectedMotor.Parameters.DisplacementPerRevolution, FallbackValue='-'}"/>
                                    <Run Text="{Binding MotorUnit, FallbackValue=''}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="减速比" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedMotor.Parameters.GearRatio, FallbackValue='-'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="JOG速度" FontSize="11" Opacity="0.6"/>
                                <TextBlock FontWeight="Medium">
                                    <Run Text="{Binding SelectedMotor.Parameters.JogSpeed, FallbackValue='-'}"/>
                                    <Run Text="{Binding MotorUnit, FallbackValue=''}"/><Run Text="/s"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>

                <!-- 工作位置 -->
                <Expander Header="工作位置" IsExpanded="True" Margin="0,8,0,0">
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" 
                                         ItemsSource="{Binding MotorWorkPositions}" 
                                         SelectedItem="{Binding SelectedWorkPosition}" 
                                         DisplayMemberPath="Name"
                                         materialDesign:HintAssist.Hint="选择位置"
                                         Margin="0,0,12,0"/>
                                <Button Grid.Column="1" 
                                       Command="{Binding MotorMoveToWorkPositionCommand}" 
                                       Style="{StaticResource MaterialDesignRaisedButton}"
                                       Content="运行到点位" 
                                       Height="36"/>
                            </Grid>
                            <DataGrid ItemsSource="{Binding MotorWorkPositions}" 
                                     AutoGenerateColumns="False" 
                                     CanUserAddRows="False" 
                                     CanUserDeleteRows="False" 
                                     IsReadOnly="True" 
                                     MaxHeight="180"
                                     materialDesign:DataGridAssist.CellPadding="8 4">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="位置" Binding="{Binding Position}" Width="80"/>
                                    <DataGridTextColumn Header="速度" Binding="{Binding Speed}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Expander>
            </StackPanel>

            <!-- 右侧控制 -->
            <StackPanel Grid.Column="1">
                <!-- 使能控制 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="使能控制" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding MotorServoOnCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="#4CAF50"
                                   BorderBrush="#4CAF50"
                                   Content="上使能" 
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding MotorServoOffCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="下使能" 
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding MotorClearAlarmCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="清报警" 
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding MotorResetCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="复位"
                                   Height="36"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 运动参数 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="运动参数" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="目标位置" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding MotorTargetPosition}" Margin="12,0" materialDesign:HintAssist.Hint="输入位置"/>
                            <TextBlock Grid.Column="2" Text="{Binding MotorUnit, FallbackValue='mm'}" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="运动速度" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding MotorSpeed}" Margin="12,0" materialDesign:HintAssist.Hint="输入速度"/>
                            <TextBlock Grid.Column="2" Text="/s" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="JOG步长" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding MotorJogStep}" Margin="12,0" materialDesign:HintAssist.Hint="输入步长"/>
                            <TextBlock Grid.Column="2" Text="{Binding MotorUnit, FallbackValue='mm'}" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="相对运动" IsChecked="{Binding MotorRelative}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <Button Command="{Binding MotorMoveCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Content="移动" 
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding MotorHomeCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="回零" 
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding MotorStopCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="#F44336"
                                   BorderBrush="#F44336"
                                   Content="停止"
                                   Height="36"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- JOG 控制 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="JOG 控制" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" 
                                   Command="{Binding MotorJogNegativeCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="48"
                                   Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Minus" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text=" JOG -" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" 
                                   Command="{Binding MotorJogPositiveCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="48"
                                   Margin="4,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text=" JOG +" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" 
                                   Command="{Binding MotorContinuousJogCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="48"
                                   Margin="8,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FastForward" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text=" 持续" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 状态显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="状态信息" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding MotorStatusMessage, FallbackValue='等待操作...'}" 
                                  Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
