<UserControl x:Class="IndustrySystem.MotionDesigner.Controls.DeviceDebug.CentrifugalDebugControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <materialDesign:Card Padding="24" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧状态和控制 -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <!-- 标题和状态 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="Fan" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="离心机调试" FontWeight="SemiBold" FontSize="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 状态指示器 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding CentrifugalConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已连接" FontSize="12" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                    </Border>
                    <Border Background="Orange" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding CentrifugalRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="运行中" FontSize="12" Foreground="White"/>
                    </Border>
                    <Border Background="#4CAF50" 
                           CornerRadius="12" Padding="12,4"
                           Visibility="{Binding CentrifugalCompleted, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已完成" FontSize="12" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- 连接控制 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="连接设置" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="串口" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" 
                                     ItemsSource="{Binding SerialPorts}" 
                                     SelectedItem="{Binding SelectedCentrifugalPort}"
                                     materialDesign:HintAssist.Hint="选择串口"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="波特率" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedCentrifugal.BaudRate, FallbackValue='19200'}" VerticalAlignment="Center" FontWeight="Medium"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding CentrifugalRefreshPortsCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="刷新" 
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding CentrifugalConnectCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="#4CAF50"
                                   BorderBrush="#4CAF50"
                                   Content="连接"
                                   Height="36"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 设备参数 -->
                <Expander Header="设备参数" IsExpanded="True">
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="最大转速" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedCentrifugal.Parameters.MaxSpeed, StringFormat='{}{0} RPM', FallbackValue='15000 RPM'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="最小转速" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedCentrifugal.Parameters.MinSpeed, StringFormat='{}{0} RPM', FallbackValue='100 RPM'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="最大时间" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedCentrifugal.Parameters.MaxTime, StringFormat='{}{0} 秒', FallbackValue='3600 秒'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="容量位置" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedCentrifugal.Parameters.CapacityPositions, FallbackValue='2'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="加速时间" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedCentrifugal.Parameters.AccelerationTime, StringFormat='{}{0} 秒', FallbackValue='30 秒'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="减速时间" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedCentrifugal.Parameters.DecelerationTime, StringFormat='{}{0} 秒', FallbackValue='30 秒'}" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>
            </StackPanel>

            <!-- 右侧运行控制 -->
            <StackPanel Grid.Column="1">
                <!-- 运行参数设置 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="运行参数" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="转速" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding CentrifugalSpeed}" Margin="12,0" materialDesign:HintAssist.Hint="100-15000"/>
                            <Button Grid.Column="2" 
                                   Command="{Binding CentrifugalSetSpeedCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}" 
                                   Content="设置" 
                                   Height="32"
                                   Margin="8,0"/>
                            <TextBlock Grid.Column="3" Text="RPM" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="离心时间" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding CentrifugalTime}" Margin="12,0" materialDesign:HintAssist.Hint="1-3600"/>
                            <Button Grid.Column="2" 
                                   Command="{Binding CentrifugalSetTimeCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}" 
                                   Content="设置" 
                                   Height="32"
                                   Margin="8,0"/>
                            <TextBlock Grid.Column="3" Text="秒" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="转子位置" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" 
                                     SelectedItem="{Binding CentrifugalRotorPosition}" 
                                     Margin="12,0"
                                     materialDesign:HintAssist.Hint="选择位置">
                                <ComboBoxItem Content="位置1"/>
                                <ComboBoxItem Content="位置2"/>
                            </ComboBox>
                            <Button Grid.Column="2" 
                                   Command="{Binding CentrifugalSetRotorPositionCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}" 
                                   Content="设置位置" 
                                   Height="32"
                                   Margin="8,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 运行控制 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="运行控制" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Command="{Binding CentrifugalStartCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}" 
                                   Background="#4CAF50"
                                   BorderBrush="#4CAF50"
                                   Content="开始离心" 
                                   Height="40"
                                   IsEnabled="{Binding CentrifugalConnected}"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding CentrifugalStopCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}" 
                                   Background="Red"
                                   BorderBrush="Red"
                                   Content="紧急停止" 
                                   Height="40"
                                   IsEnabled="{Binding CentrifugalRunning}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding CentrifugalOpenLidCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="开盖" 
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding CentrifugalCloseLidCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="关盖" 
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding CentrifugalClearAlarmCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="清除报警" 
                                   Height="36"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 工作位置 -->
                <Expander Header="工作位置" IsExpanded="False" Margin="0,0,0,16">
                    <DataGrid ItemsSource="{Binding CentrifugalWorkPositions}" 
                             AutoGenerateColumns="False" 
                             CanUserAddRows="False" 
                             CanUserDeleteRows="False" 
                             IsReadOnly="True"
                             MaxHeight="150"
                             Margin="0,8,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="位置" Binding="{Binding Position}" Width="80"/>
                            <DataGridTextColumn Header="速度" Binding="{Binding Speed}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Expander>

                <!-- 状态显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="状态信息" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding CentrifugalStatus, FallbackValue='等待操作...'}" 
                                  Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                  TextWrapping="Wrap"
                                  FontWeight="Medium"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
