<UserControl x:Class="IndustrySystem.MotionDesigner.Controls.DeviceDebug.SyringePumpDebugControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <materialDesign:Card Padding="24" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp2">
        <StackPanel>
            <!-- 标题 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <materialDesign:PackIcon Kind="Flask" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="注射泵调试" FontWeight="SemiBold" FontSize="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 连接控制 -->
            <Border BorderBrush="{DynamicResource MaterialDesignDivider}" 
                   BorderThickness="1" 
                   CornerRadius="8" 
                   Padding="20"
                   Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="连接控制" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SyringeConnectCommand}" 
                               Style="{StaticResource MaterialDesignRaisedButton}"
                               Background="#4CAF50"
                               BorderBrush="#4CAF50"
                               Content="连接" 
                               Height="36"
                               Margin="0,0,12,0"/>
                        <Button Command="{Binding SyringeInitCommand}" 
                               Style="{StaticResource MaterialDesignOutlinedButton}"
                               Content="初始化" 
                               Height="36"
                               Margin="0,0,12,0"/>
                        <Button Command="{Binding SyringeResetCommand}" 
                               Style="{StaticResource MaterialDesignOutlinedButton}"
                               Content="复位" 
                               Height="36"
                               Margin="0,0,12,0"/>
                        <Button Command="{Binding SyringeClearAlarmCommand}" 
                               Style="{StaticResource MaterialDesignOutlinedButton}"
                               Content="清除报警" 
                               Height="36"
                               Margin="0,0,12,0"/>
                        <Button Command="{Binding SyringeStopCommand}" 
                               Style="{StaticResource MaterialDesignRaisedButton}"
                               Background="Red"
                               BorderBrush="Red"
                               Content="停止"
                               Height="36"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 通道控制 -->
            <Border BorderBrush="{DynamicResource MaterialDesignDivider}" 
                   BorderThickness="1" 
                   CornerRadius="8" 
                   Padding="20"
                   Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="通道控制" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="通道选择" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" 
                                 ItemsSource="{Binding SyringeChannelOptions}" 
                                 SelectedItem="{Binding SyringeChannelCode}"
                                 Margin="16,0"
                                 materialDesign:HintAssist.Hint="选择通道"/>
                        <Button Grid.Column="2"
                               Command="{Binding SyringeSwitchChannelCommand}" 
                               Style="{StaticResource MaterialDesignRaisedButton}"
                               Content="切换通道"
                               Height="36"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 运动控制 -->
            <Border BorderBrush="{DynamicResource MaterialDesignDivider}" 
                   BorderThickness="1" 
                   CornerRadius="8" 
                   Padding="20"
                   Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 绝对位置 -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="绝对位置运动" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="目标位置" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" 
                                    Text="{Binding SyringeAbsPosition}" 
                                    Margin="12,0"
                                    materialDesign:HintAssist.Hint="输入位置"/>
                            <TextBlock Grid.Column="2" Text="ml" VerticalAlignment="Center"/>
                        </Grid>
                        <Button Command="{Binding SyringeAbsMoveCommand}" 
                               Style="{StaticResource MaterialDesignRaisedButton}"
                               Content="绝对运行" 
                               HorizontalAlignment="Stretch"
                               Height="36"
                               Margin="0,12,0,0"/>
                    </StackPanel>

                    <!-- 相对步长 -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="相对步进运动" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="步长" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" 
                                    Text="{Binding SyringeRelStep}" 
                                    Margin="12,0"
                                    materialDesign:HintAssist.Hint="输入步长"/>
                            <TextBlock Grid.Column="2" Text="ml" VerticalAlignment="Center"/>
                        </Grid>
                        <Button Command="{Binding SyringeRelMoveCommand}" 
                               Style="{StaticResource MaterialDesignRaisedButton}"
                               Content="相对运行" 
                               HorizontalAlignment="Stretch"
                               Height="36"
                               Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 状态显示 -->
            <Border Background="{DynamicResource MaterialDesignDivider}" 
                   CornerRadius="8" 
                   Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <materialDesign:PackIcon Kind="InformationOutline" 
                                                Width="20" 
                                                Height="20" 
                                                Margin="0,0,8,0"
                                                Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <TextBlock Text="状态信息" FontWeight="SemiBold" FontSize="15"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SyringeStatus, FallbackValue='等待操作...'}" 
                              Foreground="{DynamicResource PrimaryHueMidBrush}" 
                              TextWrapping="Wrap"
                              FontSize="14"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </materialDesign:Card>
</UserControl>
