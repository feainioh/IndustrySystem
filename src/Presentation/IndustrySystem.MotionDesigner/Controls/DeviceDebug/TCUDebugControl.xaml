<UserControl x:Class="IndustrySystem.MotionDesigner.Controls.DeviceDebug.TCUDebugControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <materialDesign:Card Padding="24" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧状态和连接 -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <!-- 标题和状态 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="Thermometer" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="TCU温控调试" FontWeight="SemiBold" FontSize="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 状态指示器 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding TcuConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已连接" FontSize="12" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                    </Border>
                    <Border Background="Orange" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding TcuIsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="控温中" FontSize="12" Foreground="White"/>
                    </Border>
                    <Border Background="#4CAF50" 
                           CornerRadius="12" Padding="12,4"
                           Visibility="{Binding TcuCirculationEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="循环开启" FontSize="12" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- 温度显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="当前温度" FontSize="14" Opacity="0.7" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TcuCurrentTemperature, StringFormat='{}{0:F1}', FallbackValue='25.0'}" 
                                          FontWeight="Bold" FontSize="36" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                <TextBlock Text="°C" FontSize="20" VerticalAlignment="Top" Margin="4,4,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="目标温度" FontSize="14" Opacity="0.7" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TcuTargetTemperature, StringFormat='{}{0:F1}', FallbackValue='37.0'}" 
                                          FontWeight="Bold" FontSize="36" Foreground="Orange"/>
                                <TextBlock Text="°C" FontSize="20" VerticalAlignment="Top" Margin="4,4,0,0" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 连接设置 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="连接设置" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="串口" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" 
                                     ItemsSource="{Binding SerialPorts}" 
                                     SelectedItem="{Binding SelectedTcuPort}"
                                     materialDesign:HintAssist.Hint="选择串口"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="波特率" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedTcu.BaudRate, FallbackValue='9600'}" FontWeight="Medium"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="从站ID" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedTcu.SlaveId, FallbackValue='1'}" FontWeight="Medium"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding TcuRefreshPortsCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="刷新" 
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding TcuConnectCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="#4CAF50"
                                   BorderBrush="#4CAF50"
                                   Content="连接"
                                   Height="36"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding TcuDisconnectCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="断开"
                                   Height="36"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 设备信息 -->
                <Expander Header="设备信息" IsExpanded="False">
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="设备ID" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedTcu.DeviceId, FallbackValue='tcu_queenching'}" FontWeight="Medium" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="设备名称" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedTcu.Name, FallbackValue='主TCU温控设备'}" FontWeight="Medium" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="数据位" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedTcu.DataBits, FallbackValue='8'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="校验位" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedTcu.Parity, FallbackValue='None'}" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>
            </StackPanel>

            <!-- 右侧温度控制 -->
            <StackPanel Grid.Column="1">
                <!-- 温度设置 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="温度设置" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="目标温度" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" 
                                    Text="{Binding TcuTargetTemperatureInput}" 
                                    Margin="12,0"
                                    materialDesign:HintAssist.Hint="输入温度"/>
                            <TextBlock Grid.Column="2" Text="°C" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <!-- 快捷温度按钮 -->
                        <TextBlock Text="快捷设置" FontSize="12" Opacity="0.7" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="4°C" 
                                   Command="{Binding TcuSetQuickTemperatureCommand}" 
                                   CommandParameter="4"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="32"
                                   Margin="0,0,8,0"/>
                            <Button Content="25°C" 
                                   Command="{Binding TcuSetQuickTemperatureCommand}" 
                                   CommandParameter="25"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="32"
                                   Margin="0,0,8,0"/>
                            <Button Content="37°C" 
                                   Command="{Binding TcuSetQuickTemperatureCommand}" 
                                   CommandParameter="37"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="32"
                                   Margin="0,0,8,0"/>
                            <Button Content="60°C" 
                                   Command="{Binding TcuSetQuickTemperatureCommand}" 
                                   CommandParameter="60"
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Height="32"/>
                        </StackPanel>
                        
                        <Button Command="{Binding TcuSetTemperatureCommand}" 
                               Style="{StaticResource MaterialDesignRaisedButton}"
                               Content="设置温度"
                               Height="36"
                               HorizontalAlignment="Stretch"
                               IsEnabled="{Binding TcuConnected}"/>
                    </StackPanel>
                </Border>

                <!-- 循环控制 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="循环控制" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        
                        <CheckBox Content="开启循环" 
                                 IsChecked="{Binding TcuCirculationEnabled}" 
                                 IsEnabled="{Binding TcuConnected}"
                                 Margin="0,0,0,12"/>
                        
                        <Button Command="{Binding TcuSetCirculationCommand}" 
                               Style="{StaticResource MaterialDesignOutlinedButton}" 
                               Content="应用循环设置" 
                               Height="36"
                               HorizontalAlignment="Stretch"
                               IsEnabled="{Binding TcuConnected}"/>
                    </StackPanel>
                </Border>

                <!-- 运行控制 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="运行控制" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Command="{Binding TcuStartControlCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}" 
                                   Background="#4CAF50"
                                   BorderBrush="#4CAF50"
                                   Content="开始控温" 
                                   Height="40"
                                   IsEnabled="{Binding TcuConnected}"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding TcuStopCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}" 
                                   Background="Red"
                                   BorderBrush="Red"
                                   Content="停止" 
                                   Height="40"
                                   IsEnabled="{Binding TcuIsRunning}"/>
                        </StackPanel>
                        <Button Command="{Binding TcuClearAlarmCommand}" 
                               Style="{StaticResource MaterialDesignOutlinedButton}" 
                               Content="清除报警"
                               Height="36"
                               HorizontalAlignment="Stretch"
                               IsEnabled="{Binding TcuConnected}"/>
                    </StackPanel>
                </Border>

                <!-- 状态显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="状态信息" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TcuStatus, FallbackValue='等待操作...'}" 
                                  Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
