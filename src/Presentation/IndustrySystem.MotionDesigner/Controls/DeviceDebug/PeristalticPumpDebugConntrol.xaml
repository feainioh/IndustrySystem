<UserControl x:Class="IndustrySystem.MotionDesigner.Controls.DeviceDebug.PeristalticPumpDebugConntrol"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <materialDesign:Card Padding="24" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧状态显示 -->
            <StackPanel Grid.Column="0" Margin="0,0,24,0">
                <!-- 标题和状态 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="WaterPump" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="蠕动泵调试" FontWeight="SemiBold" FontSize="20" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 状态指示器 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="{DynamicResource PrimaryHueLightBrush}" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding PeristalticConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已连接" FontSize="12" Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                    </Border>
                    <Border Background="#4CAF50" 
                           CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                           Visibility="{Binding PeristalticServoEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="已使能" FontSize="12" Foreground="White"/>
                    </Border>
                    <Border Background="Orange" 
                           CornerRadius="12" Padding="12,4"
                           Visibility="{Binding PeristalticIsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="运行中" FontSize="12" Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- 当前位置显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="当前位置" FontSize="12" Opacity="0.7"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding PeristalticPosition, FallbackValue='0.00'}" FontWeight="Bold" FontSize="20" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                <TextBlock Text="ml" FontSize="14" Margin="4,0,0,0" VerticalAlignment="Bottom" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                            <TextBlock Text="当前流量" FontSize="12" Opacity="0.7"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding PeristalticCurrentFlowRate, FallbackValue='0'}" FontWeight="Bold" FontSize="20" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                <TextBlock Text="mL/min" FontSize="14" Margin="4,0,0,0" VerticalAlignment="Bottom" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="泵头型号" FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="{Binding SelectedPeristalticPump.PumpHeadModel, FallbackValue='SN15-3'}" FontWeight="Medium" FontSize="14"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="管径规格" FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="{Binding SelectedPeristalticPump.TubeSpec, FallbackValue='16#'}" FontWeight="Medium" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 泵参数信息 -->
                <Expander Header="泵参数信息" IsExpanded="True" Margin="0,0,0,16">
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="最大转速" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedPeristalticPump.MaxRPM, StringFormat='{}{0} RPM', FallbackValue='150 RPM'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="最大流量" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedPeristalticPump.MaxFlowRate, StringFormat='{}{0} mL/min', FallbackValue='135 mL/min'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="转子数量" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedPeristalticPump.RotorCount, FallbackValue='3'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="泵精度" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedPeristalticPump.PumpAccuracy, StringFormat='{}{0:P0}', FallbackValue='100%'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,4">
                                <TextBlock Text="通信ID" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedPeristalticPump.CommunicationId, FallbackValue='18'}" FontWeight="Medium"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,4">
                                <TextBlock Text="CAN帧ID" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{Binding SelectedPeristalticPump.CanFrameId, FallbackValue='297'}" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Expander>

                <!-- 按量泵送 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="按量泵送" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="流量" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding PeristalticFlowRate}" Margin="8,0" materialDesign:HintAssist.Hint="输入流量"/>
                            <TextBlock Grid.Column="2" Text="mL/min" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="总量" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding PeristalticTotalVolume}" Margin="8,0" materialDesign:HintAssist.Hint="输入体积"/>
                            <TextBlock Grid.Column="2" Text="mL" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding PeristalticStartByVolumeCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="#4CAF50"
                                   BorderBrush="#4CAF50"
                                   Content="开始泵送" 
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding PeristalticStopCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="Red"
                                   BorderBrush="Red"
                                   Content="停止"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 右侧控制区域 -->
            <StackPanel Grid.Column="1">
                <!-- 使能和报警控制 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Command="{Binding PeristalticServoOnCommand}" 
                           Style="{StaticResource MaterialDesignRaisedButton}"
                           Background="#4CAF50"
                           BorderBrush="#4CAF50"
                           Content="上使能" 
                           Height="36"
                           Margin="0,0,12,0"/>
                    <Button Command="{Binding PeristalticServoOffCommand}" 
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Content="下使能" 
                           Height="36"
                           Margin="0,0,12,0"/>
                    <Button Command="{Binding PeristalticClearAlarmCommand}" 
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Content="清除报警" 
                           Height="36"
                           Margin="0,0,12,0"/>
                    <Button Command="{Binding PeristalticResetCommand}" 
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           Content="复位"
                           Height="36"/>
                </StackPanel>

                <!-- 运动参数 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="运动控制" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="目标体积" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding PeristalticTarget}" Margin="12,0" materialDesign:HintAssist.Hint="输入目标"/>
                            <TextBlock Grid.Column="2" Text="ml" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="转速" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding PeristalticSpeed}" Margin="12,0" materialDesign:HintAssist.Hint="输入转速"/>
                            <TextBlock Grid.Column="2" Text="RPM" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="JOG步长" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding PeristalticJogStep}" Margin="12,0" materialDesign:HintAssist.Hint="输入步长"/>
                            <TextBlock Grid.Column="2" Text="ml" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox Content="相对运动" IsChecked="{Binding PeristalticRelative}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <CheckBox Content="反向" IsChecked="{Binding PeristalticReverse}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding PeristalticMoveCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Content="运行" 
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding PeristalticStopCommand}" 
                                   Style="{StaticResource MaterialDesignRaisedButton}"
                                   Background="Red"
                                   BorderBrush="Red"
                                   Content="停止"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- JOG控制 -->
                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="JOG 控制" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding PeristalticJogNegativeCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="JOG - (吸液)" 
                                   Width="120"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding PeristalticJogPositiveCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="JOG + (排液)" 
                                   Width="120"
                                   Margin="0,0,12,0"/>
                            <Button Command="{Binding PeristalticContinuousRunCommand}" 
                                   Style="{StaticResource MaterialDesignOutlinedButton}"
                                   Content="持续运行"
                                   Width="100"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 状态显示 -->
                <Border Background="{DynamicResource MaterialDesignDivider}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="状态信息" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding PeristalticStatus, FallbackValue='等待操作...'}" 
                                  Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
