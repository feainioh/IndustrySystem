{
  "ExternalSync": {
    "Enabled": false,
    "DefaultPollingIntervalSeconds": 5,
    "DefaultTimeoutSeconds": 15,
    "EnableStructuredLog": true,
    "MaxDegreeOfParallelism": 1,
    "Retry": {
      "MaxAttempts": 3,
      "BaseDelayMilliseconds": 250,
      "MaxDelayMilliseconds": 5000,
      "UseJitter": true
    },
    "Dedup": {
      "Enabled": true,
      "WindowMinutes": 1440,
      "MaxEntries": 100000
    },
    "Conflict": {
      "Policy": "NewerWins",
      "TimestampFieldName": "updatedAt",
      "VersionFieldName": "version"
    },
    "DeadLetter": {
      "Enabled": true,
      "MaxInMemoryItems": 1000,
      "FilePath": "logs/external-sync-deadletter.jsonl"
    },
    "Endpoints": [
      {
        "Name": "external-gateway",
        "Enabled": false,
        "Protocol": "WebApi",
        "Url": "https://example.com/api/sync/events",
        "PollingIntervalSeconds": 5,
        "TimeoutSeconds": 15,
        "BatchSize": 200,
        "ApiKeyHeaderName": "X-Api-Key",
        "ApiKey": "",
        "EnableAck": false,
        "AckUrl": "https://example.com/api/sync/ack",
        "Retry": {
          "MaxAttempts": 3,
          "BaseDelayMilliseconds": 250,
          "MaxDelayMilliseconds": 5000,
          "UseJitter": true
        }
      },
      {
        "Name": "external-socket",
        "Enabled": false,
        "Protocol": "Socket",
        "Url": "tcp://127.0.0.1:9001",
        "PollingIntervalSeconds": 2,
        "TimeoutSeconds": 10,
        "BatchSize": 200,
        "MessageDelimiter": "\n",
        "EnableAck": true,
        "Retry": {
          "MaxAttempts": 5,
          "BaseDelayMilliseconds": 300,
          "MaxDelayMilliseconds": 8000,
          "UseJitter": true
        }
      },
      {
        "Name": "external-signalr",
        "Enabled": false,
        "Protocol": "SignalR",
        "Url": "https://example.com/syncHub",
        "PollingIntervalSeconds": 2,
        "TimeoutSeconds": 15,
        "BatchSize": 200,
        "MessageMethodName": "ReceiveSyncMessage",
        "AckMethodName": "AckSyncMessages",
        "AccessToken": "",
        "EnableAck": true,
        "Retry": {
          "MaxAttempts": 5,
          "BaseDelayMilliseconds": 300,
          "MaxDelayMilliseconds": 8000,
          "UseJitter": true
        }
      }
    ]
  },
  "SqlSugar": {
    "ConnectionString": "Server=localhost;Port=3306;Database=industrialvisiondb;Uid=root;Pwd=woshikeji;",
    "InitOnStartup": true,
    "InitBuildSchema": true,
    "InitSeedData": true,
    "InitOnStartupDevelopment": true,
    "InitOnStartupProduction": true,
    "InitTimeoutSeconds": 30,
    "InitRetryCount": 3,
    "InitRetryDelayMs": 1000
  }
}
