<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- Additional Gradient Brushes for Views -->
    <LinearGradientBrush x:Key="UserGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFB900" Offset="0"/>
        <GradientStop Color="#FFC83D" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="RoleGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#10893E" Offset="0"/>
        <GradientStop Color="#16A34A" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="PermissionGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#8764B8" Offset="0"/>
        <GradientStop Color="#9B7FCC" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Status Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#10893E"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#E74856"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFB900"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#0078D4"/>

    <!-- Dialog glass resources -->
    <Color x:Key="DialogSurfaceColor">#FFFDFDFE</Color>
    <Color x:Key="DialogFooterColor">#FFF8F9FC</Color>
    <SolidColorBrush x:Key="DialogInputBackgroundBrush" Color="#FFF5F8FC"/>
    <SolidColorBrush x:Key="DialogInputBorderBrush" Color="#FFD2DFEE"/>
    <SolidColorBrush x:Key="DialogInputForegroundBrush" Color="#1C2F45"/>
    <SolidColorBrush x:Key="DialogInputHintBrush" Color="#637B96"/>
    <DropShadowEffect x:Key="DialogSurfaceShadow"
                      Color="#2B000000"
                      BlurRadius="38"
                      ShadowDepth="10"
                      Opacity="0.34"
                      Direction="270"/>
    
    <!-- Additional Styles for Management Views -->
    
    <!-- Page Container -->
    <Style x:Key="PageContainer" TargetType="Grid">
        <Setter Property="Margin" Value="20"/>
    </Style>
    
    <!-- Module Icon Badge -->
    <Style x:Key="ModuleIconBadge" TargetType="Border">
        <Setter Property="Width" Value="56"/>
        <Setter Property="Height" Value="56"/>
        <Setter Property="CornerRadius" Value="28"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,16,0"/>
    </Style>
    
    <!-- Page Title -->
    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
    </Style>
    
    <!-- Page Subtitle -->
    <Style x:Key="PageSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Opacity" Value="0.6"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
    </Style>
    
    <!-- Section Title -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
    </Style>
    
    <!-- Material Card -->
    <Style x:Key="MaterialCard" TargetType="materialDesign:Card">
        <Setter Property="Padding" Value="10"/>
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2"/>
        <Setter Property="UniformCornerRadius" Value="8"/>
        <Setter Property="Background" Value="{DynamicResource AppCardBackgroundBrush}"/>
    </Style>
    
    <!-- Material Text Field -->
    <Style x:Key="MaterialTextField" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Height" Value="52"/>
        <Setter Property="MinHeight" Value="52"/>
        <Setter Property="Padding" Value="12,4,12,4"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputTextBrush}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource AppInputTextBrush}"/>
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
    </Style>

    <Style x:Key="DialogTextField" TargetType="TextBox" BasedOn="{StaticResource MaterialTextField}">
        <Setter Property="Background" Value="{DynamicResource DialogInputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DialogInputBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource DialogInputForegroundBrush}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource DialogInputForegroundBrush}"/>
        <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource DialogInputHintBrush}"/>
    </Style>

    <Style x:Key="DialogComboBox" TargetType="ComboBox" BasedOn="{StaticResource AppInteractiveComboBox}">
        <Setter Property="Background" Value="{DynamicResource DialogInputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DialogInputBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource DialogInputForegroundBrush}"/>
        <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource DialogInputHintBrush}"/>
    </Style>

    <Style x:Key="MaterialComboBox" TargetType="ComboBox" BasedOn="{StaticResource AppInteractiveComboBox}">
        <Setter Property="Height" Value="52"/>
        <Setter Property="MinHeight" Value="52"/>
        <Setter Property="Padding" Value="12,4,12,4"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputTextBrush}"/>
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
    </Style>
    
    <!-- Material Accent Button -->
    <Style x:Key="MaterialAccentButton" TargetType="Button" BasedOn="{StaticResource AppInteractiveButtonPrimary}">
        <Setter Property="Height" Value="48"/>
    </Style>
    
    <!-- Material Data Grid -->
    <Style x:Key="MaterialDataGrid" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="RowHeight" Value="56"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="materialDesign:DataGridAssist.ColumnHeaderPadding" Value="16,8"/>
        <Setter Property="materialDesign:DataGridAssist.CellPadding" Value="16,8"/>
    </Style>
    
    <!-- Header Shadow Effect -->
    <DropShadowEffect x:Key="HeaderShadow" 
                      Color="Black" 
                      BlurRadius="4" 
                      ShadowDepth="1" 
                      Opacity="0.3"/>
 
        <Style x:Key="DialogHostWindowStyle" TargetType="Window">
            <Setter Property="WindowStyle" Value="None"/>
            <Setter Property="AllowsTransparency" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="SizeToContent" Value="WidthAndHeight"/>
            <Setter Property="ResizeMode" Value="NoResize"/>
            <Setter Property="ShowInTaskbar" Value="False"/>
        </Style> 

</ResourceDictionary>
