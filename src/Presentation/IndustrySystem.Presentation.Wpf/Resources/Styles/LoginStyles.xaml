<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==========================================================
         LoginView 专属样式
         仅被 LoginView.xaml 使用，与全局 ViewStyles 分离以便维护
         ========================================================== -->

    <!-- Foreground Brushes -->
    <SolidColorBrush x:Key="LoginTitleForegroundBrush" Color="#F4FAFF"/>
    <SolidColorBrush x:Key="LoginSubtitleForegroundBrush" Color="#D1E8FF"/>
    <SolidColorBrush x:Key="LoginFooterForegroundBrush" Color="#D6EAFF"/>
    <SolidColorBrush x:Key="LoginThemeToggleForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="LoginThemeToggleBorderBrush" Color="#78FFFFFF"/>
    <SolidColorBrush x:Key="LoginThemeToggleBackgroundBrush" Color="#2CFFFFFF"/>
    <SolidColorBrush x:Key="LoginAvatarBackgroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="LoginAvatarIconBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="LoginCardBackgroundBrush" Color="#FDFEFF"/>
    <SolidColorBrush x:Key="LoginCardBorderBrush" Color="#D9E6F2"/>
    <SolidColorBrush x:Key="LoginErrorForegroundBrush" Color="#D6455D"/>
    <SolidColorBrush x:Key="LoginDecorationBrush" Color="#38FFFFFF"/>

    <!-- Background Gradients -->
    <LinearGradientBrush x:Key="LoginBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0B3860" Offset="0"/>
        <GradientStop Color="#0F5B88" Offset="0.52"/>
        <GradientStop Color="#1A7FA0" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LoginPrimaryButtonBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0A67A8" Offset="0"/>
        <GradientStop Color="#0F88C2" Offset="0.54"/>
        <GradientStop Color="#15A4CF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Effects -->
    <DropShadowEffect x:Key="LoginCardShadowEffect" Color="#243C58" BlurRadius="28" ShadowDepth="8" Opacity="0.22"/>

    <!-- Login-specific CornerRadius -->
    <CornerRadius x:Key="LoginRootCornerRadius">8</CornerRadius>

</ResourceDictionary>
