<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.HardwareDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}"
             mc:Ignorable="d">
  <Grid Style="{StaticResource PageRootGrid}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="16"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
      <Border Style="{StaticResource PageHeaderIconBorder}" Background="{DynamicResource DeviceGradientBrush}">
        <TextBlock Text="&#xE9D9;" Style="{StaticResource PageHeaderMdl2Icon}"/>
      </Border>
      <StackPanel>
        <TextBlock Text="{x:Static loc:Strings.Page_HardwareDebug_Title}" Style="{StaticResource PageHeaderTitle}"/>
        <TextBlock Text="{x:Static loc:Strings.Page_HardwareDebug_Subtitle}" Style="{StaticResource PageHeaderSubtitle}"/>
      </StackPanel>
    </StackPanel>

    <Grid Grid.Row="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Style="{StaticResource FormCard}">
        <StackPanel>
          <TextBlock Text="{x:Static loc:Strings.Section_HardwareConnection}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
          <WrapPanel VerticalAlignment="Center">
            <ComboBox Width="150" SelectedValue="{Binding Transport}" SelectedValuePath="Content" Style="{StaticResource InlineFormComboBox}">
              <ComboBoxItem Content="ModbusTCP" />
              <ComboBoxItem Content="CAN" />
              <ComboBoxItem Content="EtherCAT" />
              <ComboBoxItem Content="HTTP" />
              <ComboBoxItem Content="TCP" />
            </ComboBox>
            <TextBox Width="260" Margin="10,0,0,0" Text="{Binding Endpoint}" Style="{StaticResource InlineFormTextBox}" ui:ControlHelper.PlaceholderText="{x:Static loc:Strings.Hint_EndpointExample}" />
            <Button Content="{x:Static loc:Strings.Btn_Connect}" Margin="12,0,0,0" Command="{Binding ConnectCommand}" Style="{StaticResource PrimaryCommandButton}" />
            <Button Content="{x:Static loc:Strings.Btn_Disconnect}" Margin="8,0,0,0" Command="{Binding DisconnectCommand}" Style="{StaticResource SecondaryCommandButton}" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Grid.Row="2" Style="{StaticResource FormCard}">
        <StackPanel>
          <TextBlock Text="{x:Static loc:Strings.Section_ReadHoldingRegisters}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
          <WrapPanel VerticalAlignment="Center">
            <TextBlock Text="{x:Static loc:Strings.Label_StartAddress}" Style="{StaticResource FormLabel}"/>
            <TextBox Width="90" Text="{Binding ReadStartAddress}" Style="{StaticResource InlineFormTextBox}" />
            <TextBlock Text="{x:Static loc:Strings.Label_Count}" Style="{StaticResource FormLabel}" Margin="16,0,12,0"/>
            <TextBox Width="90" Text="{Binding ReadCount}" Style="{StaticResource InlineFormTextBox}" />
            <Button Content="{x:Static loc:Strings.Btn_Read}" Margin="12,0,0,0" Command="{Binding ReadCommand}" Style="{StaticResource PrimaryCommandButton}" />
            <TextBlock Text="{x:Static loc:Strings.Label_Result}" Style="{StaticResource FormLabel}" Margin="18,0,12,0"/>
            <TextBox Width="280" Text="{Binding LastRead}" IsReadOnly="True" Style="{StaticResource InlineFormTextBox}" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Grid.Row="4" Style="{StaticResource FormCard}">
        <StackPanel>
          <TextBlock Text="{x:Static loc:Strings.Section_WriteHoldingRegisters}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
          <WrapPanel VerticalAlignment="Center">
            <TextBlock Text="{x:Static loc:Strings.Label_StartAddress}" Style="{StaticResource FormLabel}"/>
            <TextBox Width="90" Text="{Binding WriteAddress}" Style="{StaticResource InlineFormTextBox}" />
            <TextBlock Text="{x:Static loc:Strings.Label_CommaSeparatedValues}" Style="{StaticResource FormLabel}" Margin="16,0,12,0"/>
            <TextBox Width="320" Text="{Binding WriteValues}" Style="{StaticResource InlineFormTextBox}" />
            <Button Content="{x:Static loc:Strings.Btn_Write}" Margin="12,0,0,0" Command="{Binding WriteCommand}" Style="{StaticResource PrimaryCommandButton}" />
          </WrapPanel>
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="14" Margin="0,14,0,0">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="{x:Static loc:Strings.Section_Status}" FontWeight="SemiBold" Margin="0,0,10,0"/>
        <TextBlock Foreground="{StaticResource AppMutedTextBrush}" TextWrapping="Wrap" Text="{Binding Status}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
