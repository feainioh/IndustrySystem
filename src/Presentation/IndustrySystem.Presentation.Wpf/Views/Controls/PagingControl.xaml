<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Controls.PagingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:ctrls="clr-namespace:IndustrySystem.Presentation.Wpf.Views.Controls"
             MinHeight="40">
  <UserControl.Resources>
    <res:LocalizationProvider x:Key="Loc" />
    <ctrls:PageInfoMultiConverter x:Key="PageInfoMultiConverter" />
  </UserControl.Resources>
    <Border Style="{StaticResource PaginationCard}">
    <DockPanel>
        <StackPanel Style="{StaticResource PaginationButtonPanel}">
    <Button Content="{Binding [Btn_First], Source={StaticResource Loc}}" Style="{StaticResource PaginationTextButton}" Click="First_Click" IsEnabled="{Binding CanPrev, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    <Button Content="{Binding [Btn_Prev], Source={StaticResource Loc}}" Style="{StaticResource PaginationTextButton}"
      Command="{Binding PrevPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" IsEnabled="{Binding CanPrev, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    <Button Content="{Binding [Btn_Next], Source={StaticResource Loc}}" Style="{StaticResource PaginationTextButton}"
      Command="{Binding NextPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" IsEnabled="{Binding CanNext, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    <Button Content="{Binding [Btn_Last], Source={StaticResource Loc}}" Style="{StaticResource PaginationTextButton}" Click="Last_Click" IsEnabled="{Binding CanNext, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        <TextBlock Text="{Binding [Lbl_PageSize], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
    <TextBox Width="50" Style="{StaticResource PaginationInputTextBox}" Text="{Binding PageSize, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="8,0,12,0"/>
        <TextBlock VerticalAlignment="Center" Margin="0,0,12,0">
          <TextBlock.Text>
            <MultiBinding Converter="{StaticResource PageInfoMultiConverter}">
              <Binding Path="DisplayPageIndex" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
              <Binding Path="PageCount" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
              <Binding Path="TotalCount" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
            </MultiBinding>
          </TextBlock.Text>
        </TextBlock>
        <TextBlock Text="{Binding [Lbl_JumpTo], Source={StaticResource Loc}}" VerticalAlignment="Center"/>
        <TextBox Width="50" Style="{StaticResource PaginationInputTextBox}" Loaded="JumpBox_Loaded" Margin="4,0,4,0"/>
        <Button Content="{Binding [Btn_Go], Source={StaticResource Loc}}" Style="{StaticResource PaginationTextButton}" Click="Go_Click"/>
      </StackPanel>
    </DockPanel>
  </Border>
</UserControl>
