<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.ExperimentGroupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <Style x:Key="SearchTextField" TargetType="TextBox" BasedOn="{StaticResource ManagementSearchTextBox}"/>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{StaticResource StandardGridSpacing}"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{StaticResource PageHeaderIconBorder}" Background="{StaticResource ExperimentGradientBrush}">
                    <TextBlock Text="&#xE7C5;" Style="{StaticResource PageHeaderMdl2Icon}"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Page_ExperimentGroups_Title]}" Style="{StaticResource PageHeaderTitle}"/>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Page_ExperimentGroups_Subtitle]}" Style="{StaticResource PageHeaderSubtitle}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsPanel}">
                <Button Style="{StaticResource HeaderActionOutlinedButton}"
                        Command="{Binding RefreshCommand}"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Btn_Refresh}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderActionAccentButton}"
                        Command="{Binding AddCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Btn_AddExperimentGroup]}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource FormCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource MediumGridSpacing}"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Loc}, Path=[Section_ExperimentGroupList]}" FontSize="15" FontWeight="SemiBold"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextField}"
                             materialDesign:HintAssist.Hint="{Binding Source={StaticResource Loc}, Path=[Hint_Search_ExperimentGroup]}"
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="Magnify"/>
                </Grid>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding GroupsView}"
                          Style="{StaticResource ListViewLikeDataGrid}">
                    <DataGrid.Columns>
                            <DataGridTextColumn Width="160" Header="{Binding Source={StaticResource Loc}, Path=[Col_GroupName]}" Binding="{Binding Name}"/>
                            <DataGridTextColumn Width="220" Header="{Binding Source={StaticResource Loc}, Path=[Col_Description]}" Binding="{Binding Description}"/>
                            <DataGridTextColumn Width="220" Header="{Binding Source={StaticResource Loc}, Path=[Col_StepSummary]}" Binding="{Binding StepDisplay}"/>
                            <DataGridTemplateColumn Width="120" Header="{Binding Source={StaticResource Loc}, Path=[Col_EnabledStatus]}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:Chip Content="{Binding IsEnabled, Converter={StaticResource BoolToStatusConverter}}"
                                                            Margin="6,0"
                                                            FontSize="11"
                                                            Padding="6,2"
                                                            Foreground="White"
                                                            HorizontalAlignment="Left">
                                            <materialDesign:Chip.Style>
                                                <Style TargetType="materialDesign:Chip">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                            <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:Chip.Style>
                                        </materialDesign:Chip>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Width="120" Header="{Binding Source={StaticResource Loc}, Path=[Col_CreatedBy]}" Binding="{Binding CreatedBy}"/>
                            <!--<GridViewColumn Width="160" Header="创建时间" DisplayMemberBinding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}"/>
                            <GridViewColumn Width="160" Header="更新时间" DisplayMemberBinding="{Binding UpdatedAt, StringFormat=yyyy-MM-dd HH:mm}"/>-->
                            <DataGridTemplateColumn Width="120" Header="{x:Static loc:Strings.Col_Actions}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="{x:Static loc:Strings.Btn_Edit}">
                                                <materialDesign:PackIcon Kind="Pencil" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="{x:Static loc:Strings.Btn_Delete}"
                                                    Foreground="{StaticResource ErrorBrush}">
                                                <materialDesign:PackIcon Kind="Delete" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
