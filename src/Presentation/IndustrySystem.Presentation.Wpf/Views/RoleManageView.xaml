<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.RoleManageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
    
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <Style x:Key="SearchTextField" TargetType="TextBox" BasedOn="{StaticResource ManagementSearchTextBox}"/>
    </UserControl.Resources>
    
    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{StaticResource PageHeaderIconBorder}" Background="{StaticResource RoleGradientBrush}">
                    <materialDesign:PackIcon Kind="ShieldAccount" Style="{StaticResource PageHeaderPackIcon}"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.Nav_Roles}" Style="{StaticResource PageHeaderTitle}"/>
                    <TextBlock Text="{x:Static loc:Strings.View_Roles_Subtitle}" Style="{StaticResource PageHeaderSubtitle}"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1"
                   Style="{StaticResource HeaderActionOutlinedButton}"
                   Command="{Binding RefreshCommand}"
                   VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{x:Static loc:Strings.Btn_Refresh}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Add Role Card -->
        <Border Grid.Row="2" Style="{StaticResource FormCard}">
            <StackPanel>
                <TextBlock Text="{x:Static loc:Strings.Section_AddNewRole}" Style="{StaticResource SectionTitle}"/>
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Role Name -->
                    <TextBox Grid.Column="0"
                            Text="{Binding NewRoleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Hint_Role_Name}"
                            materialDesign:HintAssist.IsFloating="True"/>
                    
                    
                    <!-- Description -->
                    <TextBox Grid.Column="2"
                            Text="{Binding NewRoleDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Col_Common_Description}"
                            materialDesign:HintAssist.IsFloating="True"/>
                    
                    <!-- Add Button -->
                    <Button Grid.Column="4"
                           Command="{Binding AddCommand}"
                           Style="{StaticResource MaterialAccentButton}"
                           Width="120"
                           Height="48">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ShieldPlus" 
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0"/>
                            <TextBlock Text="{x:Static loc:Strings.Btn_AddRole}" 
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Roles List Card -->
        <Border Grid.Row="4" Style="{StaticResource FormCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Section Header with Search -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0"
                              Text="{x:Static loc:Strings.Section_RoleList}" 
                              Style="{StaticResource SectionTitle}"/>
                    
                    <TextBox Grid.Column="1"
                            Width="250"
                            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource SearchTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Search_Roles}"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="Magnify"/>
                </Grid>
                
                <!-- DataGrid -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding PagedRoles}"
                          Style="{StaticResource ListViewLikeDataGrid}">
                    <DataGrid.Columns>
                            <DataGridTemplateColumn Width="280" Header="{x:Static loc:Strings.Col_Role}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="8,0">
                                            <Border Style="{StaticResource DataGridLeadingIconBadge}" Background="{StaticResource RoleGradientBrush}">
                                                <materialDesign:PackIcon Kind="ShieldAccount" Style="{StaticResource DataGridLeadingPackIcon}" Foreground="White"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                                <TextBlock Text="{Binding Description}" FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Width="280" Header="{x:Static loc:Strings.Col_Common_Description}" Binding="{Binding Description}"/>

                            <DataGridTemplateColumn Width="120" Header="{x:Static loc:Strings.Col_Type}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:Chip Content="{x:Static loc:Strings.Type_Default}"
                                                            Background="{StaticResource InfoBrush}"
                                                            Foreground="White"
                                                            Margin="8,0"
                                                            FontSize="12"
                                                            Padding="8,4"
                                                            HorizontalAlignment="Left"
                                                            Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="200" Header="{x:Static loc:Strings.Col_Actions}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,0">
                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                   Command="{Binding DataContext.ManagePermissionsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   ToolTip="{x:Static loc:Strings.Tooltip_ManagePermissions}">
                                                <materialDesign:PackIcon Kind="KeyChainVariant" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>

                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                   Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   ToolTip="{x:Static loc:Strings.Tooltip_EditRole}">
                                                <materialDesign:PackIcon Kind="Pencil" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>

                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                   Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   ToolTip="{x:Static loc:Strings.Tooltip_DeleteRole}"
                                                   Foreground="{StaticResource ErrorBrush}"
                                                   IsEnabled="{Binding IsDefault, Converter={StaticResource Not}}">
                                                <materialDesign:PackIcon Kind="Delete" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pagination -->
                <Border Grid.Row="4" Style="{StaticResource PaginationCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Style="{StaticResource PaginationStatsPanel}">
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Total}" Opacity="0.7"/>
                            <TextBlock Text="{Binding TotalCount}" FontWeight="SemiBold" Foreground="{StaticResource HeaderGradient}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Records}" Opacity="0.7"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Style="{StaticResource PaginationButtonPanel}">
                            <Button Content="&#xE892;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding FirstPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_FirstPage}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding PreviousPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Prev}" Style="{StaticResource PaginationButton}"/>

                            <Border Style="{StaticResource CurrentPageBorder}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CurrentPage}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" / " Opacity="0.7" Margin="4,0"/>
                                    <TextBlock Text="{Binding TotalPages}" Opacity="0.7"/>
                                </StackPanel>
                            </Border>

                            <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding NextPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Next}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE893;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding LastPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_LastPage}" Style="{StaticResource PaginationButton}"/>

                            <ComboBox SelectedItem="{Binding PageSize, Mode=TwoWay}"
                                      ItemsSource="{Binding PageSizes}"
                                      Width="80" Margin="12,0,0,0" Style="{StaticResource PaginationComboBox}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_PerPage}" VerticalAlignment="Center" Opacity="0.7" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
