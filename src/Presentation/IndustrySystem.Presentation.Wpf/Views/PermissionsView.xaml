<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.PermissionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
    
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <Style x:Key="SearchTextField" TargetType="TextBox" BasedOn="{StaticResource ManagementSearchTextBox}"/>
    </UserControl.Resources>
    
    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{StaticResource StandardGridSpacing}"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{StaticResource MediumGridSpacing}"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{StaticResource PageHeaderIconBorder}" Background="{StaticResource PermissionGradient}">
                    <TextBlock Text="&#xE72E;" Style="{StaticResource PageHeaderMdl2Icon}"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.Nav_Permissions}" Style="{StaticResource PageHeaderTitle}"/>
                    <TextBlock Text="{x:Static loc:Strings.View_Permissions_Subtitle}" Style="{StaticResource PageHeaderSubtitle}"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1"
                   Style="{StaticResource HeaderActionOutlinedButton}"
                   Command="{Binding RefreshCommand}"
                   VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" 
                                            VerticalAlignment="Center"
                                            Margin="0,0,6,0"/>
                    <TextBlock Text="{x:Static loc:Strings.Btn_Refresh}" 
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Add Permission Card -->
        <Border Grid.Row="2" Style="{StaticResource FormCard}">
            <StackPanel>
                <TextBlock Text="{x:Static loc:Strings.Section_AddNewPermission}" 
                          FontSize="15" FontWeight="SemiBold"/>
                
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0"
                            Text="{Binding NewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Col_Permission_Name}"
                            materialDesign:HintAssist.IsFloating="True"/>
                    
                    <TextBox Grid.Column="2"
                            Text="{Binding NewDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Col_Permission_DisplayName}"
                            materialDesign:HintAssist.IsFloating="True" />

                    <TextBox Grid.Column="4"
                            Text="{Binding NewGroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Col_Group}"
                            materialDesign:HintAssist.IsFloating="True" />
                    
                    <Button Grid.Column="6"
                           Command="{Binding AddCommand}"
                           Style="{StaticResource AppInteractiveButtonPrimary}"
                           Width="130" Height="40">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="LockPlus" 
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"/>
                            <TextBlock Text="{x:Static loc:Strings.Btn_AddPermission}" 
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Permissions List Card -->
        <Border Grid.Row="4" Style="{StaticResource FormCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource MediumGridSpacing}"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="{StaticResource MediumGridSpacing}"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0"
                              Text="{x:Static loc:Strings.Section_PermissionList}" 
                              FontSize="15" FontWeight="SemiBold"/>
                    
                    <TextBox Grid.Column="1"
                            Width="220"
                            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource SearchTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Search_Permissions}"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="Magnify"/>
                </Grid>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding PagedPermissions}"
                          Style="{StaticResource ListViewLikeDataGrid}">
                    <DataGrid.Columns>
                            <DataGridTemplateColumn Width="280" Header="{x:Static loc:Strings.Col_Permission}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <Border Style="{StaticResource DataGridLeadingIconBadge}" Background="{StaticResource PermissionGradient}">
                                                <materialDesign:PackIcon Kind="LockOutline" Style="{StaticResource DataGridLeadingPackIcon}" Foreground="White"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13"/>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="11" Opacity="0.6"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Width="220" Header="{x:Static loc:Strings.Col_DisplayName}" Binding="{Binding DisplayName}"/>

                            <DataGridTemplateColumn Width="130" Header="{x:Static loc:Strings.Col_Group}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:Chip Content="{Binding GroupName}"
                                                            Background="{StaticResource InfoBrush}"
                                                            Foreground="White"
                                                            Margin="6,0"
                                                            Padding="6,2"
                                                            FontSize="11"
                                                            HorizontalAlignment="Left"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="100" Header="{x:Static loc:Strings.Col_Actions}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                   Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   ToolTip="{x:Static loc:Strings.Tooltip_EditPermission}">
                                                <materialDesign:PackIcon Kind="Pencil" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>

                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                   Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   ToolTip="{x:Static loc:Strings.Tooltip_DeletePermission}"
                                                   Foreground="{StaticResource ErrorBrush}">
                                                <materialDesign:PackIcon Kind="Delete" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pagination -->
                <Border Grid.Row="4" Style="{StaticResource PaginationCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Style="{StaticResource PaginationStatsPanel}">
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Total}" Opacity="0.7"/>
                            <TextBlock Text="{Binding TotalCount}" FontWeight="SemiBold" Foreground="{StaticResource HeaderGradient}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Records}" Opacity="0.7"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Style="{StaticResource PaginationButtonPanel}">
                            <Button Content="&#xE892;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding FirstPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_FirstPage}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding PreviousPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Prev}" Style="{StaticResource PaginationButton}"/>

                            <Border Style="{StaticResource CurrentPageBorder}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CurrentPage}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" / " Opacity="0.7" Margin="4,0"/>
                                    <TextBlock Text="{Binding TotalPages}" Opacity="0.7"/>
                                </StackPanel>
                            </Border>

                            <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding NextPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Next}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE893;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding LastPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_LastPage}" Style="{StaticResource PaginationButton}"/>

                            <ComboBox SelectedItem="{Binding PageSize, Mode=TwoWay}"
                                      ItemsSource="{Binding PageSizes}"
                                      Width="80" Margin="12,0,0,0" Style="{StaticResource PaginationComboBox}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_PerPage}" VerticalAlignment="Center" Opacity="0.7" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

