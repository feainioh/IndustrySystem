<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.RunExperimentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:dto="clr-namespace:IndustrySystem.Application.Contracts.Dtos;assembly=IndustrySystem.Application.Contracts"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- 执行状态 Badge 样式 -->
    <Style x:Key="ExecStatusBadge" TargetType="Border">
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="8,3"/>
    </Style>

    <!-- DataGrid 行样式：选中高亮 -->
        <Style x:Key="ExecRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
      <Setter Property="Cursor" Value="Hand"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AppListRowSelectedBrush}"/>
                    <Setter Property="BorderBrush" Value="#4A7EFF"/>
                    <Setter Property="BorderThickness" Value="3,0,0,0"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

    <Grid Style="{StaticResource PageRootGrid}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="12"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Style="{StaticResource PageHeaderIconBorder}" Background="{DynamicResource ExperimentGradientBrush}">
                <TextBlock Text="&#xE9D9;" Style="{StaticResource PageHeaderMdl2Icon}"/>
            </Border>
            <TextBlock Text="{x:Static loc:Strings.Nav_RunExperiment}"
                                 Style="{StaticResource PageHeaderTitle}"/>
    </StackPanel>
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,12,0,0">

                <!-- 实验执行列表卡片 -->
                <Border Style="{StaticResource ListCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 标题行 -->
                        <Grid Grid.Row="0" Margin="16,14,16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                          Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                          Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Static loc:Strings.Section_ExecutionList}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <!-- 切换实验类型 -->
                            <TextBlock Grid.Column="1" Text="{x:Static loc:Strings.Label_SwitchExperimentType}" FontSize="13"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="3" Width="200" VerticalAlignment="Center"
                       ItemsSource="{Binding Experiments}"
                       SelectedItem="{Binding SelectedExperiment}"
                       DisplayMemberPath="Name"/>
                        </Grid>

                        <!-- DataGrid -->
                        <DataGrid Grid.Row="1" Margin="8,0,8,0"
                     ItemsSource="{Binding Executions}"
                     SelectedItem="{Binding SelectedExecution}"
                     RowStyle="{StaticResource ExecRowStyle}"
                     Style="{StaticResource ModernDataGrid}"
                     MaxHeight="280">
                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="{x:Static loc:Strings.Col_ExecutionId}" Binding="{Binding ExecId}" Width="110"
                                  ElementStyle="{StaticResource {x:Type TextBlock}}"/>
                                                                <DataGridTextColumn Header="{x:Static loc:Strings.Field_ExperimentName}" Binding="{Binding ExperimentName}" Width="*"/>
                                                                <DataGridTemplateColumn Header="{x:Static loc:Strings.Col_Status}" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type dto:ExperimentExecutionDto}">
                                            <Border CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#22888888"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="{x:Static dto:RunState.Running}">
                                                                <Setter Property="Background" Value="#220078D4"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="{x:Static dto:RunState.Paused}">
                                                                <Setter Property="Background" Value="#22FFB900"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="{x:Static dto:RunState.Completed}">
                                                                <Setter Property="Background" Value="#2210893E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock VerticalAlignment="Center" FontSize="13">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{x:Static loc:Strings.Run_State_Queued}"/>
                                                            <Setter Property="Foreground" Value="#FF888888"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="{x:Static dto:RunState.Running}">
                                                                    <Setter Property="Text" Value="{x:Static loc:Strings.Run_State_Running}"/>
                                                                    <Setter Property="Foreground" Value="#FF0078D4"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="{x:Static dto:RunState.Paused}">
                                                                    <Setter Property="Text" Value="{x:Static loc:Strings.Run_State_Paused}"/>
                                                                    <Setter Property="Foreground" Value="#FFCB8400"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="{x:Static dto:RunState.Completed}">
                                                                    <Setter Property="Text" Value="{x:Static loc:Strings.Run_State_Completed}"/>
                                                                    <Setter Property="Foreground" Value="#FF10893E"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="{x:Static dto:RunState.Stopped}">
                                                                    <Setter Property="Text" Value="{x:Static loc:Strings.Run_State_Stopped}"/>
                                                                    <Setter Property="Foreground" Value="#FFDC3545"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Col_StepProgress}" Binding="{Binding StepProgress}" Width="90"/>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Col_ElapsedTime}" Binding="{Binding Elapsed, StringFormat=hh\\:mm\\:ss}" Width="100"/>
                                <DataGridTemplateColumn Header="{x:Static loc:Strings.Col_StartTime}" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type dto:ExperimentExecutionDto}">
                                            <TextBlock VerticalAlignment="Center" Padding="4,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding StartTime, StringFormat=HH\\:mm\\:ss}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StartTime}" Value="{x:Null}">
                                                                <Setter Property="Text" Value="-"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 底部提示 -->
                        <TextBlock Grid.Row="2" Margin="16,8,16,12" FontSize="12"
                      Text="{x:Static loc:Strings.Run_ExecutionListHint}"
                      Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </Grid>
                </Border>

                <Rectangle Height="12"/>

                <!-- 当前监控卡片 -->
                <Border Style="{StaticResource FormCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 标题行 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Static loc:Strings.Run_Label_CurrentMonitor}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentExperiment}" FontSize="14" FontWeight="SemiBold"
                        Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                        VerticalAlignment="Center" Margin="4,0"/>
                            <Border CornerRadius="4" Padding="8,3" Margin="8,0,0,0" Background="#220078D4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding RunStatus}" FontSize="12" Foreground="#FF0078D4"/>
                            </Border>
                            <TextBlock Text="{Binding SelectedExecution.ExecId}" FontSize="13"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>

                        <!-- 步骤流程 -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Steps}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" IsItemsHost="True"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type dto:ExperimentStepDto}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border CornerRadius="14" Padding="14,6" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#22888888"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="{x:Static dto:StepState.Completed}">
                                                            <Setter Property="Background" Value="#2210893E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="{x:Static dto:StepState.Running}">
                                                            <Setter Property="Background" Value="#FF0078D4"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#FF888888"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding State}" Value="{x:Static dto:StepState.Completed}">
                                                                <Setter Property="Foreground" Value="#FF10893E"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding State}" Value="{x:Static dto:StepState.Running}">
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <!-- 箭头分隔符（最后一个不显示）-->
                                        <TextBlock Text=" → " FontSize="13" VerticalAlignment="Center"
                              Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 时间 + 进度条 -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ElapsedTime}" FontSize="24" FontWeight="Bold"
                        VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                        <ProgressBar Grid.Column="1" Height="10" VerticalAlignment="Center"
                                                    Minimum="0" Maximum="100" Value="{Binding Progress, Mode=OneWay}"/>
                            <TextBlock Grid.Column="2" Text="{Binding CurrentStepProgress}" FontSize="13"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </Grid>

                        <!-- 控制按钮 -->
                        <StackPanel Grid.Row="6" Orientation="Horizontal">
                            <Button Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}"
                     Style="{StaticResource AppInteractiveButtonPrimary}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Static loc:Strings.Btn_Start}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding PauseCommand}" IsEnabled="{Binding CanPause}"
                     Style="{StaticResource AppInteractiveButtonNeutral}" Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Static loc:Strings.Btn_Pause}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"
                        Style="{StaticResource RunExperimentStopButton}" Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"
                            VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Static loc:Strings.Btn_Terminate}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ResetCommand}" IsEnabled="{Binding CanReset}"
                     Style="{StaticResource AppInteractiveButtonNeutral}" Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Static loc:Strings.Btn_Reset}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBlock VerticalAlignment="Center" Margin="20,0,0,0" FontSize="13"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        Text="{x:Static loc:Strings.Status_Executing}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanStop}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <Rectangle Height="12"/>

                <!-- 底部两列：关键指标 + 最近报警 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 关键指标 -->
                          <Border Grid.Column="0" Style="{StaticResource FormCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                          Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                          Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Static loc:Strings.Section_KeyMetrics}" FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                            <ItemsControl Grid.Row="2" ItemsSource="{Binding Metrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" IsItemsHost="True"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type dto:KeyMetricDto}">
                                        <StackPanel Margin="0,8,16,8">
                                            <TextBlock Text="{Binding Label}" FontSize="13"
                                Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Value}" FontSize="20" FontWeight="Bold" Margin="0,2,4,0"/>
                                                <TextBlock Text="{Binding Unit}" FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,2"
                                  Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- 最近报警 -->
                          <Border Grid.Column="2" Style="{StaticResource FormCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                          Foreground="#FFDC3545" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Static loc:Strings.Section_RecentAlarms}" FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                            <ItemsControl Grid.Row="2" ItemsSource="{Binding RecentAlarms}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type dto:AlarmDto}">
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Border CornerRadius="3" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#22DC3545"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Acknowledged}" Value="True">
                                                                <Setter Property="Background" Value="#22FFB900"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="error"/>
                                                            <Setter Property="Foreground" Value="#FFDC3545"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Acknowledged}" Value="True">
                                                                    <Setter Property="Text" Value="warn"/>
                                                                    <Setter Property="Foreground" Value="#FFCB8400"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding Message}" FontSize="13" VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis" MaxWidth="240"/>
                                            <TextBlock Text="{Binding Time, StringFormat=HH\\:mm\\:ss}" FontSize="12"
                                Margin="8,0,0,0" VerticalAlignment="Center"
                                Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- 无报警提示 -->
                            <TextBlock Grid.Row="2" Text="{x:Static loc:Strings.Msg_NoRecentAlarms}" FontSize="13"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RecentAlarms.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>

                <Rectangle Height="16"/>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
