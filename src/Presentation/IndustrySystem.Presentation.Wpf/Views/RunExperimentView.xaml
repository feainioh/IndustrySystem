<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.RunExperimentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:dto="clr-namespace:IndustrySystem.Application.Contracts.Dtos;assembly=IndustrySystem.Application.Contracts"
             xmlns:vm="clr-namespace:IndustrySystem.Presentation.Wpf.ViewModels"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <!-- Group DataGrid row style -->
    <Style x:Key="GroupRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
      <Setter Property="Cursor" Value="Hand"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{StaticResource AppListRowSelectedBrush}"/>
          <Setter Property="BorderBrush" Value="#4A7EFF"/>
          <Setter Property="BorderThickness" Value="3,0,0,0"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <materialDesign:DrawerHost x:Name="StatusDrawer" IsBottomDrawerOpen="{Binding IsStatusBarExpanded}">
    <materialDesign:DrawerHost.BottomDrawerContent>
      <Border Background="#FDFDFD" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
              Padding="16,12" MinHeight="120" MaxHeight="280">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <!-- Column 1: Modbus + Devices -->
          <StackPanel Grid.Column="0">
            <TextBlock Text="设备连接" FontSize="13" FontWeight="SemiBold" Foreground="#1D2939" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
              <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                <Ellipse.Style>
                  <Style TargetType="Ellipse">
                    <Setter Property="Fill" Value="#DC3545"/>
                    <Style.Triggers><DataTrigger Binding="{Binding ModbusConnected}" Value="True"><Setter Property="Fill" Value="#10893E"/></DataTrigger></Style.Triggers>
                  </Style>
                </Ellipse.Style>
              </Ellipse>
              <TextBlock FontSize="12" Foreground="#667085"><Run Text="Modbus · "/><Run Text="{Binding ModbusStatusText}" Foreground="#1D2939"/></TextBlock>
            </StackPanel>
            <ItemsControl ItemsSource="{Binding DeviceItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:DeviceStatusItem}">
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                    <Ellipse Width="6" Height="6" Margin="8,0,6,0">
                      <Ellipse.Style>
                        <Style TargetType="Ellipse">
                          <Setter Property="Fill" Value="#DC3545"/>
                          <Style.Triggers><DataTrigger Binding="{Binding IsOnline}" Value="True"><Setter Property="Fill" Value="#10893E"/></DataTrigger></Style.Triggers>
                        </Style>
                      </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="12" Foreground="#1D2939" VerticalAlignment="Center">
                      <Run Text="{Binding DeviceName, Mode=OneWay}"/><Run Text=" · " Foreground="#94A3B8"/><Run Text="{Binding StatusText, Mode=OneWay}" Foreground="#667085"/>
                    </TextBlock>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          <!-- Column 2: API details -->
          <StackPanel Grid.Column="1" Margin="16,0,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                <Ellipse.Style>
                  <Style TargetType="Ellipse">
                    <Setter Property="Fill" Value="#DC3545"/>
                    <Style.Triggers><DataTrigger Binding="{Binding SyncStatus.IsRunning}" Value="True"><Setter Property="Fill" Value="#10893E"/></DataTrigger></Style.Triggers>
                  </Style>
                </Ellipse.Style>
              </Ellipse>
              <TextBlock Text="外部API同步" FontSize="13" FontWeight="SemiBold" Foreground="#1D2939"/>
            </StackPanel>
            <Grid Margin="0,0,0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="状态" FontSize="12" Foreground="#94A3B8"/><TextBlock Grid.Column="1" Text="{Binding SyncStatusText}" FontSize="12" Foreground="#1D2939"/></Grid>
            <Grid Margin="0,0,0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="端点" FontSize="12" Foreground="#94A3B8"/><TextBlock Grid.Column="1" Text="{Binding ApiEndpointCount, StringFormat={}{0} 个}" FontSize="12" Foreground="#1D2939"/></Grid>
            <Grid Margin="0,0,0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="已处理" FontSize="12" Foreground="#94A3B8"/><TextBlock Grid.Column="1" Text="{Binding SyncStatus.TotalProcessedCount, StringFormat={}{0} 条}" FontSize="12" Foreground="#10893E"/></Grid>
            <Grid Margin="0,0,0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="失败" FontSize="12" Foreground="#94A3B8"/><TextBlock Grid.Column="1" Text="{Binding SyncStatus.TotalFailedCount, StringFormat={}{0} 条}" FontSize="12" Foreground="#DC3545"/></Grid>
            <Grid Margin="0,0,0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="上次同步" FontSize="12" Foreground="#94A3B8"/><TextBlock Grid.Column="1" Text="{Binding ApiLastSyncTime}" FontSize="12" Foreground="#1D2939"/></Grid>
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="最后错误" FontSize="12" Foreground="#94A3B8"/><TextBlock Grid.Column="1" Text="{Binding ApiLastError}" FontSize="12" Foreground="#DC3545" TextTrimming="CharacterEllipsis"/></Grid>
          </StackPanel>
          <!-- Column 3: Summary -->
          <StackPanel Grid.Column="2" Margin="16,0,0,0">
            <TextBlock Text="设备总览" FontSize="13" FontWeight="SemiBold" Foreground="#1D2939" Margin="0,0,0,8"/>
            <Border CornerRadius="10" Background="#EEF5FF" Padding="16,12" HorizontalAlignment="Left">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding DeviceItems.Count}" FontSize="28" FontWeight="Bold" Foreground="#0078D4" HorizontalAlignment="Center"/>
                <TextBlock Text="已配置设备" FontSize="12" Foreground="#667085" HorizontalAlignment="Center"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </Grid>
      </Border>
    </materialDesign:DrawerHost.BottomDrawerContent>

    <Grid Style="{StaticResource PageRootGrid}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="12"/>
      <RowDefinition Height="330"/>
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Row 0: Header + Mode Toggle -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <Border Style="{StaticResource PageHeaderIconBorder}" Background="{DynamicResource ExperimentGradientBrush}">
          <TextBlock Text="&#xE9D9;" Style="{StaticResource PageHeaderMdl2Icon}"/>
        </Border>
        <TextBlock Text="{x:Static loc:Strings.Nav_RunExperiment}" Style="{StaticResource PageHeaderTitle}"/>
      </StackPanel>
      <Border Grid.Column="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
              CornerRadius="8" Padding="8,5" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="单机" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                     Foreground="#0078D4" Margin="0,0,6,0"/>
          <CheckBox IsChecked="{Binding IsOnlineMode}" Style="{StaticResource ModeSwitchToggle}"/>
          <TextBlock Text="联机" FontSize="13" VerticalAlignment="Center"
                     Foreground="#667085" Margin="6,0,0,0"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Row 2: Master-Detail (fixed height) -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- ===== Left: Search + Group List (fixed height) ===== -->
      <Border Grid.Column="0" Style="{StaticResource ListCard}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,14,16,10">
            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       Foreground="{DynamicResource SystemControlForegroundAccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="查找实验组" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock FontSize="13" Margin="4,0,0,0"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"
                       Text="{Binding FilteredGroups.Count, StringFormat=（共 {0} 组）}"/>
          </StackPanel>

          <Border Grid.Row="1" Margin="16,0,16,8" CornerRadius="6" Background="#F8FAFC"
                  BorderBrush="#CBD5E1" BorderThickness="1" Padding="8,4">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         Foreground="#667085" VerticalAlignment="Center" Margin="4,0,6,0"/>
              <TextBox Grid.Column="1" Text="{Binding GroupSearchText, UpdateSourceTrigger=PropertyChanged}"
                       BorderThickness="0" Background="Transparent" FontSize="13"
                       VerticalAlignment="Center" VerticalContentAlignment="Center" Foreground="#1D2939" Padding="0,4"/>
              <Button Grid.Column="2" Width="28" Height="28" Background="Transparent" BorderThickness="0"
                      Cursor="Hand" VerticalAlignment="Center" ToolTip="刷新实验组列表"
                      Command="{Binding RefreshCommand}">
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="#667085" VerticalAlignment="Center" HorizontalAlignment="Center"/>
              </Button>
            </Grid>
          </Border>

          <!-- Empty state + ListBox overlay in same grid cell -->
          <Grid Grid.Row="2" Margin="8,0,8,8">
            <!-- Empty state -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding FilteredGroups.Count}" Value="0">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                           Foreground="#CBD5E1" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#667085">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="未找到匹配的实验组"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding GroupSearchText}" Value="">
                          <Setter Property="Text" Value="暂无实验组数据"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBlock HorizontalAlignment="Center" FontSize="12" Foreground="#94A3B8"
                           Text="请在「实验组配置」页面创建实验组"/>
              </StackPanel>
            </Border>

            <!-- Filtered group ListBox – scrolls internally -->
            <ListBox ItemsSource="{Binding FilteredGroups}" SelectedItem="{Binding SearchSelection, Mode=TwoWay}"
                     BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
              <ListBox.Style>
                <Style TargetType="ListBox">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding FilteredGroups.Count}" Value="0">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </ListBox.Style>
              <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                  <Setter Property="Padding" Value="0"/>
                  <Setter Property="Margin" Value="0"/>
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border" Background="Transparent" Padding="8,4" Margin="0,1"
                                CornerRadius="4" Cursor="Hand" BorderThickness="3,0,0,0">
                          <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1D2939" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Text="{Binding GroupCode}" FontSize="12" Foreground="#667085" Margin="0,0,8,0"/>
                              <TextBlock Text="{Binding StepDisplay}" FontSize="12" Foreground="#0078D4"
                                         TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                          </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#EEF5FF"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#0078D4"/>
                          </Trigger>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </ListBox.ItemContainerStyle>
            </ListBox>
          </Grid>

          <!-- Add-to-list button -->
          <Button Grid.Row="3" Margin="16,6,16,10" Height="34"
                  Command="{Binding AddToExecutionListCommand}"
                  Style="{StaticResource AppInteractiveButtonPrimary}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Margin="0,0,4,0" VerticalAlignment="Center"/>
              <TextBlock Text="添加至运行列表" VerticalAlignment="Center" FontSize="13"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>

      <!-- ===== Right: Execution List DataGrid + Experiments ===== -->
      <Border Grid.Column="2" Style="{StaticResource ListCard}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,14,16,10">
            <TextBlock Text="&#xE7C5;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       Foreground="{DynamicResource SystemControlForegroundAccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="实验执行列表" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock FontSize="13" Margin="4,0,0,0" VerticalAlignment="Center"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       Text="{Binding SelectedGroups.Count, StringFormat=（{0} 组）}"/>
          </StackPanel>

          <!-- Execution List DataGrid -->
          <DataGrid Grid.Row="1" Margin="8,0,8,0" MaxHeight="140" HeadersVisibility="Column"
                    ItemsSource="{Binding SelectedGroups}"
                    SelectedItem="{Binding ActiveGroup, Mode=TwoWay}"
                    RowStyle="{StaticResource GroupRowStyle}"
                    CanUserAddRows="False" CanUserDeleteRows="False" AutoGenerateColumns="False">
            <DataGrid.Style>
              <Style TargetType="DataGrid" BasedOn="{StaticResource ModernDataGrid}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding SelectedGroups.Count}" Value="0">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGrid.Style>
            <DataGrid.Columns>
              <DataGridTextColumn Header="编号" Binding="{Binding GroupCode}" Width="120"/>
              <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
              <DataGridTextColumn Header="步骤" Binding="{Binding StepExperimentIds.Count, StringFormat={}{0} 步}" Width="60"/>
              <DataGridTemplateColumn Header="操作" Width="50">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate DataType="{x:Type dto:ExperimentGroupDto}">
                    <Button Width="24" Height="24" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="移出列表"
                            Command="{Binding DataContext.RemoveFromListCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                            CommandParameter="{Binding}">
                      <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#DC3545"/>
                    </Button>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>

          <!-- Placeholder when empty -->
          <Border Grid.Row="1" CornerRadius="6" Background="#F8FAFC" BorderBrush="#E2E8F0"
                  BorderThickness="1" Padding="12,10" Margin="8,0,8,0" Height="60">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding SelectedGroups.Count}" Value="0">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <TextBlock Text="暂未添加实验组，请先在左侧搜索并添加" FontSize="13" Foreground="#667085"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>

          <!-- Experiment Steps -->
          <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Margin="16,0,16,6">
              <TextBlock Text="&#xECAA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         Foreground="{DynamicResource SystemControlForegroundAccentBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
              <TextBlock Text="实验步骤列表" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
              <Border CornerRadius="8" Background="#EEF5FF" Padding="6,2" Margin="8,0,0,0">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding ActiveGroup}" Value="{x:Null}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock FontSize="11" Foreground="#0078D4"
                           Text="{Binding GroupExperiments.Count, StringFormat=共 {0} 步}"/>
              </Border>
            </StackPanel>
            <ScrollViewer Margin="8,0,8,8" MaxHeight="110" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding GroupExperiments}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type dto:ExperimentSummaryDto}">
                    <Border Style="{StaticResource GroupExperimentItemBorder}">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource StepOrderBadge}">
                          <TextBlock Text="&#xE768;" Style="{StaticResource StepOrderText}" FontFamily="Segoe MDL2 Assets"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding Status}" FontSize="11"
                                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <!-- Row 3 Spacer -->
    <Rectangle Grid.Row="3" Height="12"/>

    <!-- Row 4: Current Execution Monitor -->
    <Border Grid.Row="4" Style="{StaticResource FormCard}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="10"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="12"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="12"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
          <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
          <TextBlock Text="当前监控" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding CurrentGroupName}" FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource SystemControlForegroundAccentBrush}" VerticalAlignment="Center" Margin="4,0"/>
          <Border CornerRadius="4" Padding="8,3" Margin="8,0,0,0" Background="#220078D4" VerticalAlignment="Center">
            <TextBlock Text="{Binding RunStatus}" FontSize="12" Foreground="#FF0078D4"/>
          </Border>
        </StackPanel>

        <ItemsControl Grid.Row="2" ItemsSource="{Binding Steps}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" IsItemsHost="True"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type dto:ExperimentStepDto}">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border CornerRadius="14" Padding="14,6" VerticalAlignment="Center">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="#22888888"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding State}" Value="{x:Static dto:StepState.Completed}">
                          <Setter Property="Background" Value="#2210893E"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding State}" Value="{x:Static dto:StepState.Running}">
                          <Setter Property="Background" Value="#FF0078D4"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#FF888888"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding State}" Value="{x:Static dto:StepState.Completed}">
                            <Setter Property="Foreground" Value="#FF10893E"/>
                          </DataTrigger>
                          <DataTrigger Binding="{Binding State}" Value="{x:Static dto:StepState.Running}">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </Border>
                <TextBlock Text=" → " FontSize="13" VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="{Binding ElapsedTime}" FontSize="24" FontWeight="Bold"
                     VerticalAlignment="Center" Margin="0,0,16,0"/>
          <ProgressBar Grid.Column="1" Height="10" VerticalAlignment="Center"
                       Minimum="0" Maximum="100" Value="{Binding Progress, Mode=OneWay}"/>
          <TextBlock Grid.Column="2" Text="{Binding CurrentStepProgress}" FontSize="13"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                     VerticalAlignment="Center" Margin="16,0,0,0"/>
        </Grid>

        <StackPanel Grid.Row="6" Orientation="Horizontal">
          <Button Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}"
                  Style="{StaticResource AppInteractiveButtonPrimary}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
              <TextBlock Text="{x:Static loc:Strings.Btn_Start}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding PauseCommand}" IsEnabled="{Binding CanPause}"
                  Style="{StaticResource AppInteractiveButtonNeutral}" Margin="10,0,0,0">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
              <TextBlock Text="{x:Static loc:Strings.Btn_Pause}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"
                  Style="{StaticResource RunExperimentStopButton}" Margin="10,0,0,0">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
              <TextBlock Text="{x:Static loc:Strings.Btn_Terminate}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding ResetCommand}" IsEnabled="{Binding CanReset}"
                  Style="{StaticResource AppInteractiveButtonNeutral}" Margin="10,0,0,0">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center"/>
              <TextBlock Text="{x:Static loc:Strings.Btn_Reset}" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <TextBlock VerticalAlignment="Center" Margin="20,0,0,0" FontSize="13"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Text="执行中...">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding CanStop}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Row 5: Metrics + Alarms -->
    <Grid Grid.Row="5">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource FormCard}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       Foreground="{DynamicResource SystemControlForegroundAccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="{x:Static loc:Strings.Section_KeyMetrics}" FontSize="15" FontWeight="SemiBold"/>
          </StackPanel>
          <ItemsControl Grid.Row="2" ItemsSource="{Binding Metrics}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="2" IsItemsHost="True"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type dto:KeyMetricDto}">
                <StackPanel Margin="0,8,16,8">
                  <TextBlock Text="{Binding Label}" FontSize="13"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Value}" FontSize="20" FontWeight="Bold" Margin="0,2,4,0"/>
                    <TextBlock Text="{Binding Unit}" FontSize="14" VerticalAlignment="Bottom" Margin="0,0,0,2"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                  </StackPanel>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </Border>

      <Border Grid.Column="2" Style="{StaticResource FormCard}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       Foreground="#FFDC3545" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="{x:Static loc:Strings.Section_RecentAlarms}" FontSize="15" FontWeight="SemiBold"/>
          </StackPanel>
          <ItemsControl Grid.Row="2" ItemsSource="{Binding RecentAlarms}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type dto:AlarmDto}">
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                  <Border CornerRadius="3" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Background" Value="#22DC3545"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Acknowledged}" Value="True">
                            <Setter Property="Background" Value="#22FFB900"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <TextBlock FontSize="11" VerticalAlignment="Center">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Text" Value="error"/>
                          <Setter Property="Foreground" Value="#FFDC3545"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Acknowledged}" Value="True">
                              <Setter Property="Text" Value="warn"/>
                              <Setter Property="Foreground" Value="#FFCB8400"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Border>
                  <TextBlock Text="{Binding Message}" FontSize="13" VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" MaxWidth="240"/>
                  <TextBlock Text="{Binding Time, StringFormat=HH\\:mm\\:ss}" FontSize="12"
                             Margin="8,0,0,0" VerticalAlignment="Center"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Grid.Row="2" Text="{x:Static loc:Strings.Msg_NoRecentAlarms}" FontSize="13"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16,0,0">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding RecentAlarms.Count}" Value="0">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>
      </Border>
    </Grid>

    <!-- Row 6: Status summary bar (click to open drawer) -->
    <Border Grid.Row="6" Margin="0,8,0,0" Background="#F8FAFC" BorderBrush="#E2E8F0"
            BorderThickness="0,1,0,0" Padding="16,6" Cursor="Hand"
            MouseLeftButtonDown="StatusBar_MouseLeftButtonDown">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse Width="8" Height="8" Margin="0,0,4,0">
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Setter Property="Fill" Value="#DC3545"/>
                <Style.Triggers><DataTrigger Binding="{Binding ModbusConnected}" Value="True"><Setter Property="Fill" Value="#10893E"/></DataTrigger></Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>
          <TextBlock Text="{Binding ModbusStatusText}" FontSize="12" Foreground="#667085" Margin="0,0,12,0"/>
          <Ellipse Width="8" Height="8" Margin="0,0,4,0">
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Setter Property="Fill" Value="#DC3545"/>
                <Style.Triggers><DataTrigger Binding="{Binding SyncStatus.IsRunning}" Value="True"><Setter Property="Fill" Value="#10893E"/></DataTrigger></Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>
          <TextBlock Text="{Binding SyncStatusText}" FontSize="12" Foreground="#667085" Margin="0,0,12,0"/>
          <Ellipse Width="8" Height="8" Margin="0,0,4,0" Fill="#10893E"/>
          <TextBlock Text="{Binding DeviceSummary}" FontSize="12" Foreground="#667085"/>
        </StackPanel>
        <TextBlock Grid.Column="1" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#667085"
                   VerticalAlignment="Center" Text="&#xE70D;"/>
      </Grid>
    </Border>
  </Grid>
  </materialDesign:DrawerHost>
</UserControl>
