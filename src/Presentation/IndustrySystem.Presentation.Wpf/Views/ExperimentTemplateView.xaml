<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.ExperimentTemplateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:vm="clr-namespace:IndustrySystem.Presentation.Wpf.ViewModels"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
    <UserControl.Resources>
        <!-- 模板列表项容器样式 -->
        <Style x:Key="TemplateListBoxItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="RootBorder"
                    Background="Transparent"
                    CornerRadius="6"
                    Padding="12,9"
                    BorderThickness="1"
                    BorderBrush="Transparent"
                    SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource AppListRowHoverBrush}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource AppListRowSelectedBrush}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="RootBorder" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{StaticResource PageHeaderIconBorder}" Background="{DynamicResource ExperimentGradientBrush}">
                    <materialDesign:PackIcon Kind="FlaskOutline" Style="{StaticResource PageHeaderPackIcon}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Page_Templates_Title]}" Style="{StaticResource PageHeaderTitle}"/>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Page_Templates_Subtitle]}" Style="{StaticResource PageHeaderSubtitle}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsPanel}">
                <Button Style="{StaticResource HeaderActionOutlinedButton}"
                Command="{Binding RefreshCommand}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Btn_Refresh]}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderActionAccentButton}"
                Click="OnAdd">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Btn_NewTemplate]}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 主体区域 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左：模板列表 -->
                        <Border Grid.Column="0" Style="{StaticResource FormCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding Source={StaticResource Loc}, Path=[Section_TemplateList]}" Style="{StaticResource ManagementSectionTitle}" Margin="2,0,0,0"/>

                    <ListBox Grid.Row="2"
                   ItemsSource="{Binding Templates}"
                   SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                   ItemContainerStyle="{StaticResource TemplateListBoxItem}"
                   BorderThickness="0"
                   Background="Transparent"
                   Foreground="{DynamicResource AppPrimaryTextBrush}"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   VirtualizingPanel.IsVirtualizing="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 类型色块指示器 -->
                                    <Border Grid.Column="0" Width="4" CornerRadius="2"
                          Background="{DynamicResource ExperimentGradientBrush}"
                          VerticalAlignment="Stretch" Margin="0,2"/>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="14"
                               TextTrimming="CharacterEllipsis" MaxWidth="180" Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Margin="5 3" Foreground="{DynamicResource AppMutedTextBrush}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                                        <Border Background="{DynamicResource AppChipBackgroundBrush}" CornerRadius="6" Padding="6,2" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding Type, Converter={StaticResource EnumDescriptionConverter}}"
                                                                     FontSize="11" Foreground="{DynamicResource AppChipForegroundBrush}"/>
                                            </Border>
                                            <TextBlock Text="{Binding UpdatedAt, StringFormat=MM-dd HH:mm}"
                                                                 Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource MaterialDesignToolForegroundButton}"
                            Click="OnEdit"
                            ToolTip="{Binding Source={StaticResource Loc}, Path=[Tooltip_EditTemplate]}" Width="28" Height="28" Padding="0">
                                            <materialDesign:PackIcon Kind="Pencil" Width="15" Height="15"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignToolForegroundButton}"
                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding Id}"
                            ToolTip="{Binding Source={StaticResource Loc}, Path=[Tooltip_DeleteTemplate]}" Width="28" Height="28" Padding="0">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Width="15" Height="15"
                                               Foreground="{StaticResource ErrorBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右：模板详情与参数编辑 -->
                        <Border Grid.Column="2" Style="{StaticResource FormCard}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 模板基本信息 -->
                        <TextBlock Grid.Row="0" Text="{Binding Source={StaticResource Loc}, Path=[Section_TemplateInfo]}" Style="{StaticResource ManagementSectionTitle}"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" Grid.Column="0"
                       Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource MaterialTextField}"
                       materialDesign:HintAssist.Hint="{Binding Source={StaticResource Loc}, Path=[Field_ExperimentName]}"
                       materialDesign:HintAssist.IsFloating="True"/>

                            <ComboBox Grid.Row="0" Grid.Column="2"
                        ItemsSource="{Binding ExperimentTypes}"
                        SelectedItem="{Binding SelectedType}"
                        Style="{StaticResource MaterialComboBox}"
                        materialDesign:HintAssist.Hint="{Binding Source={StaticResource Loc}, Path=[Field_ExperimentType]}"
                        materialDesign:HintAssist.IsFloating="True">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <ComboBox Grid.ColumnSpan="3" Grid.Row="2" Grid.Column="0"
                        ItemsSource="{Binding ParameterOptions}"
                        SelectedItem="{Binding SelectedParameter, Mode=TwoWay}"
                        DisplayMemberPath="Name"
                        Style="{StaticResource MaterialComboBox}"
                        materialDesign:HintAssist.Hint="{Binding Source={StaticResource Loc}, Path=[Field_LinkedParameter]}"
                        materialDesign:HintAssist.IsFloating="True"/>

                            <StackPanel Visibility="Collapsed" Grid.Row="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Field_IsTemplate]}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ToggleButton IsChecked="{Binding IsTemplate}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                            </StackPanel>

                            <TextBox Visibility="Collapsed" Grid.Row="4" Grid.Column="0"
                       Text="{Binding EditingId}" IsReadOnly="True"
                       Style="{StaticResource MaterialTextField}"
                       materialDesign:HintAssist.Hint="{Binding Source={StaticResource Loc}, Path=[Field_ExperimentId]}"
                       materialDesign:HintAssist.IsFloating="True"
                       Opacity="0.6"/>

                            <TextBox Visibility="Collapsed" Grid.Row="4" Grid.Column="2"
                       Text="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" IsReadOnly="True"
                       Style="{StaticResource MaterialTextField}"
                       materialDesign:HintAssist.Hint="{Binding Source={StaticResource Loc}, Path=[Field_CreatedAt]}"
                       materialDesign:HintAssist.IsFloating="True"
                       Opacity="0.6"/>
                        </Grid>

                        <!-- 参数编辑区域 -->
                        <TextBlock Grid.Row="4" Text="{Binding Source={StaticResource Loc}, Path=[Section_ExperimentParameters]}" Style="{StaticResource ManagementSectionTitle}" Margin="0,16,0,8"/>

                        <Border Grid.Row="5"
                    BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                    CornerRadius="{DynamicResource AppInnerCornerRadius}" Padding="8" MinHeight="260" Background="{DynamicResource AppParameterSurfaceBrush}">
                            <ContentControl prism:RegionManager.RegionName="{x:Static vm:ExperimentTemplateViewModel.ParameterEditorRegionName}"/>
                        </Border>
                        <Button Command="{Binding SaveCommand}" Style="{StaticResource AppInteractiveButtonPrimary}" Grid.Row="6" HorizontalAlignment="Right" Margin="5"
                                Content="{Binding Source={StaticResource Loc},Path=[Btn_Save]}"/>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>

