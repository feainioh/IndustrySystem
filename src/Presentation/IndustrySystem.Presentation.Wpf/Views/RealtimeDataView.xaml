<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.RealtimeDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Style="{StaticResource PageRootGrid}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="280"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
        <Border Style="{StaticResource PageHeaderIconBorder}" Background="{DynamicResource DataGradient}">
          <TextBlock Text="&#xE9F9;" Style="{StaticResource PageHeaderMdl2Icon}"/>
        </Border>
        <TextBlock Text="{x:Static loc:Strings.Page_RealtimeData_Title}" Style="{StaticResource PageHeaderTitle}"/>
        <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" FontSize="13"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
          <Run Text="{x:Static loc:Strings.Realtime_CurrentMonitorPrefix}"/>
          <Run Text="{Binding CurrentMonitor,Mode=OneWay}"/>
          <Run Text="{x:Static loc:Strings.Realtime_CurrentMonitorSuffix}"/>
        </TextBlock>
      </StackPanel>

      <!-- 温度趋势图卡片 -->
      <Border Grid.Row="2" Style="{StaticResource FormCard}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,12,16,0">
            <TextBlock Text="&#xE9F3;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                       Foreground="#FFE85289" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="{x:Static loc:Strings.Section_TemperatureTrend}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
              <Run Text="{x:Static loc:Strings.Realtime_CurrentMonitorPrefix}"/>
              <Run Text="{Binding CurrentMonitor,Mode=OneWay}"/>
              <Run Text="{x:Static loc:Strings.Realtime_CurrentMonitorSuffix}"/>
            </TextBlock>
          </StackPanel>
          <Border Grid.Row="1" Margin="8,10,8,4" CornerRadius="8" Background="#F7F9FC" BorderBrush="#E5EAF0" BorderThickness="1">
            <Grid Margin="16">
              <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Polyline Stroke="#4D0078D4" StrokeThickness="3" Stretch="Fill" Points="0,150 80,120 150,132 220,70 300,92 380,48 460,82 540,36"/>
              <TextBlock Grid.Row="1" Text="{x:Static loc:Strings.Realtime_TrendPlaceholder}" FontSize="12"
                         Foreground="{StaticResource AppMutedTextBrush}" HorizontalAlignment="Right" Margin="0,12,0,0"/>
            </Grid>
          </Border>
        </Grid>
      </Border>

      <!-- 传感器指标卡片网格 -->
      <Border Grid.Row="4" Style="{StaticResource FormCard}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       Foreground="{DynamicResource SystemControlForegroundAccentBrush}" Margin="0,0,8,0"/>
            <TextBlock Text="{x:Static loc:Strings.Section_SensorMetrics}" FontSize="15" FontWeight="SemiBold"/>
          </StackPanel>
          <ItemsControl Grid.Row="2" ItemsSource="{Binding Sensors}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="4" IsItemsHost="True"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,12,12" Background="#F9FAFB" CornerRadius="8" BorderThickness="1" BorderBrush="#E5EAF0" Padding="14">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="8"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding Label}" FontSize="13" Foreground="{StaticResource AppMutedTextBrush}"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                      <TextBlock Text="{Binding ValueText}" FontSize="26" FontWeight="Bold" VerticalAlignment="Bottom"/>
                      <TextBlock Text="{Binding UnitSmall}" FontSize="13" Margin="4,0,0,4" VerticalAlignment="Bottom" Foreground="{StaticResource AppMutedTextBrush}"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Grid.Row="2" Text="{x:Static loc:Strings.Msg_NoRealtimeSensors}" FontSize="13"
                     Foreground="{StaticResource AppMutedTextBrush}" HorizontalAlignment="Center" Margin="0,20,0,4">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Sensors.Count}" Value="0">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
