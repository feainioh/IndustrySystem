<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.QuenchingParameterEditDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding RefreshCommand}" Margin="0,0,8,0">刷新</Button>
            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding NewCommand}">新建参数</Button>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}">
                <ListBox.ItemTemplate>
                    <DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="{Binding TypeName}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>

                    <TextBox Style="{StaticResource MaterialTextField}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="参数名称" materialDesign:HintAssist.IsFloating="True" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" Grid.Column="0" Style="{StaticResource MaterialTextField}" Text="{Binding QuenchingAgent}"
                                 materialDesign:HintAssist.Hint="淬灭剂" materialDesign:HintAssist.IsFloating="True" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="0" Grid.Column="2" Style="{StaticResource MaterialTextField}" Text="{Binding QuenchingAgentVolumeMl}"
                                 materialDesign:HintAssist.Hint="淬灭剂用量(mL)" materialDesign:HintAssist.IsFloating="True" Margin="0,0,0,10"/>

                        <TextBox Grid.Row="1" Grid.Column="0" Style="{StaticResource MaterialTextField}" Text="{Binding QuenchingAgentDripSpeedMlMin}"
                                 materialDesign:HintAssist.Hint="淬灭剂滴加速度(mL/min)" materialDesign:HintAssist.IsFloating="True" Margin="0,0,0,10"/>
                        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,10">
                            <TextBlock Text="先加淬灭剂" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ToggleButton IsChecked="{Binding AddQuenchingAgentFirst}" Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                        </StackPanel>

                        <TextBox Grid.Row="2" Grid.Column="0" Style="{StaticResource MaterialTextField}" Text="{Binding PreTemperatureC}"
                                 materialDesign:HintAssist.Hint="开始前温度(℃)" materialDesign:HintAssist.IsFloating="True" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource MaterialTextField}" Text="{Binding MaxTemperatureC}"
                                 materialDesign:HintAssist.Hint="淬灭过程最大温度(℃)" materialDesign:HintAssist.IsFloating="True" Margin="0,0,0,10"/>

                        <TextBox Grid.Row="3" Grid.Column="0" Style="{StaticResource MaterialTextField}" Text="{Binding StirSpeedRpm}"
                                 materialDesign:HintAssist.Hint="搅拌速度(rpm)" materialDesign:HintAssist.IsFloating="True" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="3" Grid.Column="2" Style="{StaticResource MaterialTextField}" Text="{Binding DurationMinutes}"
                                 materialDesign:HintAssist.Hint="反应时间(min)" materialDesign:HintAssist.IsFloating="True" Margin="0,0,0,10"/>

                        <TextBox Grid.Row="4" Grid.Column="0" Style="{StaticResource MaterialTextField}" Text="{Binding Detergent}"
                                 materialDesign:HintAssist.Hint="清洗剂" materialDesign:HintAssist.IsFloating="True" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="4" Grid.Column="2" Style="{StaticResource MaterialTextField}" Text="{Binding DetergentVolumeMl}"
                                 materialDesign:HintAssist.Hint="清洗剂用量(mL)" materialDesign:HintAssist.IsFloating="True" Margin="0,0,0,10"/>

                        <TextBox Grid.Row="5" Grid.Column="0" Style="{StaticResource MaterialTextField}" Text="{Binding TotalProductVolumeMl}"
                                 materialDesign:HintAssist.Hint="产物总体积(mL)" materialDesign:HintAssist.IsFloating="True" Margin="0,0,0,10"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding DeleteCommand}" Margin="0,0,8,0">删除</Button>
                        <Button Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding SaveCommand}">保存参数</Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
