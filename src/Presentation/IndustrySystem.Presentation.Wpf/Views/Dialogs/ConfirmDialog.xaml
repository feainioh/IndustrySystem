<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.ConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:prism="http://prismlibrary.com/">
    <prism:Dialog.WindowStyle>
        <StaticResource ResourceKey="DialogHostWindowStyle" />
    </prism:Dialog.WindowStyle>
    <UserControl.Resources>
        <SolidColorBrush x:Key="DialogSurfaceBrush" Color="{DynamicResource DialogSurfaceColor}" />
        <SolidColorBrush x:Key="DialogFooterBrush" Color="{DynamicResource DialogFooterColor}" />
        <loc:LocalizationProvider x:Key="Loc" />
    </UserControl.Resources>
    <Border Background="{StaticResource DialogSurfaceBrush}"
            CornerRadius="18">
        <Border.Effect>
            <StaticResource ResourceKey="DialogSurfaceShadow" />
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="1" Text="{Binding Message}" TextWrapping="Wrap" Margin="0,12,0,12"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding [Btn_Cancel], Source={StaticResource Loc}}" Margin="0,0,8,0" Command="{Binding CancelCommand}"/>
                <Button Content="{Binding [Btn_OK], Source={StaticResource Loc}}" Command="{Binding OkCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>


