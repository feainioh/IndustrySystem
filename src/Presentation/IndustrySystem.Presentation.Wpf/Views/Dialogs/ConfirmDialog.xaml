<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.ConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/">
    <prism:Dialog.WindowStyle>
        <StaticResource ResourceKey="DialogHostWindowStyle" />
    </prism:Dialog.WindowStyle>
    <UserControl.Resources>
        <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#FFFDFDFE" />
        <SolidColorBrush x:Key="DialogFooterBrush" Color="#FFF8F9FC" />
    </UserControl.Resources>
    <Border Background="{StaticResource DialogSurfaceBrush}"
            CornerRadius="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.22" Color="#000000" Direction="270"/>
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="1" Text="{Binding Message}" TextWrapping="Wrap" Margin="0,12,0,12"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Margin="0,0,8,0" Command="{Binding CancelCommand}"/>
                <Button Content="OK" Command="{Binding OkCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

