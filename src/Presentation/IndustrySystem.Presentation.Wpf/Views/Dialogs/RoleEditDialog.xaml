<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.RoleEditDialog"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
 xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
 xmlns:prism="http://prismlibrary.com/"
 MinWidth="680" MinHeight="560">
    <prism:Dialog.WindowStyle>
        <StaticResource ResourceKey="DialogHostWindowStyle" />
    </prism:Dialog.WindowStyle>
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#FFFDFDFE" />
        <SolidColorBrush x:Key="DialogFooterBrush" Color="#FFF8F9FC" />
        <Style x:Key="FormField" TargetType="TextBox" BasedOn="{StaticResource MaterialTextField}">
            <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </UserControl.Resources>
    <Border Background="Transparent" Padding="24">
        <Border Background="{StaticResource DialogSurfaceBrush}"
                CornerRadius="18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.22" Color="#000000" Direction="270"/>
            </Border.Effect>
            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border CornerRadius="18 18 0 0" Grid.Row="0" Background="{StaticResource RoleGradientBrush}" Padding="24,18">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="20"
                        Background="#33FFFFFF" Margin="0,0,14,0">
                            <materialDesign:PackIcon Kind="ShieldEditOutline" Width="22" Height="22"
                                             Foreground="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding [Dialog_RoleEdit_Title], Source={StaticResource Loc}}"
                               FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="编辑角色信息与权限分配"
                               FontSize="12" Foreground="#CCFFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Scrollable Body -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,20,24,10">

                        <!-- Section 1: 基本信息 -->
                        <materialDesign:Card Padding="18" Margin="0,0,0,14"
                                     materialDesign:ElevationAssist.Elevation="Dp1"
                                     UniformCornerRadius="8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20"
                                                     Foreground="{StaticResource PrimaryBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="基本信息" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0" Grid.Column="0" Style="{StaticResource FormField}"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="{Binding [Field_Common_Name], Source={StaticResource Loc}}"/>
                                    <TextBox Grid.Row="0" Grid.Column="2" Style="{StaticResource FormField}"
                                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="{Binding [Field_Common_Description], Source={StaticResource Loc}}"/>

                                    <CheckBox Grid.Row="1" Grid.Column="0"
                                      IsChecked="{Binding IsDefault}"
                                      Content="{Binding [Field_Role_Default], Source={StaticResource Loc}}"
                                      FontSize="13" Margin="0,0,0,6"/>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Section 2: 权限分配 -->
                        <materialDesign:Card Padding="18" Margin="0,0,0,6"
                                     materialDesign:ElevationAssist.Elevation="Dp1"
                                     UniformCornerRadius="8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <materialDesign:PackIcon Kind="KeyOutline" Width="20" Height="20"
                                                     Foreground="#8764B8"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding [Nav_Permissions], Source={StaticResource Loc}}"
                                       FontSize="15" FontWeight="SemiBold" Foreground="#8764B8"/>
                                </StackPanel>

                                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding PermissionGroups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="{Binding Title}" FontSize="13"
                                                   FontWeight="SemiBold" Opacity="0.7" Margin="0,0,0,6"/>
                                                    <ItemsControl ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <UniformGrid Columns="5"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <CheckBox Content="{Binding Name}"
                                                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                              Margin="0,3,20,3" FontSize="13"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </materialDesign:Card>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer Actions -->
                <Border Grid.Row="2" CornerRadius=" 0 0 18 18 " BorderBrush="{StaticResource DialogFooterBrush}" BorderThickness="0,1,0,0" Padding="24,14">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Content="{Binding [Btn_Cancel], Source={StaticResource Loc}}"
                        Command="{Binding CancelCommand}"
                        Width="100" Height="36" Margin="0,0,10,0"/>
                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="{Binding [Btn_Save], Source={StaticResource Loc}}"
                        Command="{Binding SaveCommand}"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        Width="100" Height="36"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</UserControl>

