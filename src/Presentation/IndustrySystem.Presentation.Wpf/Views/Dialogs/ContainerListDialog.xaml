<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.ContainerListDialog"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
 xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
 xmlns:prism="http://prismlibrary.com/">
    <prism:Dialog.WindowStyle>
     <StaticResource ResourceKey="DialogHostWindowStyle" />
 </prism:Dialog.WindowStyle>
 <UserControl.Resources> 
     <loc:LocalizationProvider x:Key="Loc" />
     <SolidColorBrush x:Key="DialogSurfaceBrush" Color="{DynamicResource DialogSurfaceColor}" />
     <SolidColorBrush x:Key="DialogFooterBrush" Color="{DynamicResource DialogFooterColor}" />
     <Style x:Key="FormField" TargetType="TextBox" BasedOn="{StaticResource DialogTextField}">
         <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
         <Setter Property="Margin" Value="0,0,0,14"/>
         <Setter Property="FontSize" Value="13"/>
     </Style>
     <Style x:Key="FormCombo" TargetType="ComboBox" BasedOn="{StaticResource DialogComboBox}">
         <Setter Property="Margin" Value="0,0,0,14"/>
         <Setter Property="FontSize" Value="13"/>
         <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
     </Style>
 </UserControl.Resources>
    <Border Padding="24" Background="Transparent" >
        <Border Background="{StaticResource DialogSurfaceBrush}"
             CornerRadius="18">
            <Border.Effect>
                <StaticResource ResourceKey="DialogSurfaceShadow" />
            </Border.Effect>
            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="18 18 0 0 " Background="{StaticResource PrimaryBrush}" Padding="24,16">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PackageVariant" Width="24" Height="24" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding [Dialog_ContainerList_Title], Source={StaticResource Loc}}" FontSize="17" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding AddContainerCommand}" Foreground="White" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{x:Static loc:Strings.Btn_Add}" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding PagedContainers}" Margin="8" Style="{StaticResource ListViewLikeDataGrid}">
                    <DataGrid.Columns>
                            <DataGridTextColumn Width="170" Header="{Binding [Col_Common_Name], Source={StaticResource Loc}}" Binding="{Binding Name}"/>
                            <DataGridTemplateColumn Width="100" Header="{x:Static loc:Strings.Col_Type}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ContainerType, Converter={StaticResource EnumDescriptionConverter}}" FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="70" Header="{x:Static loc:Strings.Lbl_GridSize}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="12">
                                    <Run Text="{Binding Rows, Mode=OneWay}"/><Run Text="×"/><Run Text="{Binding Columns, Mode=OneWay}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Width="140" Header="{Binding [Col_Common_Description], Source={StaticResource Loc}}" Binding="{Binding Description}"/>
                            <DataGridTemplateColumn Width="80" Header="{x:Static loc:Strings.Col_Actions}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                            Command="{Binding DataContext.EditContainerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}" ToolTip="{x:Static loc:Strings.Btn_Edit}">
                                                <materialDesign:PackIcon Kind="Pencil" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                            Command="{Binding DataContext.DeleteContainerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}" ToolTip="{x:Static loc:Strings.Btn_Delete}" Foreground="{StaticResource ErrorBrush}">
                                                <materialDesign:PackIcon Kind="Delete" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2" Style="{StaticResource PaginationCard}" Margin="8,0,8,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Style="{StaticResource PaginationStatsPanel}">
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Total}" Opacity="0.7"/>
                            <TextBlock Text="{Binding ContainerTotalCount}" FontWeight="SemiBold" Foreground="{StaticResource HeaderGradient}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Records}" Opacity="0.7"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Style="{StaticResource PaginationButtonPanel}">
                            <Button Content="&#xE892;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding ContainerFirstPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_FirstPage}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding ContainerPreviousPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Prev}" Style="{StaticResource PaginationButton}"/>

                            <Border Style="{StaticResource CurrentPageBorder}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ContainerCurrentPage}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" / " Opacity="0.7" Margin="4,0"/>
                                    <TextBlock Text="{Binding ContainerTotalPages}" Opacity="0.7"/>
                                </StackPanel>
                            </Border>

                            <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding ContainerNextPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Next}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE893;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding ContainerLastPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_LastPage}" Style="{StaticResource PaginationButton}"/>

                            <ComboBox SelectedItem="{Binding ContainerPageSize, Mode=TwoWay}"
                                      ItemsSource="{Binding ContainerPageSizes}"
                                      Width="80" Margin="12,0,0,0" Style="{StaticResource PaginationComboBox}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_PerPage}" VerticalAlignment="Center" Opacity="0.7" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="3" CornerRadius="0 0 18 18" BorderBrush="{StaticResource DialogFooterBrush}" BorderThickness="0,1,0,0" Padding="16,10">
                    <Button HorizontalAlignment="Right"
                    Style="{StaticResource AppInteractiveButtonNeutral}"
                    Content="{x:Static loc:Strings.Btn_Close}" Width="90" Height="34"
                    Click="CloseButton_Click"/>
                </Border>
            </Grid>
        </Border>
    </Border>
</UserControl>



