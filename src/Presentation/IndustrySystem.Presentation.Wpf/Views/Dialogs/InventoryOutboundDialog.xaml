<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.InventoryOutboundDialog"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
 xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
 xmlns:prism="http://prismlibrary.com/"
 MinWidth="440" MinHeight="320">
    <prism:Dialog.WindowStyle>
        <StaticResource ResourceKey="DialogHostWindowStyle" />
    </prism:Dialog.WindowStyle>
    <UserControl.Resources>
        <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#FFFDFDFE" />
        <SolidColorBrush x:Key="DialogFooterBrush" Color="#FFF8F9FC" />
        <loc:LocalizationProvider x:Key="Loc" />
    </UserControl.Resources>
         <Border Background="Transparent" Padding="24">
        <Border Background="{StaticResource DialogSurfaceBrush}"
                CornerRadius="18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.22" Color="#000000" Direction="270"/>
            </Border.Effect>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" CornerRadius="18 18 0 0" Background="{StaticResource WarningBrush}" Padding="24,18">
            <StackPanel Orientation="Horizontal">
                <Border Width="40" Height="40" CornerRadius="20"
                        Background="#33FFFFFF" Margin="0,0,14,0">
                    <materialDesign:PackIcon Kind="ArrowUpBoldCircleOutline" Width="22" Height="22"
                                             Foreground="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="物料出库" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="选择出库数量" FontSize="12" Foreground="#CCFFFFFF" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Body -->
        <StackPanel Grid.Row="1" Margin="24,20,24,10">
            <materialDesign:Card Padding="18"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 UniformCornerRadius="8">
                <StackPanel>
                    <!-- 物料信息摘要 -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="物料名称" Opacity="0.6" FontSize="13" Width="80"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MaterialName}" FontWeight="SemiBold" FontSize="13"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="批号" Opacity="0.6" FontSize="13"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding BatchNo}" FontSize="13"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="当前库存" Opacity="0.6" FontSize="13"/>
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding CurrentStock, StringFormat={}{0:0.##}}" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="{Binding Unit, StringFormat=' {0}'}" FontSize="13" Opacity="0.7"/>
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,0,0,16"/>

                    <!-- 出库数量输入 -->
                    <TextBox Text="{Binding OutboundQty, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialTextField}"
                             materialDesign:HintAssist.Hint="出库数量"
                             materialDesign:HintAssist.IsFloating="True"
                             FontSize="16"
                             HorizontalContentAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" BorderBrush="{StaticResource DialogFooterBrush}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Content="{Binding [Btn_Cancel], Source={StaticResource Loc}}"
                        Command="{Binding CancelCommand}"
                        Width="100" Height="36" Margin="0,0,10,0"/>
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="确认出库" BorderThickness="0"
                        Command="{Binding SaveCommand}"
                        Background="{StaticResource WarningBrush}"
                        Foreground="White"
                        Width="110" Height="36"/>
            </StackPanel>
        </Border>
    </Grid>
    </Border>
    </Border>
</UserControl>

