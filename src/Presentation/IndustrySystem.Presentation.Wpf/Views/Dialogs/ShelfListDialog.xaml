<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.ShelfListDialog"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
xmlns:sys="clr-namespace:System;assembly=System.Runtime"
xmlns:prism="http://prismlibrary.com/" 
             MinWidth="580" MinHeight="380">
    <prism:Dialog.WindowStyle>
        <StaticResource ResourceKey="DialogHostWindowStyle" />
    </prism:Dialog.WindowStyle>
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <SolidColorBrush x:Key="DialogSurfaceBrush" Color="{DynamicResource DialogSurfaceColor}" />
        <SolidColorBrush x:Key="DialogFooterBrush" Color="{DynamicResource DialogFooterColor}" />
        <Style x:Key="FormField" TargetType="TextBox" BasedOn="{StaticResource DialogTextField}">
            <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </UserControl.Resources>

    <Border Background="Transparent" Padding="24">
        <Border Background="{StaticResource DialogSurfaceBrush}"
             CornerRadius="18">
            <Border.Effect>
                <StaticResource ResourceKey="DialogSurfaceShadow" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border  CornerRadius="18 18 0 0"  Grid.Row="0" Background="{StaticResource DeviceGradientBrush}" Padding="24,16">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="{x:Static loc:Strings.Dialog_ShelfEdit_Title}" FontSize="17" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
							Style="{StaticResource MaterialDesignFlatButton}"
							Command="{Binding AddShelfCommand}" Foreground="White" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{x:Static loc:Strings.Btn_Add}" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding PagedShelves}" Margin="8" Style="{StaticResource ListViewLikeDataGrid}">
                    <DataGrid.Columns>
                            <DataGridTextColumn Width="110" Header="{x:Static loc:Strings.Col_Common_Id}" Binding="{Binding ShelfCode}"/>
                            <DataGridTextColumn Width="130" Header="{x:Static loc:Strings.Col_Common_Name}" Binding="{Binding Name}"/>
                            <DataGridTemplateColumn Width="70" Header="{x:Static loc:Strings.Lbl_GridSize}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="12">
										<Run Text="{Binding Rows, Mode=OneWay}"/>
										<Run Text="×"/>
										<Run Text="{Binding Columns, Mode=OneWay}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Width="120" Header="{x:Static loc:Strings.Col_Common_Description}" Binding="{Binding Description}"/>
                            <DataGridTemplateColumn Width="80" Header="{x:Static loc:Strings.Col_Common_Actions}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Style="{StaticResource DataGridActionIconButton}"
												Command="{Binding DataContext.EditShelfCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Id}" ToolTip="{x:Static loc:Strings.Btn_Edit}">
                                                <materialDesign:PackIcon Kind="Pencil" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                            <Button Style="{StaticResource DataGridActionIconButton}"
												Command="{Binding DataContext.DeleteShelfCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Id}" ToolTip="{x:Static loc:Strings.Btn_Delete}" Foreground="{StaticResource ErrorBrush}">
                                                <materialDesign:PackIcon Kind="Delete" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2" Style="{StaticResource PaginationCard}" Margin="8,0,8,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Style="{StaticResource PaginationStatsPanel}">
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Total}" Opacity="0.7"/>
                            <TextBlock Text="{Binding ShelfTotalCount}" FontWeight="SemiBold" Foreground="{StaticResource HeaderGradient}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Records}" Opacity="0.7"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Style="{StaticResource PaginationButtonPanel}">
                            <Button Content="&#xE892;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding ShelfFirstPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_FirstPage}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding ShelfPreviousPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Prev}" Style="{StaticResource PaginationButton}"/>

                            <Border Style="{StaticResource CurrentPageBorder}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ShelfCurrentPage}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" / " Opacity="0.7" Margin="4,0"/>
                                    <TextBlock Text="{Binding ShelfTotalPages}" Opacity="0.7"/>
                                </StackPanel>
                            </Border>

                            <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding ShelfNextPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Next}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE893;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding ShelfLastPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_LastPage}" Style="{StaticResource PaginationButton}"/>

                            <ComboBox SelectedItem="{Binding ShelfPageSize, Mode=TwoWay}"
                                      ItemsSource="{Binding ShelfPageSizes}"
                                      Width="80" Margin="12,0,0,0" Style="{StaticResource PaginationComboBox}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_PerPage}" VerticalAlignment="Center" Opacity="0.7" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="3" BorderBrush="{StaticResource DialogFooterBrush}" BorderThickness="0,1,0,0" Padding="16,10">
                    <Button HorizontalAlignment="Right"
						Style="{StaticResource AppInteractiveButtonNeutral}"
                        Content="{x:Static loc:Strings.Btn_Close}" Width="90" Height="34"
                        Command="{Binding CancelCommand}"/>
                </Border>
            </Grid>
        </Border>
    </Border>

</UserControl>


