
<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.SlotConfigDialog"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
 xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
 xmlns:prism="http://prismlibrary.com/"
 MinWidth="460" MinHeight="360">
    <prism:Dialog.WindowStyle>
        <StaticResource ResourceKey="DialogHostWindowStyle" />
    </prism:Dialog.WindowStyle>
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#FFFDFDFE" />
        <SolidColorBrush x:Key="DialogFooterBrush" Color="#FFF8F9FC" />
        <Style x:Key="FormField" TargetType="TextBox" BasedOn="{StaticResource MaterialTextField}">
            <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </UserControl.Resources>
   <Border Background="Transparent" Padding="24">
        <Border Background="{StaticResource DialogSurfaceBrush}"
                CornerRadius="18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.22" Color="#000000" Direction="270"/>
            </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border CornerRadius="18 18 0 0" Grid.Row="0" Background="{StaticResource ExperimentGradientBrush}" Padding="24,16">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CogOutline" Width="24" Height="24" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="White">
                    <Run Text="槽位配置 — "/>
                    <Run Text="{Binding PositionLabel, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,20,24,10">
                <TextBlock Text="鍏佽鐨勫鍣ㄧ被鍨嬶紙涓嶉€?涓嶉檺鍒讹級" FontSize="12" Foreground="#666" Margin="0,0,0,6"/>
                <ItemsControl ItemsSource="{Binding AllowedContainerTypeOptions}" Margin="0,0,0,14">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,12,4">
                                <CheckBox.Content>
                                    <TextBlock Text="{Binding ContainerType, Converter={StaticResource EnumDescriptionConverter}}"/>
                                </CheckBox.Content>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ComboBox ItemsSource="{Binding ContainerOptions}"
                      SelectedItem="{Binding SelectedContainer}"
                      DisplayMemberPath="Name"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      materialDesign:HintAssist.Hint="选择容器"
                      materialDesign:HintAssist.IsFloating="True"
                      Margin="0,0,0,14"/>

                <ComboBox ItemsSource="{Binding InventoryOptions}"
                      SelectedItem="{Binding SelectedInventory}"
                      DisplayMemberPath="MaterialName"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      materialDesign:HintAssist.Hint="绑定库存记录"
                      materialDesign:HintAssist.IsFloating="True"
                      Margin="0,0,0,14"/>

                <CheckBox IsChecked="{Binding IsDisabled}" Content="禁用此槽位" Margin="0,0,0,14"/>

                <TextBox Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialTextField}"
                     materialDesign:HintAssist.Hint="备注"
                     materialDesign:HintAssist.IsFloating="True"/>
            </StackPanel>

            <Border Grid.Row="2" BorderBrush="{StaticResource DialogFooterBrush}" BorderThickness="0,1,0,0" Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="{Binding [Btn_Cancel], Source={StaticResource Loc}}" Command="{Binding CancelCommand}" Width="100" Height="36" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Content="{Binding [Btn_Save], Source={StaticResource Loc}}" Command="{Binding SaveCommand}" Width="100" Height="36"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
    </Border>
</UserControl>

