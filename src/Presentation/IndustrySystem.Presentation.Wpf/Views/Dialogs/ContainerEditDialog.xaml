 
<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.ContainerEditDialog"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
 xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
 xmlns:prism="http://prismlibrary.com/"
 MinWidth="480" MinHeight="380">
    <prism:Dialog.WindowStyle>
        <StaticResource ResourceKey="DialogHostWindowStyle" />
    </prism:Dialog.WindowStyle>
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
		<SolidColorBrush x:Key="DialogSurfaceBrush" Color="#FFFDFDFE" />
		<SolidColorBrush x:Key="DialogFooterBrush" Color="#FFF8F9FC" />
    </UserControl.Resources>     
    <Border Background="Transparent" Padding="24">
        <Border Background="{StaticResource DialogSurfaceBrush}"
                CornerRadius="18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.22" Color="#000000" Direction="270"/>
            </Border.Effect>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border CornerRadius="18 18 0 0" Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="24,16">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="PackageVariant" Width="24" Height="24" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" Foreground="White"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="24,20,24,10">
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialTextField}"
                     materialDesign:HintAssist.Hint="容器名称 *"
                     materialDesign:HintAssist.IsFloating="True"
                     Margin="0,0,0,14"/>

            <ComboBox ItemsSource="{Binding ContainerTypeOptions}"
                      SelectedItem="{Binding ContainerType}"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      materialDesign:HintAssist.Hint="容器类型"
                      materialDesign:HintAssist.IsFloating="True"
                      Margin="0,0,0,14">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Rows, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialTextField}"
                         materialDesign:HintAssist.Hint="行数"
                         materialDesign:HintAssist.IsFloating="True"
                         Margin="0,0,0,14"/>
                <TextBox Grid.Column="2"
                         Text="{Binding Columns, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialTextField}"
                         materialDesign:HintAssist.Hint="列数"
                         materialDesign:HintAssist.IsFloating="True"
                         Margin="0,0,0,14"/>
            </Grid>

            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialTextField}"
                     materialDesign:HintAssist.Hint="描述"
                     materialDesign:HintAssist.IsFloating="True"/>
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="{StaticResource DialogFooterBrush}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="{Binding [Btn_Cancel], Source={StaticResource Loc}}" Command="{Binding CancelCommand}" Width="100" Height="36" Margin="0,0,10,0"/>
                <Button Style="{StaticResource MaterialDesignRaisedButton}" Content="{Binding [Btn_Save], Source={StaticResource Loc}}" Command="{Binding SaveCommand}" Width="100" Height="36"/>
            </StackPanel>
        </Border>
    </Grid>
    </Border>
    </Border>
</UserControl>

