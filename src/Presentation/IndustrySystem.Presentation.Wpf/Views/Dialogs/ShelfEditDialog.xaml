<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.ShelfEditDialog"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
 xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
 xmlns:sys="clr-namespace:System;assembly=System.Runtime"
 xmlns:prism="http://prismlibrary.com/"
 MinWidth="780" MinHeight="500">
    <prism:Dialog.WindowStyle>
        <StaticResource ResourceKey="DialogHostWindowStyle" />
    </prism:Dialog.WindowStyle>
	<UserControl.Resources>
		<loc:LocalizationProvider x:Key="Loc" />
		<SolidColorBrush x:Key="DialogSurfaceBrush" Color="#FFFDFDFE" />
		<SolidColorBrush x:Key="DialogFooterBrush" Color="#FFF8F9FC" />
		<Style x:Key="FormField" TargetType="TextBox" BasedOn="{StaticResource MaterialTextField}">
			<Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
			<Setter Property="Margin" Value="0,0,0,14"/>
			<Setter Property="FontSize" Value="13"/>
		</Style>
	</UserControl.Resources>
	<Border Background="{StaticResource DialogSurfaceBrush}"
                CornerRadius="18">
		<Border.Effect>
			<DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.22" Color="#000000" Direction="270"/>
		</Border.Effect>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<Border Grid.Row="0"  CornerRadius="18 18 0 0"  Background="{StaticResource DeviceGradientBrush}" Padding="24,16">
				<StackPanel Orientation="Horizontal">
					<materialDesign:PackIcon Kind="ViewGrid" Width="24" Height="24" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
					<TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" Foreground="White"/>
				</StackPanel>
			</Border>

			<Grid Grid.Row="1" Margin="24,16,24,10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="280"/>
					<ColumnDefinition Width="20"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<!-- Left: form fields -->
				<StackPanel Grid.Column="0">
					<TextBox Text="{Binding ShelfCode, UpdateSourceTrigger=PropertyChanged}"
							 Style="{StaticResource MaterialTextField}"
							 materialDesign:HintAssist.Hint="{Binding [Dialog_ShelfEdit_Hint_ShelfCode], Source={StaticResource Loc}}"
							 materialDesign:HintAssist.IsFloating="True"
							 Margin="0,0,0,12"/>
					<TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
							 Style="{StaticResource MaterialTextField}"
							 materialDesign:HintAssist.Hint="{Binding [Dialog_ShelfEdit_Hint_ShelfName], Source={StaticResource Loc}}"
							 materialDesign:HintAssist.IsFloating="True"
							 Margin="0,0,0,12"/>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<TextBox Grid.Column="0"
								 Text="{Binding Rows, UpdateSourceTrigger=PropertyChanged}"
								 Style="{StaticResource MaterialTextField}"
								 materialDesign:HintAssist.Hint="{Binding [Dialog_ShelfEdit_Hint_Rows], Source={StaticResource Loc}}"
								 materialDesign:HintAssist.IsFloating="True"
								 Margin="0,0,0,12"/>
						<TextBox Grid.Column="2"
								 Text="{Binding Columns, UpdateSourceTrigger=PropertyChanged}"
								 Style="{StaticResource MaterialTextField}"
								 materialDesign:HintAssist.Hint="{Binding [Dialog_ShelfEdit_Hint_Columns], Source={StaticResource Loc}}"
								 materialDesign:HintAssist.IsFloating="True"
								 Margin="0,0,0,12"/>
					</Grid>
					<TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
							 Style="{StaticResource MaterialTextField}"
							 materialDesign:HintAssist.Hint="{Binding [Dialog_ShelfEdit_Hint_Description], Source={StaticResource Loc}}"
							 materialDesign:HintAssist.IsFloating="True"
							 Margin="0,0,0,8"/>

					<TextBlock Text="{Binding [Dialog_ShelfEdit_Tip], Source={StaticResource Loc}}"
							   FontSize="11" Foreground="#888" TextWrapping="Wrap" Margin="0,8,0,0"/>
				</StackPanel>

				<!-- Separator -->
				<Border Grid.Column="1" Width="1" Background="#14000000" VerticalAlignment="Stretch" Margin="8,0"/>

				<!-- Right: dynamic slot grid preview -->
				<Grid Grid.Column="2">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<TextBlock Grid.Row="0" Text="{Binding [Dialog_ShelfEdit_SlotLayoutPreview], Source={StaticResource Loc}}" FontSize="13" FontWeight="Medium" Foreground="#555" Margin="0,0,0,10"/>

					<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
						<ItemsControl ItemsSource="{Binding SlotEditItems}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<UniformGrid Rows="{Binding DataContext.Rows, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
												 Columns="{Binding DataContext.Columns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border x:Name="SlotBorder"
											BorderBrush="#30000000" BorderThickness="1"
											CornerRadius="4" Margin="2" Padding="4"
											MinWidth="52" MinHeight="48"
											Background="#F0F7F0" Cursor="Hand">
										<Border.InputBindings>
											<MouseBinding MouseAction="LeftClick"
														  Command="{Binding DataContext.ToggleSlotEnabledCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
														  CommandParameter="{Binding}"/>
										</Border.InputBindings>
										<Border.ContextMenu>
											<ContextMenu Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
												<MenuItem Header="{Binding [Dialog_ShelfEdit_ClearAllRestrictions], Source={StaticResource Loc}}"
														  Command="{Binding PlacementTarget.DataContext.DataContext.ClearContainerTypesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
														  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
												<Separator/>
												<MenuItem Header="{Binding [Dialog_ShelfEdit_AllowedContainerTypes], Source={StaticResource Loc}}" IsEnabled="False" FontStyle="Italic"/>
												<ItemsControl ItemsSource="{Binding PlacementTarget.DataContext.AllowedContainerTypeOptions, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
													<ItemsControl.ItemTemplate>
														<DataTemplate>
															<CheckBox IsChecked="{Binding IsSelected}" Margin="8,3">
																<CheckBox.Content>
																	<TextBlock Text="{Binding ContainerType, Converter={StaticResource EnumDescriptionConverter}}"/>
																</CheckBox.Content>
															</CheckBox>
														</DataTemplate>
													</ItemsControl.ItemTemplate>
												</ItemsControl>
											</ContextMenu>
										</Border.ContextMenu>
										<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
											<TextBlock Text="{Binding PositionLabel}" FontSize="10" FontWeight="SemiBold"
													   HorizontalAlignment="Center" Foreground="#555"/>
											<TextBlock x:Name="TypeLabel" FontSize="9" HorizontalAlignment="Center"
													   Foreground="#888" Margin="0,1,0,0"
													   Text="{Binding AllowedTypesLabel}"/>
										</StackPanel>
									</Border>
									<DataTemplate.Triggers>
										<DataTrigger Binding="{Binding IsDisabled}" Value="True">
											<Setter TargetName="SlotBorder" Property="Background" Value="#F0F0F0"/>
											<Setter TargetName="SlotBorder" Property="BorderBrush" Value="#50FF0000"/>
											<Setter TargetName="SlotBorder" Property="Opacity" Value="0.6"/>
										</DataTrigger>
									</DataTemplate.Triggers>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</Grid>
			</Grid>

			<Border Grid.Row="2" BorderBrush="{StaticResource DialogFooterBrush}" BorderThickness="0,1,0,0" Padding="24,14">
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
					<Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="{Binding [Btn_Cancel], Source={StaticResource Loc}}" Command="{Binding CancelCommand}" Width="100" Height="36" Margin="0,0,10,0"/>
					<Button Style="{StaticResource MaterialDesignRaisedButton}" Content="{Binding [Btn_Save], Source={StaticResource Loc}}" Command="{Binding SaveCommand}" Width="100" Height="36"/>
				</StackPanel>
			</Border>
		</Grid>
	</Border>
</UserControl>

