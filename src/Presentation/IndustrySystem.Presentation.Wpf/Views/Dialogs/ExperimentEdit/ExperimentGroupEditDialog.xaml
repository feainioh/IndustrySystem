<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.ExperimentGroupEditDialog"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
 xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
 xmlns:prism="http://prismlibrary.com/"
 MinWidth="760" MinHeight="560">
    <prism:Dialog.WindowStyle>
        <StaticResource ResourceKey="DialogHostWindowStyle" />
    </prism:Dialog.WindowStyle>
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#FFFDFDFE" />
        <SolidColorBrush x:Key="DialogFooterBrush" Color="#FFF8F9FC" />

        <Style x:Key="FormField" TargetType="TextBox" BasedOn="{StaticResource MaterialTextField}">
            <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>
    <Border Background="{StaticResource DialogSurfaceBrush}"
            CornerRadius="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.22" Color="#000000" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border CornerRadius="18 18 0 0" Grid.Row="0" Background="{StaticResource ExperimentGradientBrush}" Padding="20,14">
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="18" Background="#33FFFFFF" Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="FormatListChecks" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding [Dialog_ExperimentGroupEdit_Title], Source={StaticResource Loc}}" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="{Binding [Dialog_ExperimentGroupEdit_Subtitle], Source={StaticResource Loc}}" FontSize="12" Foreground="#CCFFFFFF" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,16,20,8">
                    <materialDesign:Card Padding="16" UniformCornerRadius="8" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" Grid.Column="0" Style="{StaticResource FormField}"
               Text="{Binding GroupCode, UpdateSourceTrigger=PropertyChanged}"
               materialDesign:HintAssist.Hint="{Binding [Hint_ExperimentGroupCode], Source={StaticResource Loc}}"/>
                            <TextBox Grid.Row="0" Grid.Column="2" Style="{StaticResource FormField}"
               Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
               materialDesign:HintAssist.Hint="{Binding [Hint_ExperimentGroupName], Source={StaticResource Loc}}"/>

                            <TextBox Grid.Row="1" Grid.Column="0" Style="{StaticResource FormField}"
               Text="{Binding CreatedBy, UpdateSourceTrigger=PropertyChanged}"
               materialDesign:HintAssist.Hint="{Binding [Hint_CreatedBy], Source={StaticResource Loc}}"/>

                            <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                                <TextBlock Text="{Binding [Label_EnabledStatus], Source={StaticResource Loc}}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ToggleButton IsChecked="{Binding IsEnabled}" Style="{StaticResource MaterialDesignSwitchToggleButton}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding IsEnabled, StringFormat=启用:{0}}" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.7"/>
                            </StackPanel>

                            <TextBox Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource FormField}"
               Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
               materialDesign:HintAssist.Hint="{Binding [Col_Description], Source={StaticResource Loc}}"/>

                            <TextBlock Grid.Row="3" Grid.ColumnSpan="3" Text="{Binding StepSummary}" FontSize="12" Opacity="0.7"/>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="16" UniformCornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="{Binding [Label_ExperimentSteps], Source={StaticResource Loc}}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="6" Padding="8" MaxHeight="260">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ExperimentOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,4,0,4">
                                                    <TextBlock Text="{Binding Name}"/>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" CornerRadius="0 0 18 18 " BorderBrush="{StaticResource DialogFooterBrush}" BorderThickness="0,1,0,0" Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
            Content="{Binding [Btn_Cancel], Source={StaticResource Loc}}"
            Command="{Binding CancelCommand}"
            Width="96" Height="34" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
            Content="{Binding [Btn_Save], Source={StaticResource Loc}}"
            Command="{Binding SaveCommand}"
            Width="96" Height="34"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>

