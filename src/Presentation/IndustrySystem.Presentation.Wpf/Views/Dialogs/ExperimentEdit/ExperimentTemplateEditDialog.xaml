<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.ExperimentTemplateEditDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             MinWidth="480" MaxWidth="560">
    <prism:Dialog.WindowStyle>
        <StaticResource ResourceKey="DialogHostWindowStyle" />
    </prism:Dialog.WindowStyle>
    <UserControl.Resources>
        <SolidColorBrush x:Key="DialogSurfaceBrush" Color="{DynamicResource DialogSurfaceColor}" />
        <SolidColorBrush x:Key="DialogFooterBrush" Color="{DynamicResource DialogFooterColor}" />

    </UserControl.Resources>
    <Border Background="{StaticResource DialogSurfaceBrush}"
            CornerRadius="18">
        <Border.Effect>
            <StaticResource ResourceKey="DialogSurfaceShadow" />
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="20" FontWeight="SemiBold"/>

            <StackPanel Grid.Row="2">
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="{Binding [Hint_Template_Name], Source={StaticResource Loc}}"
                     materialDesign:HintAssist.IsFloating="True"
                     Margin="0,0,0,12"/>

                <ComboBox ItemsSource="{Binding ExperimentTypes}"
                      SelectedItem="{Binding SelectedType}"
                      Style="{StaticResource DialogComboBox}"
                      materialDesign:HintAssist.Hint="{Binding [Field_ExperimentType], Source={StaticResource Loc}}"
                      materialDesign:HintAssist.IsFloating="True"
                      Margin="0,0,0,12">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="{Binding [Hint_OptionalDescription], Source={StaticResource Loc}}"
                     materialDesign:HintAssist.IsFloating="True"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     MinHeight="60" MaxHeight="120"/>
            </StackPanel>

            <StackPanel  Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource AppInteractiveButtonNeutral}"
                    Content="{Binding [Btn_Cancel], Source={StaticResource Loc}}" Margin="0,0,12,0" Height="36" Width="90"
                    Command="{Binding CancelCommand}"/>
                <Button Style="{StaticResource AppInteractiveButtonPrimary}"
                    Content="{Binding [Btn_Save], Source={StaticResource Loc}}" Height="36" Width="90"
                    Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>




