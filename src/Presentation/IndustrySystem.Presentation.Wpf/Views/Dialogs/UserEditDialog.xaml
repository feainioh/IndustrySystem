<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.Dialogs.UserEditDialog"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
 xmlns:prism="http://prismlibrary.com/"
 xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
 prism:ViewModelLocator.AutoWireViewModel="False"
 MinWidth="620" MinHeight="520">
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <Style x:Key="FormField" TargetType="TextBox" BasedOn="{StaticResource MaterialTextField}">
            <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource UserGradientBrush}" Padding="24,18">
            <StackPanel Orientation="Horizontal">
                <Border Width="40" Height="40" CornerRadius="20"
                        Background="#33FFFFFF" Margin="0,0,14,0">
                    <materialDesign:PackIcon Kind="AccountEditOutline" Width="22" Height="22"
                                             Foreground="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Dialog_UserEdit_Title], Source={StaticResource Loc}}"
                               FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="编辑用户基本信息与角色分配"
                               FontSize="12" Foreground="#CCFFFFFF" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Scrollable Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,10">

                <!-- Section 1: 基本信息 -->
                <materialDesign:Card Padding="18" Margin="0,0,0,14"
                                     materialDesign:ElevationAssist.Elevation="Dp1"
                                     UniformCornerRadius="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20"
                                                     Foreground="{StaticResource PrimaryBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="基本信息" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" Grid.Column="0" Style="{StaticResource FormField}"
                                     Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="{Binding [Field_User_UserName], Source={StaticResource Loc}}"/>
                            <TextBox Grid.Row="0" Grid.Column="2" Style="{StaticResource FormField}"
                                     Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="{Binding [Field_User_DisplayName], Source={StaticResource Loc}}"/>

                            <CheckBox Grid.Row="1" Grid.Column="0"
                                      IsChecked="{Binding IsActive}"
                                      Content="{Binding [Field_Common_Active], Source={StaticResource Loc}}"
                                      FontSize="13" Margin="0,0,0,6"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Section 2: 角色分配 -->
                <materialDesign:Card Padding="18" Margin="0,0,0,6"
                                     materialDesign:ElevationAssist.Elevation="Dp1"
                                     UniformCornerRadius="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <materialDesign:PackIcon Kind="ShieldAccountOutline" Width="20" Height="20"
                                                     Foreground="#10893E"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding [Nav_Roles], Source={StaticResource Loc}}"
                                       FontSize="15" FontWeight="SemiBold" Foreground="#10893E"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding AllRoles}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                              Margin="0,4,20,4" FontSize="13"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" BorderBrush="#14000000" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Content="{Binding [Btn_Cancel], Source={StaticResource Loc}}"
                        Command="{Binding CancelCommand}"
                        Width="100" Height="36" Margin="0,0,10,0"/>
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="{Binding [Btn_Save], Source={StaticResource Loc}}"
                        Command="{Binding SaveCommand}"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        Width="100" Height="36"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
