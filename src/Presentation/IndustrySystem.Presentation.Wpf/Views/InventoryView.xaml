<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <Style x:Key="SearchTextField" TargetType="TextBox" BasedOn="{StaticResource ManagementSearchTextBox}"/>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{StaticResource PageHeaderIconBorder}" Background="{StaticResource ExperimentGradientBrush}">
                    <materialDesign:PackIcon Kind="Warehouse" Style="{StaticResource PageHeaderPackIcon}"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.Nav_Inventory}" Style="{StaticResource PageHeaderTitle}"/>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Page_Inventory_Subtitle]}" Style="{StaticResource PageHeaderSubtitle}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsPanel}">
                <Button Style="{StaticResource HeaderActionOutlinedButton}"
                        Command="{Binding RefreshCommand}"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Btn_Refresh}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource HeaderActionAccentButton}"
                        Command="{Binding InboundCommand}"
                        Background="{StaticResource SuccessBrush}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowDownBoldCircleOutline" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Btn_Inbound]}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Inventory List Card -->
        <Border Grid.Row="2" Style="{StaticResource FormCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Section header + search + toggle -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Loc}, Path=[Section_InventoryList]}" FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <ToggleButton Grid.Column="1" IsChecked="{Binding ShowSummary}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  ToolTip="{Binding Source={StaticResource Loc}, Path=[Tooltip_ToggleSummaryView]}" Margin="16,0,6,0"
                                  VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding Source={StaticResource Loc}, Path=[Label_SummaryView]}" FontSize="12" Opacity="0.6"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Column="3"
                             Width="280"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextField}"
                             materialDesign:HintAssist.Hint="{Binding Source={StaticResource Loc}, Path=[Hint_Search_Inventory]}"
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="Magnify"/>
                </Grid>

                <!-- Detail DataGrid (ShowSummary=False) -->
                <DataGrid Grid.Row="2" ItemsSource="{Binding PagedItems}">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource ListViewLikeDataGrid}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowSummary}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>

                            <!-- 物料 -->
                            <DataGridTemplateColumn Width="200" Header="{Binding Source={StaticResource Loc}, Path=[Col_Material]}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <Border Style="{StaticResource DataGridLeadingIconBadge}" Background="{StaticResource ExperimentGradientBrush}">
                                                <materialDesign:PackIcon Kind="PackageVariant" Style="{StaticResource DataGridLeadingPackIcon}" Foreground="White"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding MaterialName}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding MaterialCode}" FontSize="11" Opacity="0.65"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 批号 -->
                            <DataGridTextColumn Width="140" Header="{Binding Source={StaticResource Loc}, Path=[Col_BatchNo]}" Binding="{Binding BatchNo}"/>

                            <!-- 库存 / 安全库存 -->
                            <DataGridTemplateColumn Width="130" Header="{Binding Source={StaticResource Loc}, Path=[Col_Inventory_SafetyStock]}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="13" FontWeight="SemiBold">
                                                <TextBlock.Text>
                                                    <Binding Path="Quantity" StringFormat="{}{0:0.##}"/>
                                                </TextBlock.Text>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Value="True">
                                                                <DataTrigger.Binding>
                                                                    <MultiBinding Converter="{StaticResource LessThanConverter}">
                                                                        <Binding Path="Quantity"/>
                                                                        <Binding Path="SafetyStock"/>
                                                                    </MultiBinding>
                                                                </DataTrigger.Binding>
                                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text=" / " FontSize="12" Opacity="0.5"/>
                                            <TextBlock Text="{Binding SafetyStock, StringFormat={}{0:0.##}}" FontSize="12" Opacity="0.6"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 单位 -->
                            <DataGridTextColumn Width="70" Header="{Binding Source={StaticResource Loc}, Path=[Col_Unit]}" Binding="{Binding Unit}"/>

                            <!-- 入库日期 -->
                            <DataGridTextColumn Width="110" Header="{Binding Source={StaticResource Loc}, Path=[Col_LastInboundDate]}" Binding="{Binding InboundDate, StringFormat=yyyy-MM-dd}"/>

                            <!-- 过期日期 -->
                            <DataGridTextColumn Width="110" Header="{Binding Source={StaticResource Loc}, Path=[Col_ExpiryDate]}" Binding="{Binding ExpiryDate, StringFormat=yyyy-MM-dd}"/>

                            <!-- 位置 -->
                            <DataGridTextColumn Width="100" Header="{Binding Source={StaticResource Loc}, Path=[Col_Location]}" Binding="{Binding Location}"/>

                            <!-- 孔位 -->
                            <DataGridTemplateColumn Width="80" Header="{Binding Source={StaticResource Loc}, Path=[Slot]}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="12" Opacity="0.75">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource WellPosition}">
                                                    <Binding Path="WellRow"/>
                                                    <Binding Path="WellColumn"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 操作 -->
                            <DataGridTemplateColumn Width="160" Header="{x:Static loc:Strings.Col_Actions}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                            <!-- 出库 -->
                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                    Command="{Binding DataContext.OutboundCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="{Binding Source={StaticResource Loc}, Path=[Btn_Outbound]}"
                                                    Foreground="{StaticResource WarningBrush}">
                                                <materialDesign:PackIcon Kind="ArrowUpBoldCircleOutline" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                            <!-- 编辑 -->
                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="{x:Static loc:Strings.Btn_Edit}">
                                                <materialDesign:PackIcon Kind="Pencil" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                            <!-- 删除 -->
                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="{x:Static loc:Strings.Btn_Delete}"
                                                    Foreground="{StaticResource ErrorBrush}">
                                                <materialDesign:PackIcon Kind="Delete" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Summary DataGrid (ShowSummary=True) -->
                <DataGrid Grid.Row="2" ItemsSource="{Binding PagedSummaryItems}">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource ListViewLikeDataGrid}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowSummary}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>

                            <!-- 物料 -->
                            <DataGridTemplateColumn Width="200" Header="{Binding Source={StaticResource Loc}, Path=[Col_Material]}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <Border Width="30" Height="30" CornerRadius="15"
                                                    Background="{StaticResource MaterialGradientBrush}" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="ChartBox" Width="16" Height="16"
                                                                         Foreground="White"
                                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding MaterialName}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding MaterialCode}" FontSize="11" Opacity="0.65"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 批号 -->
                            <DataGridTextColumn Width="140" Header="{Binding Source={StaticResource Loc}, Path=[Col_BatchNo]}" Binding="{Binding BatchNo}"/>

                            <!-- 总库存 / 安全库存 -->
                            <DataGridTemplateColumn Width="150">
                                <DataGridTemplateColumn.Header>
                                    <MultiBinding StringFormat="{}{0} / {1}">
                                        <Binding Source="{StaticResource Loc}" Path="[Col_TotalQuantity]"/>
                                        <Binding Source="{StaticResource Loc}" Path="[Hint_SafetyStock]"/>
                                    </MultiBinding>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="14" FontWeight="Bold">
                                                <TextBlock.Text>
                                                    <Binding Path="TotalQuantity" StringFormat="{}{0:0.##}"/>
                                                </TextBlock.Text>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Value="True">
                                                                <DataTrigger.Binding>
                                                                    <MultiBinding Converter="{StaticResource LessThanConverter}">
                                                                        <Binding Path="TotalQuantity"/>
                                                                        <Binding Path="SafetyStock"/>
                                                                    </MultiBinding>
                                                                </DataTrigger.Binding>
                                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text=" / " FontSize="12" Opacity="0.5"/>
                                            <TextBlock Text="{Binding SafetyStock, StringFormat={}{0:0.##}}" FontSize="12" Opacity="0.6"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- 单位 -->
                            <DataGridTextColumn Width="70" Header="{Binding Source={StaticResource Loc}, Path=[Col_Unit]}" Binding="{Binding Unit}"/>

                            <!-- 记录数 -->
                            <DataGridTemplateColumn Width="90" Header="{Binding Source={StaticResource Loc}, Path=[Col_BatchCount]}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource PrimaryBrush}" CornerRadius="10"
                                                Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding RecordCount}" Foreground="White"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pagination -->
                <Border Grid.Row="4" Style="{StaticResource PaginationCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Style="{StaticResource PaginationStatsPanel}">
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Total}" Opacity="0.7"/>
                            <TextBlock Text="{Binding TotalCount}" FontWeight="SemiBold" Foreground="{StaticResource HeaderGradient}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Records}" Opacity="0.7"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Style="{StaticResource PaginationButtonPanel}">
                            <Button Content="&#xE892;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding FirstPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_FirstPage}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding PreviousPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Prev}" Style="{StaticResource PaginationButton}"/>

                            <Border Style="{StaticResource CurrentPageBorder}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CurrentPage}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" / " Opacity="0.7" Margin="4,0"/>
                                    <TextBlock Text="{Binding TotalPages}" Opacity="0.7"/>
                                </StackPanel>
                            </Border>

                            <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding NextPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Next}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE893;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding LastPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_LastPage}" Style="{StaticResource PaginationButton}"/>

                            <ComboBox SelectedItem="{Binding PageSize, Mode=TwoWay}"
                                      ItemsSource="{Binding PageSizes}"
                                      Width="80" Margin="12,0,0,0" Style="{StaticResource PaginationComboBox}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_PerPage}" VerticalAlignment="Center" Opacity="0.7" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
