<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="False"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <Style x:Key="SearchTextField" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignFilledTextBox}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="10,2,10,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CaretBrush" Value="Black"/>
        </Style>
        <Style x:Key="OperationLikeListView" TargetType="ListView" BasedOn="{StaticResource ModernListView}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ManageListItem}"/>
        </Style>
        <Style x:Key="OperationLikeListViewItem" TargetType="ListViewItem" BasedOn="{StaticResource ManageListItem}">
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource SystemControlAltMediumLowBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="40" Height="40" CornerRadius="8"
                        Background="{StaticResource ExperimentGradientBrush}"
                        VerticalAlignment="Center" Margin="0,0,16,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#8764B8" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                    </Border.Effect>
                    <materialDesign:PackIcon Kind="Warehouse"
                                             Width="20" Height="20"
                                             Foreground="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.Nav_Inventory}" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Page_Inventory_Subtitle]}" FontSize="12" Opacity="0.7" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding RefreshCommand}"
                        Height="36" Padding="12,0"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Btn_Refresh}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                        Command="{Binding InboundCommand}"
                        Height="36" Padding="12,0"
                        Background="{StaticResource SuccessBrush}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowDownBoldCircleOutline" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Btn_Inbound]}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Inventory List Card -->
        <Border Grid.Row="2"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="16"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Section header + search + toggle -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Loc}, Path=[Section_InventoryList]}" FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <ToggleButton Grid.Column="1" IsChecked="{Binding ShowSummary}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  ToolTip="{Binding Source={StaticResource Loc}, Path=[Tooltip_ToggleSummaryView]}" Margin="16,0,6,0"
                                  VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding Source={StaticResource Loc}, Path=[Label_SummaryView]}" FontSize="12" Opacity="0.6"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Column="3"
                             Width="280"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextField}"
                             materialDesign:HintAssist.Hint="{Binding Source={StaticResource Loc}, Path=[Hint_Search_Inventory]}"
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="Magnify"/>
                </Grid>

                <!-- Detail ListView (ShowSummary=False) -->
                <ListView Grid.Row="2" ItemsSource="{Binding InventoryView}">
                    <ListView.Style>
                        <Style TargetType="ListView" BasedOn="{StaticResource OperationLikeListView}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowSummary}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.Style>
                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ManageListColumnHeader}"/>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource OperationLikeListViewItem}"/>
                    </ListView.Resources>
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">

                            <!-- 物料 -->
                            <GridViewColumn Width="200" Header="{Binding Source={StaticResource Loc}, Path=[Col_Material]}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <Border Width="30" Height="30" CornerRadius="15"
                                                    Background="{StaticResource ExperimentGradientBrush}" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="PackageVariant" Width="16" Height="16"
                                                                         Foreground="White"
                                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding MaterialName}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding MaterialCode}" FontSize="11" Opacity="0.65"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- 批号 -->
                            <GridViewColumn Width="140" Header="{Binding Source={StaticResource Loc}, Path=[Col_BatchNo]}" DisplayMemberBinding="{Binding BatchNo}"/>

                            <!-- 库存 / 安全库存 -->
                            <GridViewColumn Width="130" Header="{Binding Source={StaticResource Loc}, Path=[Col_Inventory_SafetyStock]}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="13" FontWeight="SemiBold">
                                                <TextBlock.Text>
                                                    <Binding Path="Quantity" StringFormat="{}{0:0.##}"/>
                                                </TextBlock.Text>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Value="True">
                                                                <DataTrigger.Binding>
                                                                    <MultiBinding Converter="{StaticResource LessThanConverter}">
                                                                        <Binding Path="Quantity"/>
                                                                        <Binding Path="SafetyStock"/>
                                                                    </MultiBinding>
                                                                </DataTrigger.Binding>
                                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text=" / " FontSize="12" Opacity="0.5"/>
                                            <TextBlock Text="{Binding SafetyStock, StringFormat={}{0:0.##}}" FontSize="12" Opacity="0.6"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- 单位 -->
                            <GridViewColumn Width="70" Header="{Binding Source={StaticResource Loc}, Path=[Col_Unit]}" DisplayMemberBinding="{Binding Unit}"/>

                            <!-- 入库日期 -->
                            <GridViewColumn Width="110" Header="{Binding Source={StaticResource Loc}, Path=[Col_LastInboundDate]}" DisplayMemberBinding="{Binding InboundDate, StringFormat=yyyy-MM-dd}"/>

                            <!-- 过期日期 -->
                            <GridViewColumn Width="110" Header="{Binding Source={StaticResource Loc}, Path=[Col_ExpiryDate]}" DisplayMemberBinding="{Binding ExpiryDate, StringFormat=yyyy-MM-dd}"/>

                            <!-- 位置 -->
                            <GridViewColumn Width="100" Header="{Binding Source={StaticResource Loc}, Path=[Col_Location]}" DisplayMemberBinding="{Binding Location}"/>

                            <!-- 孔位 -->
                            <GridViewColumn Width="80" Header="{Binding Source={StaticResource Loc}, Path=[Slot]}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="12" Opacity="0.75">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource WellPosition}">
                                                    <Binding Path="WellRow"/>
                                                    <Binding Path="WellColumn"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- 操作 -->
                            <GridViewColumn Width="160" Header="{x:Static loc:Strings.Col_Actions}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <!-- 出库 -->
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Command="{Binding DataContext.OutboundCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="{Binding Source={StaticResource Loc}, Path=[Btn_Outbound]}"
                                                    Width="32" Height="32" Margin="0,0,2,0"
                                                    Foreground="{StaticResource WarningBrush}">
                                                <materialDesign:PackIcon Kind="ArrowUpBoldCircleOutline" Width="18" Height="18"/>
                                            </Button>
                                            <!-- 编辑 -->
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="{x:Static loc:Strings.Btn_Edit}"
                                                    Width="32" Height="32" Margin="0,0,2,0">
                                                <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                            </Button>
                                            <!-- 删除 -->
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="{x:Static loc:Strings.Btn_Delete}"
                                                    Width="32" Height="32"
                                                    Foreground="{StaticResource ErrorBrush}">
                                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Summary ListView (ShowSummary=True) -->
                <ListView Grid.Row="2" ItemsSource="{Binding SummaryView}">
                    <ListView.Style>
                        <Style TargetType="ListView" BasedOn="{StaticResource OperationLikeListView}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowSummary}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.Style>
                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ManageListColumnHeader}"/>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource OperationLikeListViewItem}"/>
                    </ListView.Resources>
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">

                            <!-- 物料 -->
                            <GridViewColumn Width="200" Header="{Binding Source={StaticResource Loc}, Path=[Col_Material]}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <Border Width="30" Height="30" CornerRadius="15"
                                                    Background="{StaticResource MaterialGradientBrush}" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="ChartBox" Width="16" Height="16"
                                                                         Foreground="White"
                                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding MaterialName}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding MaterialCode}" FontSize="11" Opacity="0.65"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- 批号 -->
                            <GridViewColumn Width="140" Header="{Binding Source={StaticResource Loc}, Path=[Col_BatchNo]}" DisplayMemberBinding="{Binding BatchNo}"/>

                            <!-- 总库存 / 安全库存 -->
                            <GridViewColumn Width="150">
                                <GridViewColumn.Header>
                                    <MultiBinding StringFormat="{}{0} / {1}">
                                        <Binding Source="{StaticResource Loc}" Path="[Col_TotalQuantity]"/>
                                        <Binding Source="{StaticResource Loc}" Path="[Hint_SafetyStock]"/>
                                    </MultiBinding>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="14" FontWeight="Bold">
                                                <TextBlock.Text>
                                                    <Binding Path="TotalQuantity" StringFormat="{}{0:0.##}"/>
                                                </TextBlock.Text>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Value="True">
                                                                <DataTrigger.Binding>
                                                                    <MultiBinding Converter="{StaticResource LessThanConverter}">
                                                                        <Binding Path="TotalQuantity"/>
                                                                        <Binding Path="SafetyStock"/>
                                                                    </MultiBinding>
                                                                </DataTrigger.Binding>
                                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text=" / " FontSize="12" Opacity="0.5"/>
                                            <TextBlock Text="{Binding SafetyStock, StringFormat={}{0:0.##}}" FontSize="12" Opacity="0.6"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- 单位 -->
                            <GridViewColumn Width="70" Header="{Binding Source={StaticResource Loc}, Path=[Col_Unit]}" DisplayMemberBinding="{Binding Unit}"/>

                            <!-- 记录数 -->
                            <GridViewColumn Width="90" Header="{Binding Source={StaticResource Loc}, Path=[Col_BatchCount]}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource PrimaryBrush}" CornerRadius="10"
                                                Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding RecordCount}" Foreground="White"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</UserControl>
