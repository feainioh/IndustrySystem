<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="False"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
    
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <Style x:Key="SearchTextField" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignFilledTextBox}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="10,2,10,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CaretBrush" Value="Black"/>
        </Style>
        <Style x:Key="OperationLikeListView" TargetType="ListView" BasedOn="{StaticResource ModernListView}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ManageListItem}"/>
        </Style>
        <Style x:Key="OperationLikeListViewItem" TargetType="ListViewItem" BasedOn="{StaticResource ManageListItem}">
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource SystemControlAltMediumLowBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="40" Height="40" CornerRadius="8"
                        Background="{StaticResource UserGradientBrush}"
                        VerticalAlignment="Center" Margin="0,0,16,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#FFB900" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                    </Border.Effect>
                    <materialDesign:PackIcon Kind="AccountMultiple" Width="20" Height="20"
                                            Foreground="White"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.Nav_Users}" 
                              FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Static loc:Strings.View_Users_Subtitle}" 
                              FontSize="12" Opacity="0.7" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                       Command="{Binding RefreshCommand}"
                       Height="36" Padding="12,0"
                       Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" 
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Btn_Refresh}" 
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                       Command="{Binding ExportCommand}"
                       IsEnabled="False"
                       Height="36" Padding="12,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Export" 
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Btn_Export}" 
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Add User Card -->
        <Border Grid.Row="2"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="10"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="{x:Static loc:Strings.Section_AddNewUser}" 
                          FontSize="15" FontWeight="SemiBold"/>
                
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Username -->
                    <TextBox Grid.Column="0"
                            Text="{Binding NewUserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Field_User_UserName}"
                            materialDesign:HintAssist.IsFloating="True"/>
                    
                    <!-- Display Name -->
                    <TextBox Grid.Column="2"
                            Text="{Binding NewDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Field_User_DisplayName}"
                            materialDesign:HintAssist.IsFloating="True"/>
                    
                    <!-- Add Button -->
                    <Button Grid.Column="4"
                           Command="{Binding AddCommand}"
                           Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                           Width="120" Height="40">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountPlus" 
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"/>
                            <TextBlock Text="{x:Static loc:Strings.Btn_AddUser}" 
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Users List Card -->
        <Border Grid.Row="4"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="16"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Section Header with Search -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0"
                              Text="{x:Static loc:Strings.Section_UserList}" 
                              FontSize="15" FontWeight="SemiBold"/>
                    
                    <TextBox Grid.Column="1"
                            Width="220"
                            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource SearchTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Search_Users}"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="Magnify"/>
                </Grid>
                
                <!-- ListView -->
                <ListView Grid.Row="2"
                         ItemsSource="{Binding UsersView}"
                         Style="{StaticResource OperationLikeListView}">
                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ManageListColumnHeader}"/>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource OperationLikeListViewItem}"/>
                    </ListView.Resources>
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">
                            <GridViewColumn Width="250" Header="{x:Static loc:Strings.Col_User_UserName}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <Border Width="32" Height="32"
                                                   CornerRadius="16"
                                                   Background="{StaticResource UserGradientBrush}"
                                                   Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="Account"
                                                                        Width="18" Height="18"
                                                                        Foreground="White"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding UserName}" FontWeight="Medium" FontSize="13"/>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="11" Opacity="0.6"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Width="100" Header="{x:Static loc:Strings.Col_Status}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:Chip Content="{Binding IsActive, Converter={StaticResource BoolToStatusConverter}}"
                                                            Margin="6,0"
                                                            FontSize="11"
                                                            Padding="6,2"
                                                            Foreground="White"
                                                            HorizontalAlignment="Left">
                                            <materialDesign:Chip.Style>
                                                <Style TargetType="materialDesign:Chip">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:Chip.Style>
                                        </materialDesign:Chip>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Width="220" Header="{x:Static loc:Strings.Col_Created}" DisplayMemberBinding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}"/>

                            <GridViewColumn Width="140" Header="{x:Static loc:Strings.Col_Actions}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                   Command="{Binding DataContext.ResetPasswordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   ToolTip="{x:Static loc:Strings.Tooltip_ResetPassword}"
                                                   Width="32" Height="32"
                                                   Margin="0,0,4,0">
                                                <materialDesign:PackIcon Kind="LockReset" Width="18" Height="18"/>
                                            </Button>

                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                   Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   ToolTip="{x:Static loc:Strings.Tooltip_EditUser}"
                                                   Width="32" Height="32"
                                                   Margin="0,0,4,0">
                                                <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                            </Button>

                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                   Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   ToolTip="{x:Static loc:Strings.Tooltip_DeleteUser}"
                                                   Width="32" Height="32"
                                                   Foreground="{StaticResource ErrorBrush}">
                                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</UserControl>
