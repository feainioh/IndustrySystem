<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
    
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <Style x:Key="SearchTextField" TargetType="TextBox" BasedOn="{StaticResource ManagementSearchTextBox}"/>
    </UserControl.Resources>
    
    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{StaticResource PageHeaderIconBorder}" Background="{StaticResource UserGradientBrush}">
                    <materialDesign:PackIcon Kind="AccountMultiple" Style="{StaticResource PageHeaderPackIcon}"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.Nav_Users}" Style="{StaticResource PageHeaderTitle}"/>
                    <TextBlock Text="{x:Static loc:Strings.View_Users_Subtitle}" Style="{StaticResource PageHeaderSubtitle}"/>
                </StackPanel>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsPanel}">
                <Button Style="{StaticResource HeaderActionOutlinedButton}"
                       Command="{Binding RefreshCommand}"
                       Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" 
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Btn_Refresh}" 
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                  <Button Style="{StaticResource HeaderActionRaisedButton}"
                       Command="{Binding ExportCommand}"
                      IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Export" 
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Btn_Export}" 
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Add User Card -->
        <Border Grid.Row="2" Style="{StaticResource FormCard}">
            <StackPanel>
                <TextBlock Text="{x:Static loc:Strings.Section_AddNewUser}" 
                          FontSize="15" FontWeight="SemiBold"/>
                
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Username -->
                    <TextBox Grid.Column="0"
                            Text="{Binding NewUserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Field_User_UserName}"
                            materialDesign:HintAssist.IsFloating="True"/>
                    
                    <!-- Display Name -->
                    <TextBox Grid.Column="2"
                            Text="{Binding NewDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Field_User_DisplayName}"
                            materialDesign:HintAssist.IsFloating="True"/>
                    
                    <!-- Add Button -->
                    <Button Grid.Column="4"
                           Command="{Binding AddCommand}"
                           Style="{StaticResource AppInteractiveButtonPrimary}"
                           Width="120" Height="40">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountPlus" 
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"/>
                            <TextBlock Text="{x:Static loc:Strings.Btn_AddUser}" 
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Users List Card -->
        <Border Grid.Row="4" Style="{StaticResource FormCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Section Header with Search -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0"
                              Text="{x:Static loc:Strings.Section_UserList}" 
                              FontSize="15" FontWeight="SemiBold"/>
                    
                    <TextBox Grid.Column="1"
                            Width="220"
                            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource SearchTextField}"
                            materialDesign:HintAssist.Hint="{x:Static loc:Strings.Search_Users}"
                            materialDesign:TextFieldAssist.HasLeadingIcon="True"
                            materialDesign:TextFieldAssist.LeadingIcon="Magnify"/>
                </Grid>
                
                <!-- DataGrid -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding PagedUsers}"
                          Style="{StaticResource ListViewLikeDataGrid}">
                    <DataGrid.Columns>
                            <DataGridTemplateColumn Width="250" Header="{x:Static loc:Strings.Col_User_UserName}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <Border Style="{StaticResource DataGridLeadingIconBadge}" Background="{StaticResource UserGradientBrush}">
                                                <materialDesign:PackIcon Kind="Account" Style="{StaticResource DataGridLeadingPackIcon}" Foreground="White"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding UserName}" FontWeight="Medium" FontSize="13"/>
                                                <TextBlock Text="{Binding DisplayName}" FontSize="11" Opacity="0.6"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="100" Header="{x:Static loc:Strings.Col_Status}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:Chip Content="{Binding IsActive, Converter={StaticResource BoolToStatusConverter}}"
                                                            Margin="6,0"
                                                            FontSize="11"
                                                            Padding="6,2"
                                                            Foreground="White"
                                                            HorizontalAlignment="Left">
                                            <materialDesign:Chip.Style>
                                                <Style TargetType="materialDesign:Chip">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:Chip.Style>
                                        </materialDesign:Chip>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Width="220" Header="{x:Static loc:Strings.Col_Created}" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}"/>

                            <DataGridTemplateColumn Width="140" Header="{x:Static loc:Strings.Col_Actions}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                   Command="{Binding DataContext.ResetPasswordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   ToolTip="{x:Static loc:Strings.Tooltip_ResetPassword}">
                                                <materialDesign:PackIcon Kind="LockReset" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>

                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                   Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   ToolTip="{x:Static loc:Strings.Tooltip_EditUser}">
                                                <materialDesign:PackIcon Kind="Pencil" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>

                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                   Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding Id}"
                                                   ToolTip="{x:Static loc:Strings.Tooltip_DeleteUser}"
                                                   Foreground="{StaticResource ErrorBrush}">
                                                <materialDesign:PackIcon Kind="Delete" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pagination -->
                <Border Grid.Row="4" Style="{StaticResource PaginationCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Style="{StaticResource PaginationStatsPanel}">
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Total}" Opacity="0.7"/>
                            <TextBlock Text="{Binding TotalCount}" FontWeight="SemiBold" Foreground="{StaticResource HeaderGradient}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Records}" Opacity="0.7"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Style="{StaticResource PaginationButtonPanel}">
                            <Button Content="&#xE892;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding FirstPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_FirstPage}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding PreviousPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Prev}" Style="{StaticResource PaginationButton}"/>

                            <Border Style="{StaticResource CurrentPageBorder}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CurrentPage}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" / " Opacity="0.7" Margin="4,0"/>
                                    <TextBlock Text="{Binding TotalPages}" Opacity="0.7"/>
                                </StackPanel>
                            </Border>

                            <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding NextPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Next}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE893;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding LastPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_LastPage}" Style="{StaticResource PaginationButton}"/>

                            <ComboBox SelectedItem="{Binding PageSize, Mode=TwoWay}"
                                      ItemsSource="{Binding PageSizes}"
                                      Width="80" Margin="12,0,0,0" Style="{StaticResource PaginationComboBox}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_PerPage}" VerticalAlignment="Center" Opacity="0.7" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

