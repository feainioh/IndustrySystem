<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.MaterialInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <Style x:Key="SearchTextField" TargetType="TextBox" BasedOn="{StaticResource ManagementSearchTextBox}"/>
    </UserControl.Resources>

    <Grid Style="{StaticResource PageRootGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{StaticResource StandardGridSpacing}"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{StaticResource PageHeaderIconBorder}" Background="{StaticResource MaterialGradientBrush}">
                    <TextBlock Text="&#xE81E;" Style="{StaticResource PageHeaderMdl2Icon}"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.Nav_MaterialInfo}" Style="{StaticResource PageHeaderTitle}"/>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Page_MaterialInfo_Subtitle]}" Style="{StaticResource PageHeaderSubtitle}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Style="{StaticResource PageHeaderActionsPanel}">
                <Button Style="{StaticResource HeaderActionOutlinedButton}"
                        Command="{Binding RefreshCommand}"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Btn_Refresh}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource HeaderActionAccentButton}"
                        Command="{Binding AddCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Btn_Add}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource FormCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource MediumGridSpacing}"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="{StaticResource MediumGridSpacing}"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Loc}, Path=[Section_MaterialList]}" FontSize="15" FontWeight="SemiBold"/>

                    <TextBox Grid.Column="1"
                             Width="280"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextField}"
                             materialDesign:HintAssist.Hint="{Binding Source={StaticResource Loc}, Path=[Hint_Search_Material]}"
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="Magnify"/>
                </Grid>

                <DataGrid Grid.Row="2" ItemsSource="{Binding PagedMaterials}" Style="{StaticResource ListViewLikeDataGrid}">
                    <DataGrid.Columns>

                            <DataGridTemplateColumn Width="260" Header="{Binding Source={StaticResource Loc}, Path=[Col_Material]}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <Border Style="{StaticResource DataGridLeadingIconBadge}" Background="{StaticResource MaterialGradientBrush}">
                                                <materialDesign:PackIcon Kind="FlaskOutline" Style="{StaticResource DataGridLeadingPackIcon}" Foreground="White"/>
                                            </Border>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding FullName}" FontSize="11" Opacity="0.65" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Width="110" Header="{Binding Source={StaticResource Loc}, Path=[Col_MolecularFormula]}" Binding="{Binding MolecularFormula}"/>

                            <DataGridTemplateColumn Width="110" Header="{Binding Source={StaticResource Loc}, Path=[Col_Category]}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:Chip Content="{Binding Category, Converter={StaticResource EnumDescriptionConverter}}" Margin="6,0" Padding="8,2" FontSize="11"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="110" Header="{Binding Source={StaticResource Loc}, Path=[Col_MaterialType]}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding MaterialType, Converter={StaticResource EnumDescriptionConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Width="140" Header="{Binding Source={StaticResource Loc}, Path=[Col_CasNo]}" Binding="{Binding CasNo}"/>
                            <DataGridTextColumn Width="120" Header="{Binding Source={StaticResource Loc}, Path=[Col_Purity]}" Binding="{Binding Purity}"/>
                            <DataGridTextColumn Width="100" Header="{Binding Source={StaticResource Loc}, Path=[Col_Unit]}" Binding="{Binding Unit}"/>
                            <DataGridTemplateColumn Width="120" Header="{Binding Source={StaticResource Loc}, Path=[Col_HazardLevel]}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HazardLevel, Converter={StaticResource EnumDescriptionConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="120" Header="{Binding Source={StaticResource Loc}, Path=[Col_StorageCondition]}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StorageCondition, Converter={StaticResource EnumDescriptionConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Width="130" Header="{Binding Source={StaticResource Loc}, Path=[Col_Supplier]}" Binding="{Binding Supplier}"/>

                            <DataGridTemplateColumn Width="130" Header="{x:Static loc:Strings.Col_Actions}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="{x:Static loc:Strings.Btn_Edit}">
                                                <materialDesign:PackIcon Kind="Pencil" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                            <Button Style="{StaticResource DataGridActionIconButton}"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="{x:Static loc:Strings.Btn_Delete}"
                                                    Foreground="{StaticResource ErrorBrush}">
                                                <materialDesign:PackIcon Kind="Delete" Style="{StaticResource DataGridActionPackIcon}"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Pagination -->
                <Border Grid.Row="4" Style="{StaticResource PaginationCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Style="{StaticResource PaginationStatsPanel}">
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Total}" Opacity="0.7"/>
                            <TextBlock Text="{Binding TotalCount}" FontWeight="SemiBold" Foreground="{StaticResource HeaderGradient}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_Records}" Opacity="0.7"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Style="{StaticResource PaginationButtonPanel}">
                            <Button Content="&#xE892;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding FirstPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_FirstPage}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding PreviousPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Prev}" Style="{StaticResource PaginationButton}"/>

                            <Border Style="{StaticResource CurrentPageBorder}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CurrentPage}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" / " Opacity="0.7" Margin="4,0"/>
                                    <TextBlock Text="{Binding TotalPages}" Opacity="0.7"/>
                                </StackPanel>
                            </Border>

                            <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding NextPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Btn_Next}" Style="{StaticResource PaginationButton}"/>
                            <Button Content="&#xE893;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding LastPageCommand}"
                                    ToolTip="{x:Static loc:Strings.Tooltip_LastPage}" Style="{StaticResource PaginationButton}"/>

                            <ComboBox SelectedItem="{Binding PageSize, Mode=TwoWay}"
                                      ItemsSource="{Binding PageSizes}"
                                      Width="80" Margin="12,0,0,0" Style="{StaticResource PaginationComboBox}"/>
                            <TextBlock Text="{x:Static loc:Strings.Lbl_PerPage}" VerticalAlignment="Center" Opacity="0.7" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
