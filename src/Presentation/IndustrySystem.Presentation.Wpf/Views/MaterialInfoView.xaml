<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.MaterialInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="False"
             Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
    <UserControl.Resources>
        <loc:LocalizationProvider x:Key="Loc" />
        <Style x:Key="SearchTextField" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignFilledTextBox}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Padding" Value="10,2,10,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CaretBrush" Value="Black"/>
        </Style>
        <Style x:Key="OperationLikeListView" TargetType="ListView" BasedOn="{StaticResource ModernListView}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ManageListItem}"/>
        </Style>
        <Style x:Key="OperationLikeListViewItem" TargetType="ListViewItem" BasedOn="{StaticResource ManageListItem}">
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource SystemControlAltMediumLowBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="40" Height="40" CornerRadius="8"
                        Background="{StaticResource MaterialGradientBrush}"
                        VerticalAlignment="Center" Margin="0,0,16,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#8764B8" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                    </Border.Effect>
                    <materialDesign:PackIcon Kind="PackageVariant"
                                             Width="20" Height="20"
                                             Foreground="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.Nav_MaterialInfo}" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Page_MaterialInfo_Subtitle]}" FontSize="12" Opacity="0.7" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding RefreshCommand}"
                        Height="36" Padding="12,0"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Btn_Refresh}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                        Command="{Binding AddCommand}"
                        Height="36" Padding="12,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{x:Static loc:Strings.Btn_Add}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="8" Padding="16"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding Source={StaticResource Loc}, Path=[Section_MaterialList]}" FontSize="15" FontWeight="SemiBold"/>

                    <TextBox Grid.Column="1"
                             Width="280"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextField}"
                             materialDesign:HintAssist.Hint="{Binding Source={StaticResource Loc}, Path=[Hint_Search_Material]}"
                             materialDesign:TextFieldAssist.HasLeadingIcon="True"
                             materialDesign:TextFieldAssist.LeadingIcon="Magnify"/>
                </Grid>

                <ListView Grid.Row="2" ItemsSource="{Binding MaterialsView}" Style="{StaticResource OperationLikeListView}">
                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader" BasedOn="{StaticResource ManageListColumnHeader}"/>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource OperationLikeListViewItem}"/>
                    </ListView.Resources>
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">

                            <GridViewColumn Width="260" Header="{Binding Source={StaticResource Loc}, Path=[Col_Material]}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <Border Width="30" Height="30" CornerRadius="15" Background="{StaticResource MaterialGradientBrush}" Margin="0,0,10,0">
                                                <materialDesign:PackIcon Kind="FlaskOutline" Width="16" Height="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding FullName}" FontSize="11" Opacity="0.65" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Width="110" Header="{Binding Source={StaticResource Loc}, Path=[Col_MolecularFormula]}" DisplayMemberBinding="{Binding MolecularFormula}"/>

                            <GridViewColumn Width="110" Header="{Binding Source={StaticResource Loc}, Path=[Col_Category]}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:Chip Content="{Binding Category, Converter={StaticResource EnumDescriptionConverter}}" Margin="6,0" Padding="8,2" FontSize="11"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Width="110" Header="{Binding Source={StaticResource Loc}, Path=[Col_MaterialType]}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding MaterialType, Converter={StaticResource EnumDescriptionConverter}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <GridViewColumn Width="140" Header="{Binding Source={StaticResource Loc}, Path=[Col_CasNo]}" DisplayMemberBinding="{Binding CasNo}"/>
                            <GridViewColumn Width="120" Header="{Binding Source={StaticResource Loc}, Path=[Col_Purity]}" DisplayMemberBinding="{Binding Purity}"/>
                            <GridViewColumn Width="100" Header="{Binding Source={StaticResource Loc}, Path=[Col_Unit]}" DisplayMemberBinding="{Binding Unit}"/>
                            <GridViewColumn Width="120" Header="{Binding Source={StaticResource Loc}, Path=[Col_HazardLevel]}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HazardLevel, Converter={StaticResource EnumDescriptionConverter}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="120" Header="{Binding Source={StaticResource Loc}, Path=[Col_StorageCondition]}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StorageCondition, Converter={StaticResource EnumDescriptionConverter}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="130" Header="{Binding Source={StaticResource Loc}, Path=[Col_Supplier]}" DisplayMemberBinding="{Binding Supplier}"/>

                            <GridViewColumn Width="130" Header="{x:Static loc:Strings.Col_Actions}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,0">
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="{x:Static loc:Strings.Btn_Edit}"
                                                    Width="32" Height="32"
                                                    Margin="0,0,4,0">
                                                <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    ToolTip="{x:Static loc:Strings.Btn_Delete}"
                                                    Width="32" Height="32"
                                                    Foreground="{StaticResource ErrorBrush}">
                                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</UserControl>
