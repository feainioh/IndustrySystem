<UserControl x:Class="IndustrySystem.Presentation.Wpf.Views.AlarmView"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:ui="http://schemas.modernwpf.com/2019"
           xmlns:prism="http://prismlibrary.com/"
           xmlns:loc="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
           xmlns:conv="clr-namespace:IndustrySystem.Presentation.Wpf.Converters"
           prism:ViewModelLocator.AutoWireViewModel="True"
           Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
<UserControl.Resources>
  <conv:BooleanNegationConverter x:Key="BooleanNegationConverter"/>

  <Style x:Key="AlarmSummaryCard" TargetType="Border" BasedOn="{StaticResource CardBorder}">
    <Setter Property="Padding" Value="14,10"/>
  </Style>

  <Style x:Key="AlarmStatusChip" TargetType="Border">
    <Setter Property="CornerRadius" Value="10"/>
    <Setter Property="Padding" Value="8,3"/>
    <Setter Property="Background" Value="#F1F5F9"/>
  </Style>
</UserControl.Resources>
<Grid Style="{StaticResource PageRootGrid}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="12"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header with title and refresh button -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <Border Style="{StaticResource PageHeaderIconBorder}" Background="{DynamicResource DeviceGradientBrush}">
          <TextBlock Text="&#xE7BA;" Style="{StaticResource PageHeaderMdl2Icon}"/>
        </Border>
        <TextBlock Text="{x:Static loc:Strings.Nav_Alarm}" 
                   Style="{StaticResource PageHeaderTitle}"/>
      </StackPanel>
      
      <Button Grid.Column="1" 
              Command="{Binding RefreshCommand}"
              Style="{StaticResource PrimaryCommandButton}">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
          <TextBlock Text="{x:Static loc:Strings.Btn_Refresh}" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </Grid>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource AlarmSummaryCard}">
        <StackPanel>
          <TextBlock Text="{x:Static loc:Strings.Nav_Alarm}" FontSize="12" Foreground="{StaticResource AppMutedTextBrush}"/>
          <TextBlock Text="{Binding TotalAlarms}" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource AppPrimaryTextBrush}"/>
        </StackPanel>
      </Border>

      <Border Grid.Column="2" Style="{StaticResource AlarmSummaryCard}">
        <StackPanel>
          <TextBlock Text="{x:Static loc:Strings.Alarm_Status_Unacknowledged}" FontSize="12" Foreground="{StaticResource AppMutedTextBrush}"/>
          <TextBlock Text="{Binding UnacknowledgedAlarms}" FontSize="24" FontWeight="SemiBold" Foreground="#C81E1E"/>
        </StackPanel>
      </Border>

      <Border Grid.Column="4" Style="{StaticResource AlarmSummaryCard}">
        <StackPanel>
          <TextBlock Text="{x:Static loc:Strings.Alarm_Status_Acknowledged}" FontSize="12" Foreground="{StaticResource AppMutedTextBrush}"/>
          <TextBlock Text="{Binding AcknowledgedAlarms}" FontSize="24" FontWeight="SemiBold" Foreground="#1E7C45"/>
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="4" Style="{StaticResource ListCard}" Padding="14">
      <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,6,0">
          <ItemsControl ItemsSource="{Binding Alarms}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="#FBFCFE" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="14,12" Margin="0,0,0,10">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="StatusPill"
                            Width="42" Height="42" CornerRadius="21"
                            VerticalAlignment="Top" HorizontalAlignment="Left">
                      <TextBlock x:Name="StatusIcon"
                                 FontFamily="Segoe MDL2 Assets" FontSize="18"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,12,0">
                      <TextBlock Text="{Binding Message}" FontSize="14" FontWeight="SemiBold"
                                 Foreground="{StaticResource AppPrimaryTextBrush}"
                                 TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>

                      <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{StaticResource AppMutedTextBrush}" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Time, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" FontSize="12"
                                   Foreground="{StaticResource AppMutedTextBrush}"/>

                        <Border x:Name="StatusChip" Style="{StaticResource AlarmStatusChip}" Margin="12,0,0,0">
                          <TextBlock x:Name="StatusText" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                      </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Command="{Binding DataContext.AckCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding Id}"
                            IsEnabled="{Binding Acknowledged, Converter={StaticResource BooleanNegationConverter}}"
                            Style="{StaticResource SecondaryCommandButton}"
                            MinWidth="96" VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static loc:Strings.Btn_Acknowledge}" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Button>
                  </Grid>
                </Border>

                <DataTemplate.Triggers>
                  <DataTrigger Binding="{Binding Acknowledged}" Value="False">
                    <Setter TargetName="StatusPill" Property="Background" Value="#FEECEC"/>
                    <Setter TargetName="StatusIcon" Property="Text" Value="&#xE7BA;"/>
                    <Setter TargetName="StatusIcon" Property="Foreground" Value="#C81E1E"/>
                    <Setter TargetName="StatusChip" Property="Background" Value="#FEECEC"/>
                    <Setter TargetName="StatusText" Property="Text" Value="{x:Static loc:Strings.Alarm_Status_Unacknowledged}"/>
                    <Setter TargetName="StatusText" Property="Foreground" Value="#C81E1E"/>
                  </DataTrigger>

                  <DataTrigger Binding="{Binding Acknowledged}" Value="True">
                    <Setter TargetName="StatusPill" Property="Background" Value="#E9F7EF"/>
                    <Setter TargetName="StatusIcon" Property="Text" Value="&#xE73E;"/>
                    <Setter TargetName="StatusIcon" Property="Foreground" Value="#1E7C45"/>
                    <Setter TargetName="StatusChip" Property="Background" Value="#E9F7EF"/>
                    <Setter TargetName="StatusText" Property="Text" Value="{x:Static loc:Strings.Alarm_Status_Acknowledged}"/>
                    <Setter TargetName="StatusText" Property="Foreground" Value="#1E7C45"/>
                  </DataTrigger>
                </DataTemplate.Triggers>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding TotalAlarms}" Value="0">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>
          <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets"
                     FontSize="48" HorizontalAlignment="Center"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
          <TextBlock Text="{x:Static loc:Strings.Alarm_NoAlarms}"
                     FontSize="16" Margin="0,16,0,0"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
