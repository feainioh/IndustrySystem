<Window x:Class="IndustrySystem.Presentation.Wpf.Shell"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:ui="http://schemas.modernwpf.com/2019"
 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
 xmlns:local="clr-namespace:IndustrySystem.Presentation.Wpf"
 xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
 xmlns:behaviors="clr-namespace:IndustrySystem.Presentation.Wpf.Behaviors"
 xmlns:res="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
 xmlns:conv="clr-namespace:IndustrySystem.Presentation.Wpf.Converters"
 xmlns:vm="clr-namespace:IndustrySystem.Presentation.Wpf.ViewModels"
 xmlns:prism="http://prismlibrary.com/"
 xmlns:s="clr-namespace:IndustrySystem.Presentation.Wpf.Services"
 xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
 ui:WindowHelper.UseModernWindowStyle="True"
 ui:TitleBar.ExtendViewIntoTitleBar="True"
 ui:TitleBar.IsBackButtonVisible="False"
 Title="{x:Static res:Strings.App_Title}"
 Height="800" Width="1280"
 WindowState="Maximized"
        WindowStyle="None"
 WindowStartupLocation="CenterScreen"
 MinHeight="600" MinWidth="900"
 Background="{DynamicResource AppPageBackgroundBrush}">

    <Window.Resources>
        <conv:PermissionToVisibilityConverter x:Key="PermissionToVisibility"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- 动画样式 -->
        <Style x:Key="FadeInAnimation" TargetType="FrameworkElement">
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                           From="0" To="1" Duration="0:0:0.5"
                                           DecelerationRatio="0.7"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <!-- 自定义标题栏区域 -->
        <Grid Height="40" VerticalAlignment="Top" 
                            Background="{DynamicResource ShellTitleBarBrush}">
                        <i:Interaction.Behaviors>
                                <behaviors:WindowTitleBarDragBehavior/>
                        </i:Interaction.Behaviors>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- 底部发光线条 -->
            <Rectangle Grid.ColumnSpan="3" Height="1" VerticalAlignment="Bottom"
                       Fill="{DynamicResource ShellAccentLineBrush}"/>

            <!-- Logo 和标题 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" 
                       Margin="16,0,0,0" VerticalAlignment="Center">
                <!-- Logo with gradient border -->
                <Border Width="28" Height="28" CornerRadius="6"
                    Background="{DynamicResource ShellAccentBrush}"
                        Padding="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#0078D4" BlurRadius="8" 
                                        ShadowDepth="0" Opacity="0.6"/>
                    </Border.Effect>
                    <Border Background="{DynamicResource ShellLogoInnerBrush}" CornerRadius="5">
                        <ui:FontIcon Glyph="&#xE950;" FontSize="14" 
                                   Foreground="{DynamicResource ShellAccentBrush}"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                </Border>
                
                <!-- 标题文字 -->
                <TextBlock Text="{x:Static res:Strings.App_Title}" 
                          FontSize="13" FontWeight="SemiBold"
                          Foreground="{DynamicResource ShellTitleForegroundBrush}"
                          VerticalAlignment="Center" 
                          Margin="12,0,0,0"/>
                
                <!-- 版本信息 -->
                  <Border Background="{DynamicResource ShellChromeSurfaceBrush}" 
                       CornerRadius="3" 
                       Padding="6,2"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.App_Version}" 
                              FontSize="9" 
                              Foreground="{DynamicResource ShellMutedForegroundBrush}"
                              FontWeight="Medium"/>
                </Border>
            </StackPanel>

            <!-- 中间工具栏 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" 
                       VerticalAlignment="Center"
                       shell:WindowChrome.IsHitTestVisibleInChrome="True"
                       Margin="0,0,138,0">
                
                <!-- 主题切换按钮 -->
                <Button x:Name="VisualThemeButton"
                        Width="118" Height="30"
                        Background="{DynamicResource ShellChromeSurfaceBrush}"
                        BorderBrush="{DynamicResource ShellContentBorderBrush}"
                        BorderThickness="1"
                        Padding="10,0"
                        ToolTip="{Binding VisualThemeToolTip}"
                        Command="{Binding ToggleVisualThemeCommand}"
                        Margin="4,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:FontIcon Glyph="{Binding VisualThemeGlyph}"
                                     FontSize="12"
                                     Foreground="{DynamicResource ShellButtonForegroundBrush}"
                                     Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding VisualThemeText}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellTitleForegroundBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                               BorderBrush="{TemplateBinding BorderBrush}"
                                               BorderThickness="{TemplateBinding BorderThickness}"
                                               CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#20FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#30FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- 用户信息卡片 -->
                  <Border Background="{DynamicResource ShellChromeSurfaceBrush}" 
                       CornerRadius="16" 
                       Padding="8,4"
                       Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="24" Height="24" CornerRadius="12"
                               Background="{DynamicResource ShellAccentBrush}"
                               Margin="0,0,6,0">
                            <ui:FontIcon Glyph="&#xE77B;" 
                                       FontSize="11" 
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding CurrentUserName}" 
                                  Foreground="{DynamicResource ShellTitleForegroundBrush}" 
                                  FontSize="11"
                                  FontWeight="Medium"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 登出按钮 -->
                  <Button Command="{Binding LogoutCommand}" 
                       Width="32" Height="32"
                       Background="Transparent"
                       BorderThickness="0"
                       ToolTip="{x:Static res:Strings.Tooltip_Logout}"
                       Margin="4,0">
                    <ui:FontIcon Glyph="&#xF3B1;" 
                               FontSize="12" 
                               Foreground="{DynamicResource ShellButtonForegroundBrush}"/>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                               CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#20FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#30FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="2"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Tag" Value="{DynamicResource IsLiquidGlassTheme}"/>
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <Button Width="46" Height="30"
                        Background="Transparent"
                        BorderThickness="0"
                    Command="{Binding MinimizeWindowCommand}"
                        ToolTip="最小化">
                    <ui:FontIcon Glyph="&#xE921;" FontSize="10" Foreground="{DynamicResource ShellTitleForegroundBrush}"/>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1FFFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#30FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Width="46" Height="30"
                        Background="Transparent"
                        BorderThickness="0"
                    Command="{Binding ToggleWindowStateCommand}"
                        ToolTip="最大化/还原">
                    <ui:FontIcon x:Name="WindowStateIcon" Glyph="&#xE922;" FontSize="10" Foreground="{DynamicResource ShellTitleForegroundBrush}"/>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1FFFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#30FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Width="46" Height="30"
                        Background="Transparent"
                        BorderThickness="0"
                    Command="{Binding CloseWindowCommand}"
                        ToolTip="关闭">
                    <ui:FontIcon Glyph="&#xE8BB;" FontSize="10" Foreground="{DynamicResource ShellTitleForegroundBrush}"/>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#C50F1F"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

        </Grid>

        <Border HorizontalAlignment="Left"
            VerticalAlignment="Stretch"
            Width="{DynamicResource ShellNavigationPaneWidth}"
            Margin="{DynamicResource ShellNavigationPaneMargin}"
            CornerRadius="{DynamicResource ShellNavigationPaneCornerRadius}"
            Background="{DynamicResource ShellNavigationPaneBackgroundBrush}"
            BorderBrush="{DynamicResource ShellNavigationPaneBorderBrush}"
            BorderThickness="{DynamicResource ShellNavigationPaneBorderThickness}"
            Effect="{DynamicResource ShellNavigationPaneShadow}"
            IsHitTestVisible="False"
            Visibility="{Binding ElementName=NavView, Path=IsPaneOpen, Converter={StaticResource BoolToVisibility}}"/>

        <!-- 主内容区域 -->
        <ui:NavigationView x:Name="NavView" 
                  Margin="0,40,0,0"
                          IsSettingsVisible="False"
                          PaneDisplayMode="Left"
                          IsPaneOpen="True"
                  OpenPaneLength="{DynamicResource ShellNavigationPaneWidth}"
                          CompactPaneLength="56"
                          IsBackButtonVisible="Collapsed"
                          Background="Transparent">

            <ui:NavigationView.PaneFooter>
                <TextBlock Text="{x:Static res:Strings.App_FooterCopyright}" 
                          FontSize="11" 
                          Foreground="{DynamicResource ShellMutedForegroundBrush}"
                          Opacity="0.8"
                          Margin="16,8"
                          TextAlignment="Center"/>
            </ui:NavigationView.PaneFooter>

            <i:Interaction.Triggers>
                <i:EventTrigger EventName="Loaded">
                    <i:InvokeCommandAction Command="{Binding OnLoadedCommand}"/>
                </i:EventTrigger>
                <i:EventTrigger EventName="SelectionChanged">
                    <i:InvokeCommandAction Command="{Binding NavSelectionChangedCommand}" PassEventArgsToCommand="True"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>

            <ui:NavigationView.MenuItems>
                <!-- 运行看板 -->
                <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_RunDashboard}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE80F;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_RunExperiment}" Tag="RunExperimentView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE768;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_RealtimeData}" Tag="RealtimeDataView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE9D2;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_Alarm}" Tag="AlarmView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE7BA;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemSeparator/>

                <!-- 实验管理 -->
                <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_ExperimentManagement}"
                                       AutomationProperties.AutomationId="NavExperimentManagementGroup">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE8F1;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.Visibility>
                        <MultiBinding Converter="{StaticResource PermissionToVisibility}">
                            <Binding Path="AuthState"/>
                            <Binding>
                                <Binding.Source>Experiments.View</Binding.Source>
                            </Binding>
                            <Binding>
                                <Binding.Source>Templates.View</Binding.Source>
                            </Binding>
                            <Binding>
                                <Binding.Source>Templates.Edit</Binding.Source>
                            </Binding>
                        </MultiBinding>
                    </ui:NavigationViewItem.Visibility>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_Templates}" Tag="ExperimentTemplateView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE8A5;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_ExperimentConfig}" Tag="ExperimentConfigView"
                                               AutomationProperties.AutomationId="NavExperimentConfigItem">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE9E9;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_ExperimentGroupConfig}" Tag="ExperimentGroupsView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE71D;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>

                <!-- 物料管理 -->
                <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_MaterialManagement}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE7B8;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.Visibility>
                        <MultiBinding Converter="{StaticResource PermissionToVisibility}">
                            <Binding Path="AuthState"/>
                            <Binding>
                                <Binding.Source>Material.View</Binding.Source>
                            </Binding>
                            <Binding>
                                <Binding.Source>Inventory.View</Binding.Source>
                            </Binding>
                        </MultiBinding>
                    </ui:NavigationViewItem.Visibility>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_MaterialInfo}" Tag="MaterialInfoView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE8EC;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_ShelfInfo}" Tag="ShelfInfoView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE81E;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_Inventory}" Tag="InventoryView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE8B7;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemSeparator/>

                <!-- 数据管理 -->
                <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_DataManagement}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE8B7;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.Visibility>
                        <Binding Path="AuthState.IsAuthenticated" Converter="{StaticResource BoolToVisibility}"/>
                    </ui:NavigationViewItem.Visibility>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_ExperimentHistory}" Tag="ExperimentHistoryView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE81C;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_OperationLogs}" Tag="OperationLogsView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE8BC;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>

                <!-- 设备管理 -->
                <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_DeviceManagement}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xECAA;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.Visibility>
                        <MultiBinding Converter="{StaticResource PermissionToVisibility}">
                            <Binding Path="AuthState"/>
                            <Binding>
                                <Binding.Source>Admin</Binding.Source>
                            </Binding>
                            <Binding>
                                <Binding.Source>Device.Maintain</Binding.Source>
                            </Binding>
                        </MultiBinding>
                    </ui:NavigationViewItem.Visibility>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_ManualDebug}" Tag="HardwareDebugView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE9D9;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_DeviceParams}" Tag="DeviceParamsView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE713;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemSeparator/>

                <!-- 系统管理 -->
                <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_SystemManagement}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE115;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.Visibility>
                        <MultiBinding Converter="{StaticResource PermissionToVisibility}">
                            <Binding Path="AuthState"/>
                            <Binding>
                                <Binding.Source>SuperAdmin</Binding.Source>
                            </Binding>
                            <Binding>
                                <Binding.Source>Admin</Binding.Source>
                            </Binding>
                        </MultiBinding>
                    </ui:NavigationViewItem.Visibility>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_Users}" Tag="UsersView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE77B;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_Roles}" Tag="RoleManageView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE716;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_Permissions}" Tag="PermissionsView">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE72E;" Foreground="{DynamicResource ShellNavigationIconBrush}"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <!-- 内容区域带卡片效果 -->
            <Border x:Name="ShellContentBorder"
                    CornerRadius="{DynamicResource ShellContentCornerRadius}" 
                    Margin="4"
                    Background="{DynamicResource ShellContentBackgroundBrush}"
                    BorderBrush="{DynamicResource ShellContentBorderBrush}"
                    BorderThickness="1"
                    Effect="{DynamicResource ShellContentShadow}">

                <Grid x:Name="ShellContentClipHost" SizeChanged="ShellContentClipHost_SizeChanged">
                    <materialDesign:DialogHost Identifier="RootDialogHost">
                        <ContentControl x:Name="MainRegionHost" 
                                       Margin="{DynamicResource ShellMainRegionMargin}" 
                                       prism:RegionManager.RegionName="{x:Static vm:ShellViewModel.MainRegionName}"
                                       Style="{StaticResource FadeInAnimation}"/>
                    </materialDesign:DialogHost>
                </Grid>
            </Border>
        </ui:NavigationView>
    </Grid>
</Window>
