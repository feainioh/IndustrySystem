<Window x:Class="IndustrySystem.Presentation.Wpf.Shell"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:ui="http://schemas.modernwpf.com/2019"
 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
 xmlns:local="clr-namespace:IndustrySystem.Presentation.Wpf"
 xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
 xmlns:res="clr-namespace:IndustrySystem.Presentation.Wpf.Resources"
 xmlns:conv="clr-namespace:IndustrySystem.Presentation.Wpf.Converters"
 xmlns:prism="http://prismlibrary.com/"
 xmlns:s="clr-namespace:IndustrySystem.Presentation.Wpf.Services"
 ui:WindowHelper.UseModernWindowStyle="True"
 ui:TitleBar.ExtendViewIntoTitleBar="True"
 ui:TitleBar.IsBackButtonVisible="False"
 Title="{x:Static res:Strings.App_Title}"
 Height="800" Width="1280"
        WindowStyle="None"
 WindowStartupLocation="CenterScreen"
 MinHeight="600" MinWidth="900"
 Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">

    <Window.Resources>
        <conv:PermissionToVisibilityConverter x:Key="PermissionToVisibility"/>
        <!-- 标题栏渐变背景 -->
        <LinearGradientBrush x:Key="TitleBarGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0D1117" Offset="0"/>
            <GradientStop Color="#161B22" Offset="0.5"/>
            <GradientStop Color="#0D1117" Offset="1"/>
        </LinearGradientBrush>

        <!-- 标题栏前景色 -->
        <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="#E6F3FF"/>

        <!-- 科技感渐变背景 -->
        <LinearGradientBrush x:Key="TechGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F1419" Offset="0"/>
            <GradientStop Color="#1A2332" Offset="0.5"/>
            <GradientStop Color="#0F1419" Offset="1"/>
        </LinearGradientBrush>
     

        <!-- Accent 渐变 -->
        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0078D4" Offset="0"/>
            <GradientStop Color="#00BCF2" Offset="1"/>
        </LinearGradientBrush>

        <!-- 发光效果 -->
        <DropShadowEffect x:Key="GlowEffect" 
                          Color="#0078D4" 
                          BlurRadius="20" 
                          ShadowDepth="0" 
                          Opacity="0.6"/>

        <!-- 标题阴影 -->
        <DropShadowEffect x:Key="HeaderShadow" 
                          Color="Black" 
                          BlurRadius="4" 
                          ShadowDepth="1" 
                          Opacity="0.5"/>

        <!-- 卡片阴影 -->
        <DropShadowEffect x:Key="CardShadow" 
                          Color="Black" 
                          BlurRadius="10" 
                          ShadowDepth="2" 
                          Opacity="0.3"/>

        <!-- 动画样式 -->
        <Style x:Key="FadeInAnimation" TargetType="FrameworkElement">
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                           From="0" To="1" Duration="0:0:0.5"
                                           DecelerationRatio="0.7"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- 窗口控制按钮样式 -->
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B3D9FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20FFFFFF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#30FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 关闭按钮样式 -->
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C50F1F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 自定义标题栏区域 -->
        <Grid Height="40" VerticalAlignment="Top" 
              Background="{StaticResource TitleBarGradientBrush}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- 底部发光线条 -->
            <Rectangle Grid.ColumnSpan="4" Height="1" VerticalAlignment="Bottom">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#0078D4" Offset="0.3"/>
                        <GradientStop Color="#00BCF2" Offset="0.7"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Logo 和标题 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" 
                       Margin="16,0,0,0" VerticalAlignment="Center">
                <!-- Logo with gradient border -->
                <Border Width="28" Height="28" CornerRadius="6"
                        Background="{StaticResource AccentGradientBrush}"
                        Padding="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#0078D4" BlurRadius="8" 
                                        ShadowDepth="0" Opacity="0.6"/>
                    </Border.Effect>
                    <Border Background="#1A1F2E" CornerRadius="5">
                        <ui:FontIcon Glyph="&#xE950;" FontSize="14" 
                                   Foreground="{StaticResource AccentGradientBrush}"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                </Border>
                
                <!-- 标题文字 -->
                <TextBlock Text="{x:Static res:Strings.App_Title}" 
                          FontSize="13" FontWeight="SemiBold"
                          Foreground="{StaticResource TitleBarForegroundBrush}"
                          VerticalAlignment="Center" 
                          Margin="12,0,0,0"/>
                
                <!-- 版本信息 -->
                <Border Background="#152030" 
                       CornerRadius="3" 
                       Padding="6,2"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center">
                    <TextBlock Text="v1.0" 
                              FontSize="9" 
                              Foreground="#6B8CAE"
                              FontWeight="Medium"/>
                </Border>
            </StackPanel>

            <!-- 中间工具栏 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" 
                       VerticalAlignment="Center"
                       Margin="0,0,8,0">
                
                <!-- 主题切换按钮 -->
                <Button Width="32" Height="32" 
                       Background="Transparent"
                       BorderThickness="0"
                       ToolTip="切换主题"
                       Margin="4,0">
                    <ui:FontIcon Glyph="&#xE771;" FontSize="12" Foreground="#B3D9FF"/>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                               CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#20FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#30FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- 用户信息卡片 -->
                <Border Background="#152030" 
                       CornerRadius="16" 
                       Padding="8,4"
                       Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="24" Height="24" CornerRadius="12"
                               Background="{StaticResource AccentGradientBrush}"
                               Margin="0,0,6,0">
                            <ui:FontIcon Glyph="&#xE77B;" 
                                       FontSize="11" 
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding CurrentUserName}" 
                                  Foreground="#E6F3FF" 
                                  FontSize="11"
                                  FontWeight="Medium"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 登出按钮 -->
                <Button Click="OnLogoutClick" 
                       Width="32" Height="32"
                       Background="Transparent"
                       BorderThickness="0"
                       ToolTip="登出"
                       Margin="4,0">
                    <ui:FontIcon Glyph="&#xF3B1;" 
                               FontSize="12" 
                               Foreground="#B3D9FF"/>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                               CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#20FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#30FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- 窗口控制按钮 -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" 
                       VerticalAlignment="Center">
                <!-- 最小化 -->
                <Button Content="&#xE921;" 
                       Style="{StaticResource WindowControlButtonStyle}"
                       Click="MinimizeWindow_Click"
                       ToolTip="最小化"/>
                
                <!-- 最大化/还原 -->
                <Button x:Name="MaximizeRestoreButton"
                       Content="&#xE922;" 
                       Style="{StaticResource WindowControlButtonStyle}"
                       Click="MaximizeRestoreWindow_Click"
                       ToolTip="最大化"/>
                
                <!-- 关闭 -->
                <Button Content="&#xE8BB;" 
                       Style="{StaticResource CloseButtonStyle}"
                       Click="CloseWindow_Click"
                       ToolTip="关闭"/>
            </StackPanel>
        </Grid>

        <!-- 主内容区域 -->
        <ui:NavigationView x:Name="NavView" 
                          Margin="0,56,0,0"
                          IsSettingsVisible="False"
                          PaneDisplayMode="Left"
                          IsPaneOpen="True"
                          OpenPaneLength="240"
                          CompactPaneLength="56"
                          IsBackButtonVisible="Collapsed"
                          Background="Transparent">

            <ui:NavigationView.PaneFooter>
                <TextBlock Text="© 2024 Industry System" 
                          FontSize="11" 
                          Foreground="#6B8CAE"
                          Opacity="0.8"
                          Margin="16,8"
                          TextAlignment="Center"/>
            </ui:NavigationView.PaneFooter>

            <i:Interaction.Triggers>
                <i:EventTrigger EventName="Loaded">
                    <i:InvokeCommandAction Command="{Binding OnLoadedCommand}"/>
                </i:EventTrigger>
                <i:EventTrigger EventName="SelectionChanged">
                    <i:InvokeCommandAction Command="{Binding NavSelectionChangedCommand}" PassEventArgsToCommand="True"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>

            <ui:NavigationView.MenuItems>
                <!-- 运行看板 -->
                <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_RunDashboard}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE80F;" Foreground="#00BCF2"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_RunExperiment}" Tag="RunExperiment">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE768;" Foreground="#0078D4"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_RealtimeData}" Tag="RealtimeData">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE9D2;" Foreground="#00BCF2"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="告警监控" Tag="Alarm">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE7BA;" Foreground="#FF4444"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemSeparator/>

                <!-- 实验管理 -->
                <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_ExperimentManagement}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE8F1;" Foreground="#10893E"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.Visibility>
                        <MultiBinding Converter="{StaticResource PermissionToVisibility}">
                            <Binding Path="AuthState"/>
                            <Binding>
                                <Binding.Source>Experiments.View</Binding.Source>
                            </Binding>
                            <Binding>
                                <Binding.Source>Templates.View</Binding.Source>
                            </Binding>
                            <Binding>
                                <Binding.Source>Templates.Edit</Binding.Source>
                            </Binding>
                        </MultiBinding>
                    </ui:NavigationViewItem.Visibility>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_Templates}" Tag="Templates">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE8A5;" Foreground="#107C10"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_ExperimentConfig}" Tag="ExperimentConfig">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE9E9;" Foreground="#10893E"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_ExperimentGroupConfig}" Tag="ExperimentGroupConfig">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE71D;" Foreground="#107C10"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>

                <!-- 物料管理 -->
                <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_MaterialManagement}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE7B8;" Foreground="#FF8C00"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.Visibility>
                        <MultiBinding Converter="{StaticResource PermissionToVisibility}">
                            <Binding Path="AuthState"/>
                            <Binding>
                                <Binding.Source>Material.View</Binding.Source>
                            </Binding>
                            <Binding>
                                <Binding.Source>Inventory.View</Binding.Source>
                            </Binding>
                        </MultiBinding>
                    </ui:NavigationViewItem.Visibility>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_MaterialInfo}" Tag="MaterialInfo">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE8EC;" Foreground="#FF8C00"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_ShelfInfo}" Tag="ShelfInfo">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE81E;" Foreground="#CA5010"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_Inventory}" Tag="Inventory">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE8B7;" Foreground="#FF8C00"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemSeparator/>

                <!-- 数据管理 -->
                <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_DataManagement}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE8B7;" Foreground="#8764B8"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.Visibility>
                        <MultiBinding Converter="{StaticResource PermissionToVisibility}">
                            <Binding Path="AuthState"/>
                            <Binding>
                                <Binding.Source>Admin</Binding.Source>
                            </Binding>
                            <Binding>
                                <Binding.Source>SuperAdmin</Binding.Source>
                            </Binding>
                        </MultiBinding>
                    </ui:NavigationViewItem.Visibility>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_ExperimentHistory}" Tag="ExperimentHistory">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE81C;" Foreground="#8764B8"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_OperationLogs}" Tag="OperationLogs">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE8BC;" Foreground="#8764B8"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>

                <!-- 设备管理 -->
                <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_DeviceManagement}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xECAA;" Foreground="#E74856"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.Visibility>
                        <MultiBinding Converter="{StaticResource PermissionToVisibility}">
                            <Binding Path="AuthState"/>
                            <Binding>
                                <Binding.Source>Admin</Binding.Source>
                            </Binding>
                            <Binding>
                                <Binding.Source>Device.Maintain</Binding.Source>
                            </Binding>
                        </MultiBinding>
                    </ui:NavigationViewItem.Visibility>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_ManualDebug}" Tag="ManualDebug">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE9D9;" Foreground="#E74856"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_DeviceParams}" Tag="DeviceParams">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE713;" Foreground="#C50F1F"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemSeparator/>

                <!-- 系统管理 -->
                <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_SystemManagement}">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE115;" Foreground="#FFB900"/>
                    </ui:NavigationViewItem.Icon>
                    <ui:NavigationViewItem.Visibility>
                        <MultiBinding Converter="{StaticResource PermissionToVisibility}">
                            <Binding Path="AuthState"/>
                            <Binding>
                                <Binding.Source>SuperAdmin</Binding.Source>
                            </Binding>
                            <Binding>
                                <Binding.Source>Admin</Binding.Source>
                            </Binding>
                        </MultiBinding>
                    </ui:NavigationViewItem.Visibility>
                    <ui:NavigationViewItem.MenuItems>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_Users}" Tag="Users">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE77B;" Foreground="#FFB900"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_Roles}" Tag="Roles">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE716;" Foreground="#FFB900"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem Content="{x:Static res:Strings.Nav_Permissions}" Tag="Permissions">
                            <ui:NavigationViewItem.Icon>
                                <ui:FontIcon Glyph="&#xE72E;" Foreground="#FFB900"/>
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationViewItem.MenuItems>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <!-- 内容区域带卡片效果 -->
            <Border CornerRadius="8" 
                    Margin="8"
                    Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2" Color="Black"/>
                </Border.Effect>

                <Grid>
                    <materialDesign:DialogHost Identifier="RootDialogHost">
                        <ContentControl x:Name="MainRegionHost" 
                                       Margin="16" 
                                       Content="{Binding CurrentContent}"
                                       Style="{StaticResource FadeInAnimation}"/>
                    </materialDesign:DialogHost>
                </Grid>
            </Border>
        </ui:NavigationView>
    </Grid>
</Window>
